---
import DarkModeToggle from './DarkModeToggle.astro';
import LanguageSwitch from './LanguageSwitch.astro';
import type { CVData } from '../lib/types';

interface Props {
  data: CVData;
  lang: 'de' | 'en';
}

const { data, lang } = Astro.props;
const { profile, contact, ui } = data;
const pdfUrl = `/pdfs/Michael_Boiman_CV_${lang.toUpperCase()}.pdf`;

const iconPaths: Record<string, string> = {
  'fa-envelope': 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
  'fa-phone': 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z',
  'fa-globe': 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9',
  'fa-linkedin': 'M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z',
  'fa-github': 'M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z',
  'fa-twitter': 'M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z',
};

function isFillIcon(icon: string) {
  return icon === 'fa-github' || icon === 'fa-linkedin';
}
---

<header class="relative overflow-hidden" style={`background: linear-gradient(135deg, var(--color-header-from) 0%, var(--color-header-to) 60%, ${lang === 'de' ? '#1a3a4a' : '#1a3a4a'} 100%)`}>
  <!-- Subtle geometric pattern -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"></div>

  <div class="relative max-w-6xl mx-auto">
    <!-- Top bar -->
    <div class="flex items-center justify-between px-6 pt-4 no-print">
      <!-- PDF Download -->
      <a
        href={pdfUrl}
        download
        class="flex items-center gap-2 text-sm text-white/70 hover:text-white transition-colors cursor-pointer group"
      >
        <svg class="w-4 h-4 group-hover:translate-y-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        <span>{ui.pdf_download}</span>
      </a>

      <div class="flex items-center gap-3">
        <LanguageSwitch currentLang={lang} />
        <DarkModeToggle />
      </div>
    </div>

    <!-- Profile Section -->
    <div class="px-6 pb-10 pt-6">
      <div class="flex flex-col sm:flex-row items-center sm:items-start gap-8">
        <!-- Profile photo with glow ring -->
        <div class="relative flex-shrink-0">
          <div class="absolute -inset-1 bg-gradient-to-r from-teal-400 to-cyan-300 rounded-full opacity-30 blur-sm"></div>
          <img
            src="/images/profile.png"
            alt={profile.name}
            class="relative w-32 h-32 rounded-full border-4 border-white/10 shadow-2xl object-cover"
            width="128"
            height="128"
          />
        </div>

        <div class="text-center sm:text-left text-white">
          <h1 class="text-4xl sm:text-5xl font-heading font-bold tracking-tight">
            {profile.name}
          </h1>
          <p class="mt-3 text-lg text-white/80 max-w-2xl leading-relaxed">
            {ui.tagline}
          </p>

          <!-- Contact grid -->
          {contact.enable && (
            <div class="mt-6 flex flex-wrap gap-x-5 gap-y-2.5 justify-center sm:justify-start">
              {contact.list.map((item) => (
                <a
                  href={item.url || '#'}
                  target={item.url?.startsWith('mailto:') ? '_self' : '_blank'}
                  rel="noopener"
                  class="flex items-center gap-2 text-sm text-white/60 hover:text-white transition-colors cursor-pointer"
                >
                  <svg class="w-4 h-4 flex-shrink-0" fill={isFillIcon(item.icon) ? 'currentColor' : 'none'} viewBox="0 0 24 24" stroke={isFillIcon(item.icon) ? 'none' : 'currentColor'} stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[item.icon] || iconPaths['fa-globe']} />
                  </svg>
                  <span>{item.title}</span>
                </a>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</header>
