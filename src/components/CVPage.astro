---
import BaseLayout from '../layouts/BaseLayout.astro';
import DarkModeToggle from './DarkModeToggle.astro';
import { getCVData } from '../lib/toml-loader';
import { formatToHTML, formatMarkdown } from '../lib/markdown';
import { i18n } from '../lib/i18n';

interface Props {
  lang: 'de' | 'en';
}

const { lang } = Astro.props;
const otherLang = lang === 'de' ? 'en' : 'de';
const t = i18n[lang];

const data = getCVData(lang);
const { profile, contact, ui, experiences, projects, summary, education, language: langs, skills, agent_proof } = data;

const featuredProjects = projects.list.filter(p => p.featured);
const otherProjects = projects.list.filter(p => !p.featured);
const agentProof = agent_proof ?? {
  eyebrow: lang === 'de' ? 'Live Proof statt Portfolio-Behauptung' : 'Live proof, not a portfolio claim',
  headline: lang === 'de' ? 'Mein CV hat einen eigenen A2A-Agenten.' : 'This CV has its own A2A agent.',
  text: lang === 'de'
    ? 'Er beantwortet Fragen zu Erfahrung und Stack, liest freie Zeitslots nur als Free/Busy und kann Terminwünsche an mich weitergeben.'
    : 'It answers questions about experience and stack, reads availability as free/busy only, and can hand meeting requests to me.',
  status: lang === 'de' ? 'Live auf mboiman.bks-lab.com' : 'Live at mboiman.bks-lab.com',
  card: lang === 'de' ? 'A2A-Agent-Card' : 'A2A Agent Card',
  endpoint: 'JSON-RPC · Streaming · Free/Busy · Handoff',
  ask: lang === 'de' ? 'Agent fragen' : 'Ask the agent',
  promptTitle: lang === 'de' ? 'Schnell fragen' : 'Try a question',
  prompts: [
    lang === 'de' ? 'Passt Michael für AI-QA in regulierten Systemen?' : 'Is Michael a fit for AI-QA in regulated systems?',
    lang === 'de' ? 'Wann hat Michael nächste Woche Zeit für ein Gespräch?' : 'When is Michael available next week?',
    lang === 'de' ? 'Welche Erfahrung hat Michael mit KI-Agenten?' : 'What is Michael’s experience with AI agents?',
  ],
  facts: ['A2A 0.3', 'Streaming', '4 Skills', 'Free/Busy'],
};

const skillGroupConfig = lang === 'de'
  ? [
      { title: 'Quality Engineering', test: /quality|playwright|cucumber|gauge|jmeter|gatling/i },
      { title: 'KI & Agenten', test: /llm|claude|gemini|gpt|copilot|mcp|a2a|adk|langchain/i },
      { title: 'Delivery & Automation', test: /ci\/cd|docker|kubernetes|python|rest/i },
      { title: 'Plattform & Monitoring', test: /grafana|elastic|peppol|e-invoicing|azure/i },
    ]
  : [
      { title: 'Quality Engineering', test: /quality|playwright|cucumber|gauge|jmeter|gatling/i },
      { title: 'AI & Agents', test: /llm|claude|gemini|gpt|copilot|mcp|a2a|adk|langchain/i },
      { title: 'Delivery & Automation', test: /ci\/cd|docker|kubernetes|python|rest/i },
      { title: 'Platform & Monitoring', test: /grafana|elastic|peppol|e-invoicing|azure/i },
    ];

const sidebarSkillGroups = skillGroupConfig.map(group => ({
  title: group.title,
  skills: ui.sidebar_skills.filter(skill => group.test.test(skill)),
})).filter(group => group.skills.length > 0);

// Separate talks/workshops from regular positions (mirrors the PDF's isWorkshopOrPresentation)
const isTalk = (exp: { position: string; company?: string }) => {
  const p = (exp.position || '').toLowerCase();
  const c = (exp.company || '').toLowerCase();
  return /workshop|präsentation|presentation|impulsvortrag|vortrag|lecture|anwendungen von ki/.test(p)
      || /workshop|präsentation/.test(c);
};
const jobs = experiences.list.filter(e => !isTalk(e));
const talks = experiences.list.filter(isTalk);

// Keep intro + tools section, remove verbose middle (Schwerpunkte bullet lists)
function truncateDetails(details: string): string {
  const lines = details.split('\n');
  const introLines: string[] = [];
  const toolLines: string[] = [];
  let inTools = false;
  let inSchwerpunkte = false;

  const schwerpunktePattern = new RegExp(`^\\*\\*(${t.truncatePatterns.join('|')})`);
  const toolPattern = new RegExp(`^\\*\\*(${t.truncateToolPatterns.join('|')})`);

  for (const line of lines) {
    if (line.match(schwerpunktePattern)) {
      inSchwerpunkte = true;
      inTools = false;
      continue;
    }
    if (line.match(toolPattern)) {
      inSchwerpunkte = false;
      inTools = true;
      toolLines.push(line);
      continue;
    }
    if (!inSchwerpunkte && !inTools) {
      introLines.push(line);
    } else if (inTools) {
      toolLines.push(line);
    }
  }

  // Combine intro (limited) + tools
  let intro = introLines.join('\n').trim();
  const introWords = intro.split(/\s+/);
  if (introWords.length > 80) {
    const clipped = introWords.slice(0, 80).join(' ');
    // Back up to the last sentence end so we never cut mid-thought
    const lastStop = Math.max(clipped.lastIndexOf('. '), clipped.lastIndexOf('! '), clipped.lastIndexOf('? '));
    intro = lastStop > 40 ? clipped.slice(0, lastStop + 1) : clipped + '…';
  }

  const tools = toolLines.join('\n').trim();
  return tools ? intro + '\n\n' + tools : intro;
}
---

<BaseLayout
  title={`${profile.name} — ${ui.tagline}`}
  description={ui.tagline}
  lang={lang}
>
  <!-- Header -->
  <header class="cv-hero relative overflow-hidden px-6 sm:px-8">
    <div class="relative max-w-6xl mx-auto pt-6 pb-14 lg:pb-16">
      <!-- Top bar -->
      <div class="flex items-center justify-between mb-8 text-sm">
        <a href={`/${lang}/story/`} class="group opacity-70 hover:opacity-100 transition-all cursor-pointer flex items-center gap-2" style="color: var(--accent)">
          <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
          {t.experienceTheStory}
        </a>
        <div class="flex items-center gap-3">
          <a href="/de/" class={lang === 'de' ? 'cv-lang-link is-active' : 'cv-lang-link'}>DE</a>
          <span class="opacity-20">|</span>
          <a href="/en/" class={lang === 'en' ? 'cv-lang-link is-active' : 'cv-lang-link'}>EN</a>
          <span class="opacity-20">|</span>
          <DarkModeToggle />
        </div>
      </div>

      <!-- Profile + live agent proof -->
      <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1.1fr)_minmax(340px,0.7fr)] gap-9 lg:gap-12 items-center">
        <div class="text-center sm:text-left">
          <div class="cv-kicker inline-flex items-center gap-2 rounded-full px-3 py-1.5 text-[11px] font-medium uppercase tracking-[0.16em]">
            <span class="h-1.5 w-1.5 rounded-full" style="background: var(--accent)"></span>
            {agentProof.eyebrow}
          </div>

          <div class="mt-7 flex flex-col sm:flex-row items-center sm:items-start gap-5">
            <div class="relative flex-shrink-0">
              <div class="absolute -inset-1 rounded-full opacity-45 blur-md" style="background: var(--accent)"></div>
              <img src="/images/profile_.jpg" alt={profile.name} class="cv-avatar relative w-[5.5rem] h-[5.5rem] sm:w-24 sm:h-24 rounded-full object-cover grayscale-[10%]" width="96" height="96" />
            </div>
            <div class="min-w-0">
              <h1 class="text-4xl sm:text-5xl lg:text-[4.75rem] font-light tracking-[-0.02em] font-sans leading-[1.02] cv-hero-title">{profile.name}</h1>
              <p class="cv-tagline mt-3 max-w-2xl text-base sm:text-lg">{ui.tagline}</p>
            </div>
          </div>

          <p class="cv-proof-text mt-6 max-w-[42rem] text-[15px] leading-[1.75]">
            {agentProof.text}
          </p>

          <!-- Contact -->
          <div class="mt-5 flex flex-wrap items-center justify-center sm:justify-start gap-2 text-sm">
            {contact.list.slice(0, 6).map(item => (
              <a href={item.url || '#'} target={item.url?.startsWith('mailto:') ? '_self' : '_blank'} rel="noopener" class="cv-contact-link cursor-pointer">{item.title}</a>
            ))}
          </div>

          <!-- CTAs -->
          <div class="mt-5 flex flex-wrap justify-center sm:justify-start gap-3">
            <button type="button" data-agent-prompt={agentProof.prompts[0]} class="cv-primary-cta px-5 py-2.5 rounded-lg text-sm font-semibold transition-colors cursor-pointer flex items-center gap-2">
              {agentProof.ask}
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M21 12c0 4.418-4.03 8-9 8a9.77 9.77 0 01-4-.83L3 20l1.36-3.4A7.68 7.68 0 013 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
            </button>
            <a href={`/pdfs/Michael_Boiman_CV_${lang.toUpperCase()}.pdf`} download class="cv-secondary-cta px-5 py-2.5 rounded-lg text-sm font-medium transition-colors cursor-pointer flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
              {t.pdfDownload}
            </a>
            <a href={`/${lang}/story/`} class="cv-secondary-cta px-5 py-2.5 rounded-lg text-sm font-medium transition-colors cursor-pointer flex items-center gap-2">
              {t.experienceTheStory}
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
            </a>
          </div>
        </div>

        <div class="cv-agent-card rounded-2xl p-5 lg:p-5">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-[11px] font-semibold uppercase tracking-[0.16em]" style="color: var(--accent)">{agentProof.card}</p>
              <h2 class="mt-2 text-xl sm:text-[1.55rem] font-sans font-light tracking-[-0.01em] leading-tight">{agentProof.headline}</h2>
            </div>
            <span class="cv-live-badge inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-[11px] font-medium flex-shrink-0">
              <span class="h-1.5 w-1.5 rounded-full"></span>
              Live
            </span>
          </div>

          <div class="mt-4 rounded-xl p-4 cv-agent-terminal">
            <p class="text-sm font-medium">{agentProof.status}</p>
            <p class="mt-1 text-xs leading-relaxed" style="color: var(--text-secondary)">{agentProof.endpoint}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {agentProof.facts.map(fact => (
                <span class="cv-agent-fact rounded-full px-2.5 py-1 text-[11px]">{fact}</span>
              ))}
            </div>
          </div>

          <div class="mt-4">
            <p class="mb-2 text-[11px] font-semibold uppercase tracking-[0.14em]" style="color: var(--text-secondary)">{agentProof.promptTitle}</p>
            <div class="space-y-2">
              {agentProof.prompts.map(prompt => (
                <button type="button" data-agent-prompt={prompt} class="cv-prompt-button w-full rounded-lg px-3 py-2 text-left text-sm leading-snug transition">
                  {prompt}
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- Main Layout -->
  <div class="max-w-6xl mx-auto px-4 sm:px-8 py-12">
    <div class="flex flex-col lg:flex-row gap-12">

      <!-- Main Content (70%) -->
      <main id="main" class="lg:w-[70%] space-y-14">

        <!-- Karriereprofil -->
        {summary.enable && (
          <section>
            <h2 class="cv-section-title">{summary.title}</h2>

            <!-- Intro -->
            <p class="text-[15px] leading-[1.85] mb-8" style="color: var(--text-secondary)">
              {t.careerIntro}
            </p>

            <!-- Impact-Highlights -->
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
              {t.cvImpactMetrics.map(item => (
                <div class="cv-metric-card p-4 rounded-xl text-center">
                  <p class="text-2xl font-light font-sans tracking-[-0.02em]" style="color: var(--accent)">{item.metric}</p>
                  <p class="text-sm font-medium mt-1">{item.label}</p>
                  <p class="text-xs mt-0.5" style="color: var(--text-secondary)">{item.detail}</p>
                </div>
              ))}
            </div>

            <!-- Details -->
            <div class="space-y-3 text-[14px] leading-[1.85]" style="color: var(--text-secondary)">
              {t.careerDetails.map(detail => (
                <p set:html={detail} />
              ))}
            </div>
          </section>
        )}

        <!-- PROJEKTE VOR ERFAHRUNG -->
        {projects.enable && (
          <section>
            <h2 class="cv-section-title">{projects.title}</h2>
            <p class="text-sm mb-6" style="color: var(--text-secondary)" set:html={formatMarkdown(projects.intro)} />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {featuredProjects.map(project => (
                <div class="cv-project-card rounded-xl overflow-hidden cursor-pointer group">
                  {project.screenshot && (
                    <div class="h-40 overflow-hidden relative">
                      <img src={`/images/${project.screenshot}`} alt={project.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/16 to-transparent"></div>
                      <p class="absolute bottom-3 left-4 text-[10px] tracking-[0.2em] uppercase text-white/80">{project.category}</p>
                    </div>
                  )}
                  {!project.screenshot && (
                    <div class="px-5 pt-4">
                      <p class="text-[10px] tracking-[0.2em] uppercase" style="color: var(--accent)">{project.category}</p>
                    </div>
                  )}
                  <div class="p-5">
                    <h3 class="text-base font-medium font-sans mb-2 leading-tight">
                      {project.url ? (
                        <a href={project.url} target="_blank" rel="noopener" class="hover:text-[var(--accent)] transition-colors inline-flex items-center gap-1.5">
                          {project.title}
                          <svg class="w-3.5 h-3.5 opacity-40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                        </a>
                      ) : project.title}
                    </h3>

                    {project.tech_stack?.length > 0 && (
                      <div class="flex flex-wrap gap-1.5 mb-3">
                        {project.tech_stack.slice(0, 6).map(tech => (
                          <span class="cv-tech-chip text-[10px] px-2 py-0.5 rounded-md font-medium">{tech}</span>
                        ))}
                        {project.tech_stack.length > 6 && (
                          <span class="text-[10px] px-2 py-0.5 rounded-md" style="color: var(--text-secondary)">+{project.tech_stack.length - 6}</span>
                        )}
                      </div>
                    )}

                    <div class="project-copy text-[13px] leading-[1.75] [&_strong]:font-medium [&_strong]:text-[var(--text)]" style="color: var(--text-secondary)" set:html={formatMarkdown(project.tagline)} />
                  </div>
                </div>
              ))}
            </div>

            {otherProjects.length > 0 && (
              <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
                {otherProjects.map(project => (
                  <div class="cv-mini-project p-4 rounded-lg">
                    <p class="text-[10px] tracking-[0.15em] uppercase mb-1" style="color: var(--accent)">{project.category}</p>
                    <h4 class="text-sm font-medium font-sans mb-1">{project.title}</h4>
                    {project.tech_stack?.length > 0 && (
                      <p class="text-[10px]" style="color: var(--text-secondary)">{project.tech_stack.slice(0, 4).join(' · ')}</p>
                    )}
                  </div>
                ))}
              </div>
            )}
          </section>
        )}

        <!-- Berufserfahrung -->
        {experiences.enable && (
          <section>
            <h2 class="cv-section-title">{experiences.title}</h2>
            <div class="cv-timeline space-y-6 relative ml-3 pl-7">
              {jobs.map((exp, i) => (
                <div class="relative">
                  <!-- Timeline dot -->
                  <div class="absolute -left-[33px] top-2 w-3 h-3 rounded-full border-2 bg-[var(--bg)]" style="border-color: var(--accent)"></div>

                  <div class="cv-experience-card p-6 rounded-xl">
                    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-3">
                      <div>
                        <h3 class="text-[15px] font-medium font-sans leading-snug" style="color: var(--accent)">{exp.position}</h3>
                        <p class="text-sm mt-1 font-medium" style="color: var(--text-secondary)">{exp.company}</p>
                      </div>
                      <span class="cv-date-pill text-[11px] font-medium px-2.5 py-1 rounded-md whitespace-nowrap self-start">{exp.dates}</span>
                    </div>
                    <div class="text-[13px] leading-[1.9] [&_strong]:font-medium [&_strong]:text-[var(--text)] [&_p]:mb-3" style="color: var(--text-secondary)" set:html={formatToHTML(truncateDetails(exp.details))} />
                  </div>
                </div>
              ))}
            </div>
          </section>
        )}

        <!-- Vorträge & Workshops -->
        {talks.length > 0 && (
          <section>
            <h2 class="cv-section-title">{t.talksTitle}</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {talks.map(talk => (
                  <div class="cv-mini-project p-4 rounded-lg">
                  <h3 class="text-sm font-medium font-sans leading-snug" style="color: var(--accent)">{talk.position}</h3>
                  <p class="text-xs mt-1" style="color: var(--text-secondary)">{talk.company}</p>
                  <span class="cv-date-pill inline-block mt-2 text-[11px] font-medium px-2 py-0.5 rounded-md">{talk.dates}</span>
                </div>
              ))}
            </div>
          </section>
        )}
      </main>

      <!-- Sidebar (30%) -->
      <aside class="lg:w-[30%]">
        <div class="sticky top-6 space-y-6">

          <!-- Skills -->
          <div class="cv-sidebar-card">
            <h3 class="cv-sidebar-title">{ui.sidebar_skills_title}</h3>
            <div class="space-y-4">
              {sidebarSkillGroups.map(group => (
                <div>
                  <p class="cv-skill-group-title">{group.title}</p>
                  <div class="mt-2 flex flex-wrap gap-1.5">
                    {group.skills.map(skill => (
                      <span class="cv-skill-chip text-xs px-2.5 py-1 rounded-full cursor-default">{skill}</span>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Education -->
          {education.enable && (
            <div class="cv-sidebar-card">
              <h3 class="cv-sidebar-title">{education.title}</h3>
              <div class="space-y-3">
                {education.list.map(edu => (
                  <div>
                    <p class="text-sm font-medium">{edu.degree}</p>
                    {edu.college && <p class="text-xs mt-0.5" style="color: var(--text-secondary)">{edu.college}</p>}
                    <p class="text-xs" style="color: var(--text-secondary)">{edu.dates}</p>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Languages -->
          {langs.enable && (
            <div class="cv-sidebar-card">
              <h3 class="cv-sidebar-title">{langs.title}</h3>
              <div class="space-y-2.5">
                {langs.list.map(l => (
                  <div class="flex justify-between items-center text-sm">
                    <span>{l.language}</span>
                    <span class="cv-date-pill text-[11px] px-2.5 py-0.5 rounded-md font-medium">{l.level}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Certifications -->
          <div class="cv-sidebar-card">
            <h3 class="cv-sidebar-title">{ui.sidebar_qualifications_title}</h3>
            <div class="space-y-2.5 text-sm">
              {['ISTQB Certified Tester', 'Dynatrace Diagnostics', 'Agile (Scrum/Kanban)'].map(cert => (
                <div class="flex items-center gap-2.5">
                  <div class="w-1.5 h-1.5 rounded-full flex-shrink-0" style="background: var(--accent)"></div>
                  <span>{cert}</span>
                </div>
              ))}
            </div>
          </div>

        </div>
      </aside>

    </div>
  </div>

  <!-- Footer -->
  <footer class="py-10 px-6 text-center text-sm border-t" style="color: var(--text-secondary); border-color: var(--line)">
    <p>&copy; {new Date().getFullYear()} {profile.name} &middot; BKS-Lab &middot; Frankfurt am Main</p>
    <p class="mt-3 text-xs opacity-60">
      <a href={`/${lang}/story/`} class="hover:opacity-100 transition-opacity">{t.experienceTheStory}</a>
      &nbsp;&middot;&nbsp;
      <a href={`/pdfs/Michael_Boiman_CV_${lang.toUpperCase()}.pdf`} class="hover:opacity-100 transition-opacity">PDF</a>
      &nbsp;&middot;&nbsp;
      <a href={`/${otherLang}/`} class="hover:opacity-100 transition-opacity">{t.cvFooterOtherLang}</a>
    </p>
  </footer>

  <script>
    document.querySelectorAll('[data-agent-prompt]').forEach((button) => {
      button.addEventListener('click', () => {
        const text = button.getAttribute('data-agent-prompt') || '';
        window.dispatchEvent(new CustomEvent('bridge-agent:prompt', { detail: { text } }));
      });
    });
  </script>
</BaseLayout>

<style>
  .cv-hero :is(h1, h2, h3, h4),
  main :is(h2, h3, h4),
  aside :is(h3, h4) {
    font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
  }

  .cv-hero {
    color: var(--text);
    background:
      radial-gradient(circle at 18% 8%, color-mix(in srgb, var(--accent) 16%, transparent), transparent 28rem),
      radial-gradient(circle at 84% 18%, color-mix(in srgb, var(--accent-hover) 8%, transparent), transparent 24rem),
      linear-gradient(180deg, var(--surface) 0%, var(--bg) 100%);
    border-bottom: 1px solid var(--line);
  }

  .cv-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.5;
    background-image:
      linear-gradient(color-mix(in srgb, var(--text) 5%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in srgb, var(--text) 5%, transparent) 1px, transparent 1px);
    background-size: 44px 44px;
    mask-image: linear-gradient(to bottom, black, transparent 88%);
  }

  .cv-hero::after {
    content: "";
    position: absolute;
    inset-x: 0;
    bottom: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--accent) 32%, transparent), transparent);
  }

  .cv-hero-title {
    color: var(--text);
    text-shadow: none;
