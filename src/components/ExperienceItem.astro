---
import { formatToHTML } from '../lib/markdown';
import type { ExperienceItem as ExpType } from '../lib/types';

interface Props {
  experience: ExpType;
}

const { experience } = Astro.props;
const detailsHtml = formatToHTML(experience.details);
---

<div class="relative pl-8 pb-8 last:pb-0 group">
  <!-- Timeline dot -->
  <div class="absolute left-0 top-1 w-3 h-3 rounded-full border-2 border-[var(--color-accent)] bg-[var(--color-bg)] transition-colors duration-300 group-hover:bg-[var(--color-accent)]"></div>

  <!-- Content -->
  <div class="card">
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-3">
      <div>
        <h3 class="font-heading font-semibold text-base" style="color: var(--color-accent)">
          {experience.position}
        </h3>
        <p class="text-sm text-[var(--color-muted)]">{experience.company}</p>
      </div>
      <span class="text-xs font-medium px-3 py-1 rounded-full whitespace-nowrap bg-[var(--color-surface-alt)] text-[var(--color-muted)]">
        {experience.dates}
      </span>
    </div>

    <div class="text-sm leading-relaxed text-[var(--color-text)] prose prose-sm max-w-none dark:prose-invert" set:html={detailsHtml} />
  </div>
</div>
