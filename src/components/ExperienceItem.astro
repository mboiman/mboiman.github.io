---
import { formatToHTML } from '../lib/markdown';
import type { ExperienceItem as ExpType } from '../lib/types';

interface Props {
  experience: ExpType;
  index?: number;
}

const { experience, index = 0 } = Astro.props;
const detailsHtml = formatToHTML(experience.details);
---

<div class="relative pl-10 pb-10 last:pb-0 reveal" style={`transition-delay: ${index * 60}ms`}>
  <!-- Timeline dot -->
  <div class="absolute left-0 top-2 z-10">
    <div class="w-3 h-3 rounded-full border-2 border-[var(--color-accent)] bg-[var(--color-bg)] transition-all duration-300"></div>
  </div>

  <!-- Content card -->
  <div class="card">
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-4">
      <div>
        <h3 class="font-heading font-semibold text-base leading-tight" style="color: var(--color-accent)">
          {experience.position}
        </h3>
        <p class="text-sm text-[var(--color-muted)] mt-0.5">{experience.company}</p>
      </div>
      <span class="text-[11px] font-semibold px-3 py-1.5 rounded-lg whitespace-nowrap self-start" style="background-color: var(--color-accent-light); color: var(--color-accent);">
        {experience.dates}
      </span>
    </div>

    <div
      class="text-sm leading-relaxed text-[var(--color-text)] [&_strong]:text-[var(--color-accent)] [&_strong]:font-semibold"
      set:html={detailsHtml}
    />
  </div>
</div>
