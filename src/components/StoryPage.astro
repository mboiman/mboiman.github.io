---
import BaseLayout from '../layouts/BaseLayout.astro';
import DarkModeToggle from './DarkModeToggle.astro';
import { getCVData } from '../lib/toml-loader';
import { formatToHTML, formatMarkdown } from '../lib/markdown';
import { i18n, darkScreenshots } from '../lib/i18n';

interface Props {
  lang: 'de' | 'en';
}

const { lang } = Astro.props;
const otherLang = lang === 'de' ? 'en' : 'de';
const t = i18n[lang];
const screenshots = darkScreenshots[lang];

const data = getCVData(lang);
const { profile, contact, ui, experiences, projects, summary, education, language: langs, skills } = data;

const featuredProjects = projects.list.filter(p => p.featured).slice(0, 5);
const recentExp = experiences.list.slice(0, 5);
const olderExp = experiences.list.slice(5);

const storyTitle = lang === 'de'
  ? `${profile.name} — Projekt-Story`
  : `${profile.name} — Project Story`;
---

<BaseLayout
  title={storyTitle}
  description={ui.story_seo_description}
  lang={lang}
>
  <div class="story-page">
  <!-- Scroll progress bar -->
  <div id="scroll-progress" style="width: 0%"></div>

  <!-- ═══ FLOATING NAV ═══ -->
  <header>
    <nav class="fixed top-0 left-0 right-0 z-50 no-print story-nav" id="floating-nav">
      <div class="max-w-6xl mx-auto px-6 py-3 flex items-center justify-between">
        <div class="flex items-center gap-4">
          <!-- Always-visible escape hatch back to the CV — a presentation must
               never be a dead end (was missing entirely). Kept out of the
               scroll-gated tabindex toggle below so it stays keyboard-reachable. -->
          <a href={`/${lang}/`} class="story-back text-xs tracking-[0.1em] uppercase opacity-60 hover:opacity-100 transition-opacity duration-300 cursor-pointer min-h-[44px] flex items-center gap-1.5" style="color: var(--text-secondary)" aria-label={t.storyBackToCv}>
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
            <span>{t.storyBackToCv}</span>
          </a>
          <a href={`/pdfs/Michael_Boiman_CV_${lang.toUpperCase()}.pdf`} download class="text-xs tracking-[0.1em] uppercase opacity-0 hover:opacity-80 transition-all duration-500 cursor-pointer min-h-[44px] min-w-[44px] flex items-center" style="color: var(--text-secondary)" id="nav-pdf" tabindex="-1">
            {t.pdfDownload}
          </a>
        </div>
        <div class="flex items-center gap-2 opacity-0 transition-all duration-500" id="nav-right">
          <span class="story-key-hint hidden sm:inline-flex">← →</span>
          <a href="/de/story/" class={`text-xs ${lang === 'de' ? 'font-semibold' : 'opacity-50 hover:opacity-100 transition-opacity'} min-h-[44px] min-w-[44px] flex items-center justify-center`} style={lang === 'de' ? 'color: var(--text)' : 'color: var(--text-secondary)'} tabindex="-1">DE</a>
          <span class="text-xs" style="color: var(--text-secondary); opacity: 0.3">|</span>
          <a href="/en/story/" class={`text-xs ${lang === 'en' ? 'font-semibold' : 'opacity-50 hover:opacity-100 transition-opacity'} min-h-[44px] min-w-[44px] flex items-center justify-center`} style={lang === 'en' ? 'color: var(--text)' : 'color: var(--text-secondary)'} tabindex="-1">EN</a>
          <DarkModeToggle />
        </div>
      </div>
    </nav>
  </header>

  <!-- ═══ ACT 1: THE STATEMENT ═══ -->
  <section class="act" aria-label={t.ariaStatement}>
    <div class="text-center max-w-5xl">
      <p class="text-sm tracking-[0.2em] uppercase mb-12 opacity-0 animate-[fadeIn_1s_ease_0.3s_forwards]" style="color: var(--text-secondary)">
        {t.storyEyebrow}
      </p>
      <h1 class="story-display text-[clamp(2.5rem,7vw,7rem)] leading-[1.03] opacity-0 animate-[fadeIn_1.2s_ease_0.8s_forwards]" set:html={t.storyStatement} />
      <div class="mt-16 opacity-0 animate-[fadeIn_1s_ease_2s_forwards]">
        <div class="teal-rule"></div>
      </div>
      <!-- Scroll hint -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 opacity-0 animate-[fadeIn_1s_ease_2.5s_forwards] no-print" aria-hidden="true">
        <svg class="w-5 h-5 animate-[scrollHint_2s_ease-in-out_infinite]" style="color: var(--text-secondary)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7" />
        </svg>
      </div>
    </div>
  </section>

  <main id="main">

  <!-- ═══ ACT 1.5: THE PORTRAIT REVEAL ═══ -->
  <section class="flex flex-col items-center justify-center pt-0 pb-32 px-6 -mt-16 relative z-10" aria-label="Portrait">
    <div class="reveal max-w-md mx-auto">
      <div class="relative">
        <div class="absolute -inset-16 rounded-full opacity-[0.1] blur-3xl" style="background: var(--accent)" aria-hidden="true"></div>
        <img
          src="/images/profile_.jpg"
          alt={profile.name}
          class="relative w-full max-w-[360px] mx-auto"
          style="filter: contrast(1.05); mix-blend-mode: luminosity;"
          width="360"
          height="480"
        />
      </div>
      <p class="story-heading text-center mt-10 text-3xl sm:text-4xl tracking-tight">
        {profile.name}
      </p>
      <p class="text-center mt-2 text-sm tracking-[0.15em] uppercase" style="color: var(--accent)">
        {t.storyRole}
      </p>
      <p class="text-center mt-2 text-sm tracking-[0.1em]" style="color: var(--text-secondary)">
        Frankfurt am Main
      </p>
      <p class="text-center mt-8 text-sm leading-relaxed max-w-xs mx-auto" style="color: var(--text-secondary)">
        {t.availability}
      </p>
    </div>
  </section>

  <!-- ═══ ACT 2: NUMBERS + IMPACT ═══ -->
  <section class="py-32 px-6" aria-label={t.ariaNumbers} style="background-color: var(--bg-alt)">
    <div class="max-w-4xl mx-auto w-full">
      <!-- Hero numbers -->
      <div class="flex flex-col sm:flex-row sm:justify-center sm:gap-20 gap-8 mb-20">
        {t.numberLabels.map((item, i) => (
          <div class="reveal text-center sm:text-left" style={`transition-delay: ${i * 150}ms`}>
            <span class="story-number text-[clamp(4rem,12vw,9rem)] leading-none block">
              {item.num}
            </span>
            <span class="text-sm sm:text-base tracking-wide mt-2 block" style="color: var(--text-secondary)">
              {item.label}
            </span>
          </div>
        ))}
      </div>

      <!-- Impact metrics -->
      <div class="story-separator border-t pt-16">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
          {t.impactMetrics.map((item, i) => (
            <div class="text-center reveal" style={`transition-delay: ${(i + 2) * 150}ms`}>
              <p class="story-metric text-3xl sm:text-4xl tracking-tight" style="color: var(--accent)">{item.metric}</p>
              <p class="text-sm font-medium mt-2">{item.label}</p>
              <p class="text-xs mt-1" style="color: var(--text-secondary)">{item.detail}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ ACT 3: THE ORIGIN (kompakt) ═══ -->
  <section class="py-32 px-6" aria-label={t.ariaProfile}>
    <div class="prose-column">
      <div class="reveal">
        <div class="teal-rule mb-20"></div>
        <p class="story-quote text-xl sm:text-2xl leading-[1.8]" style="color: var(--text-secondary)">
          {t.originQuote}
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ ACT 4: SELECTED WORKS (Gamma-style) ═══ -->
  <section aria-label={t.ariaProjects}>
    {featuredProjects.map((project, i) => {
      const bgImage = screenshots[project.title];
      const hasGamma = project.challenge && project.metric;
      return (
        <div
          class="relative px-6 py-28 reveal overflow-hidden"
          style={`transition-delay: ${i * 80}ms; background-color: ${i % 2 === 0 ? 'var(--bg-alt)' : 'var(--bg)'}`}
        >
          {bgImage && (
            <div class="absolute inset-0 opacity-[0.04] bg-cover bg-center" style={`background-image: url('${bgImage}')`}></div>
          )}
          <div class="relative max-w-5xl mx-auto">
            <div class="flex flex-wrap items-center gap-4 mb-8">
              <span class="text-[10px] tracking-[0.25em] uppercase" style="color: var(--accent)">{project.category}</span>
              {project.tech_stack?.length > 0 && (
                <span class="text-[10px] tracking-wider uppercase hidden sm:inline" style="color: var(--text-secondary); opacity: 0.5">
                  {project.tech_stack.slice(0, 4).join(' / ')}
                </span>
              )}
            </div>

            <h3 class="story-project-title text-2xl sm:text-4xl lg:text-5xl mb-12 tracking-tight leading-tight">{project.title}</h3>

            {hasGamma ? (
              <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-12 lg:gap-20 items-start">
                <div class="space-y-10">
                  <div>
                    <p class="text-[10px] tracking-[0.25em] uppercase mb-3" style="color: var(--accent); opacity: 0.7">{t.gammaLabels.challenge}</p>
                    <p class="text-base sm:text-lg leading-relaxed font-light" style="color: var(--text-secondary)">{project.challenge}</p>
                  </div>
                  <div>
                    <p class="text-[10px] tracking-[0.25em] uppercase mb-3" style="color: var(--accent); opacity: 0.7">{t.gammaLabels.solution}</p>
                    <p class="text-base leading-relaxed" style="color: var(--text-secondary)">{project.solution}</p>
                  </div>
                  {project.impact && (
                    <div class="pt-4" style="border-top: 1px solid var(--line)">
                      <p class="text-sm leading-relaxed" style="color: var(--text-secondary)">
                      <span style="color: var(--accent)">→</span> {project.impact}
                      </p>
                    </div>
                  )}
                </div>
                <div class="flex flex-col items-start lg:items-end justify-center lg:min-w-[180px]">
                  <span class="story-project-metric text-[clamp(3rem,10vw,6rem)] leading-none tracking-tight" style="color: var(--accent)">{project.metric}</span>
                  <span class="text-sm mt-2 tracking-wide" style="color: var(--text-secondary)">{project.metric_label}</span>
                </div>
              </div>
            ) : (
              <div class="max-w-3xl text-base leading-relaxed [&_strong]:text-[var(--text)] [&_strong]:font-medium" style="color: var(--text-secondary)" set:html={formatMarkdown(project.tagline)} />
            )}
          </div>
        </div>
      );
    })}
  </section>


  <!-- ═══ ACT 6: BELIEFS ═══ -->
  <section class="py-32 px-6" aria-label={t.ariaBeliefs} style="background-color: var(--bg-alt)">
    <div class="max-w-4xl mx-auto">
      {t.beliefs.map((belief, i) => (
        <div class={`reveal py-14 ${i < 3 ? 'story-separator border-b' : ''}`} style={`transition-delay: ${i * 200}ms`}>
          <div class={`relative max-w-lg ${belief.align === 'text-right' ? 'ml-auto' : belief.align === 'text-center' ? 'mx-auto' : ''}`}>
            <span class={`story-quote-mark absolute -top-6 text-[5rem] leading-none select-none pointer-events-none ${belief.align === 'text-right' ? '-right-3' : '-left-3'}`} aria-hidden="true">{belief.align === 'text-right' ? '\u201D' : '\u201C'}</span>
            <p class={`story-belief text-xl sm:text-2xl leading-snug whitespace-pre-line ${belief.align}`} style="color: var(--text-secondary)">
              {belief.text}
            </p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ ACT 7: EXPERIENCE ═══ -->
  <section class="py-32 px-6" aria-label={t.experienceTitle}>
    <div class="max-w-4xl mx-auto">
      <div class="teal-rule mb-20"></div>
      <h2 class="story-heading text-3xl sm:text-4xl text-center mb-20 reveal">{t.experienceTitle}</h2>

      <!-- Recent: full details -->
      {recentExp.map((exp, i) => (
        <div class="reveal mb-16 last:mb-0" style={`transition-delay: ${Math.min(i * 60, 300)}ms`}>
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-3">
            <h3 class="text-lg font-sans font-medium" style="color: var(--accent)">{exp.position}</h3>
            <span class="text-sm whitespace-nowrap" style="color: var(--text-secondary)">{exp.dates}</span>
          </div>
          <p class="text-sm mb-4" style="color: var(--text-secondary)">{exp.company}</p>
          <div class="text-sm leading-[1.9] [&_strong]:text-[var(--text)] [&_strong]:font-medium" style="color: var(--text-secondary)" set:html={formatToHTML(exp.details)} />
          {i < recentExp.length - 1 && (
            <div class="story-separator border-b mt-16"></div>
          )}
        </div>
      ))}

      <!-- Older: compact -->
      {olderExp.length > 0 && (
        <div class="mt-20 reveal">
          <div class="story-separator border-b mb-10"></div>
          <p class="text-xs tracking-[0.2em] uppercase mb-8" style="color: var(--text-secondary)">{t.earlierPositions}</p>
          {olderExp.map((exp) => (
            <div class="exp-compact">
              <div>
                <span class="text-sm font-medium" style="color: var(--text)">{exp.position}</span>
                <span class="text-sm ml-2" style="color: var(--text-secondary)">— {exp.company}</span>
              </div>
              <span class="text-xs whitespace-nowrap" style="color: var(--text-secondary)">{exp.dates}</span>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- ═══ ACT 7.5: EDUCATION & SKILLS ═══ -->
  <section class="py-20 px-6" aria-label={t.ariaEducation} style="background-color: var(--bg-alt)">
    <div class="max-w-4xl mx-auto reveal">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-12 text-sm">
        <!-- Education -->
        <div>
          <p class="text-[10px] tracking-[0.25em] uppercase mb-4" style="color: var(--accent)">{education.title}</p>
          {education.list.map(edu => (
            <div class="mb-3">
              <p class="font-medium">{edu.degree}</p>
              {edu.college && <p style="color: var(--text-secondary)">{edu.college}</p>}
              <p class="text-xs" style="color: var(--text-secondary)">{edu.dates}</p>
            </div>
          ))}
        </div>

        <!-- Languages -->
        <div>
          <p class="text-[10px] tracking-[0.25em] uppercase mb-4" style="color: var(--accent)">{langs.title}</p>
          {langs.list.map(l => (
            <div class="flex justify-between mb-2">
              <span>{l.language}</span>
              <span style="color: var(--text-secondary)">{l.level}</span>
            </div>
          ))}
        </div>

        <!-- Key Skills -->
        <div>
          <p class="text-[10px] tracking-[0.25em] uppercase mb-4" style="color: var(--accent)">Skills</p>
          <p class="leading-relaxed" style="color: var(--text-secondary)">
            {ui.sidebar_skills.join(' · ')}
          </p>
        </div>
      </div>
    </div>
  </section>

  </main>

  <!-- ═══ ACT 8: CLOSE ═══ -->
  <footer>
  <section class="act" aria-label={t.ariaContact}>
    <div class="text-center reveal">
      <p class="story-display text-5xl sm:text-7xl lg:text-8xl mb-6">{profile.name}</p>
      <p class="text-sm tracking-[0.2em] uppercase mb-10" style="color: var(--text-secondary)">
        {t.storyClosingEyebrow}
      </p>
      <p class="story-quote text-sm mb-10 max-w-md mx-auto" style="color: var(--text-secondary)">
        {t.closingLine}
      </p>

      <a href="mailto:mboiman@gmail.com" class="text-lg transition-colors duration-300 hover:opacity-80" style="color: var(--accent)">
        mboiman@gmail.com
      </a>
      <p class="mt-4 text-sm" style="color: var(--text-secondary)">
        <a href="https://www.linkedin.com/in/mboiman/" target="_blank" rel="noopener" class="hover:text-[var(--text)] transition-colors">LinkedIn</a>
        &nbsp;&middot;&nbsp;
        <a href="https://github.com/mboiman" target="_blank" rel="noopener" class="hover:text-[var(--text)] transition-colors">GitHub</a>
        &nbsp;&middot;&nbsp;
        <a href="https://bks-lab.com" target="_blank" rel="noopener" class="hover:text-[var(--text)] transition-colors">BKS-Lab</a>
      </p>

      <p class="mt-16 text-xs no-print" style="color: var(--text-secondary); opacity: 0.4">
        <a href={`/${lang}/`} class="hover:opacity-100 transition-opacity">{t.classicCV}</a>
        &nbsp;&middot;&nbsp;
        <a href={`/pdfs/Michael_Boiman_CV_${lang.toUpperCase()}.pdf`} class="hover:opacity-100 transition-opacity">PDF</a>
        &nbsp;&middot;&nbsp;
        <a href={`/${otherLang}/`} class="hover:opacity-100 transition-opacity">{t.otherLangLabel}</a>
        &nbsp;&middot;&nbsp;
        <a href={`/${lang}/datenschutz`} class="hover:opacity-100 transition-opacity">{t.legalPrivacy}</a>
        &nbsp;&middot;&nbsp;
        <a href={`/${lang}/impressum`} class="hover:opacity-100 transition-opacity">{t.legalImpressum}</a>
      </p>
    </div>
  </section>

  </footer>

  <style>
    .story-page {
      color: var(--text);
      --story-nav-height: 4.25rem;
      --story-step-pad-x: clamp(1.25rem, 4vw, 3rem);
      --story-step-pad-y: clamp(4.5rem, 9vh, 7rem);
      overflow-x: clip;
    }

    :global(html),
    :global(body) {
      overflow-x: hidden;
    }

    .story-page :is(h1, h2, h3, h4, p, span, a) {
      text-wrap: pretty;
    }

    .story-nav {
      background: color-mix(in srgb, var(--surface) 86%, transparent);
      border-bottom: 1px solid var(--line);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      box-shadow: 0 16px 34px -30px rgba(15,23,42,0.30);
    }

    .story-page :is(section, section[aria-label="Projekte"] > div, section[aria-label="Projects"] > div) {
      scroll-margin-top: var(--story-nav-height);
    }

    .story-page .act {
      min-height: 100svh;
      min-height: 100dvh;
      padding-block: var(--story-step-pad-y);
      padding-inline: var(--story-step-pad-x);
    }

    .story-page section[aria-label="Portrait"] {
      min-height: calc(100svh - var(--story-nav-height));
      min-height: calc(100dvh - var(--story-nav-height));
      margin-top: 0;
      padding: var(--story-step-pad-y) var(--story-step-pad-x) clamp(3rem, 7vh, 5rem);
    }

    .story-page section[aria-label="Portrait"] .reveal {
      width: min(100%, 28rem);
    }

    .story-page section[aria-label="Portrait"] img {
      width: min(100%, clamp(14rem, 28vw, 22rem));
      height: min(52svh, 28rem);
      height: min(52dvh, 28rem);
      object-fit: cover;
      object-position: center top;
    }

    .story-page :is(
      section[aria-label="Zahlen"],
      section[aria-label="Numbers"],
      section[aria-label="Profil"],
      section[aria-label="Profile"],
      section[aria-label="Überzeugungen"],
      section[aria-label="Beliefs"],
      section[aria-label="Ausbildung"],
      section[aria-label="Education"]
    ) {
      min-height: calc(100svh - var(--story-nav-height));
      min-height: calc(100dvh - var(--story-nav-height));
      display: flex;
      align-items: center;
      padding-block: var(--story-step-pad-y);
      padding-inline: var(--story-step-pad-x);
    }

    .story-page :is(section[aria-label="Projekte"], section[aria-label="Projects"]) > div {
      min-height: calc(100svh - var(--story-nav-height));
      min-height: calc(100dvh - var(--story-nav-height));
      display: flex;
      align-items: center;
      padding-block: var(--story-step-pad-y);
      padding-inline: var(--story-step-pad-x);
    }

    .story-key-hint {
      align-items: center;
      border: 1px solid var(--line);
      border-radius: 9999px;
      padding: 0.28rem 0.55rem;
      color: var(--accent);
      background: color-mix(in srgb, var(--accent) 7%, var(--surface));
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.08em;
    }

    .story-display,
    .story-heading,
    .story-number,
    .story-metric,
    .story-project-title,
    .story-project-metric {
      font-family: var(--font-display);
      letter-spacing: -0.035em;
    }

    .story-display,
    .story-number,
    .story-project-metric {
      font-weight: 300;
    }

    .story-heading,
    .story-project-title {
      font-weight: 400;
    }

    .story-metric {
      font-weight: 300;
    }

    .story-quote,
    .story-belief {
      font-family: var(--font-body);
      font-style: normal;
      font-weight: 400;
    }

    .story-quote-mark {
      font-family: var(--font-display);
      color: var(--accent);
      opacity: 0.08;
    }

    .story-separator {
      border-color: var(--line);
    }

    .story-page section[aria-label="Profil"] .prose-column,
    .story-page section[aria-label="Profile"] .prose-column,
    .story-page section[aria-label="Kontakt"] > div,
    .story-page section[aria-label="Contact"] > div {
      max-width: 760px;
    }

    .story-page section[aria-label="Kontakt"],
    .story-page section[aria-label="Contact"] {
      background:
        radial-gradient(circle at 50% 16%, color-mix(in srgb, var(--accent) 12%, transparent), transparent 28rem),
        var(--bg);
    }

    .story-page .exp-compact {
      border-bottom-color: var(--line);
    }

    .story-page #story-step-counter,
    .story-page #story-keyboard-hint {
      font-family: var(--font-body);
    }

    .story-page #story-step-counter {
      border: 1px solid var(--line);
      border-radius: 9999px;
      padding: 0.42rem 0.62rem;
      background: color-mix(in srgb, var(--surface) 86%, transparent);
      box-shadow: 0 14px 32px -26px rgba(15,23,42,0.36);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      font-variant-numeric: tabular-nums;
    }

    .story-page #story-keyboard-hint {
      border: 1px solid var(--line);
      border-radius: 9999px;
      padding: 0.42rem 0.7rem;
      background: color-mix(in srgb, var(--surface) 86%, transparent);
      color: var(--text-secondary);
      box-shadow: 0 14px 32px -26px rgba(15,23,42,0.36);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      font-size: 0.66rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    @media (max-width: 640px) {
      .story-page {
        --story-step-pad-x: 1.25rem;
        --story-step-pad-y: clamp(3.5rem, 7vh, 4.5rem);
      }

      .story-page section[aria-label="Portrait"] img {
        width: min(100%, 14rem);
        height: min(48svh, 27rem);
        height: min(48dvh, 27rem);
      }

      .story-page #story-step-counter {
        bottom: 1rem;
        left: 1rem;
      }

      .story-page #story-keyboard-hint,
      :global(#agent-widget-label) {
        display: none !important;
      }
    }
  </style>

  <!-- Scripts -->
  <script>
    // Floating nav
    const navPdf = document.getElementById('nav-pdf');
    const navRight = document.getElementById('nav-right');
    // Scroll progress
    const progressBar = document.getElementById('scroll-progress');

    window.addEventListener('scroll', () => {
      const y = window.scrollY;
      // Nav visibility + tabindex
      const show = y > 300;
      [navPdf, navRight].forEach(el => {
        if (show) { el?.classList.remove('opacity-0'); el?.classList.add('opacity-100'); }
        else { el?.classList.add('opacity-0'); el?.classList.remove('opacity-100'); }
      });
      // Make nav links tabbable only when visible
      // .story-back is the always-visible escape hatch → keep it tabbable regardless.
      document.querySelectorAll('#floating-nav a:not(.story-back), #floating-nav button').forEach(a => {
        (a as HTMLElement).tabIndex = show ? 0 : -1;
      });
      // Progress bar
      const max = document.documentElement.scrollHeight - window.innerHeight;
      if (progressBar && max > 0) {
        progressBar.style.width = `${(y / max) * 100}%`;
      }
    });
  </script>

  <!-- Presentation navigation: step act-to-act with arrow keys (Story page only) -->
  <script>
    (function () {
      // Each top-level <section> is a step; the "Selected Works" act has multiple
      // direct <div> children (one per project) → each becomes its own step.
      const steps: Element[] = [];
      document.querySelectorAll('.story-page section').forEach((sec) => {
        const divs = Array.from(sec.children).filter((c) => c.tagName === 'DIV');
        if (divs.length > 1) divs.forEach((d) => steps.push(d));
        else steps.push(sec);
      });
      if (steps.length < 2) return;

      // A presentation always opens on the first act — don't restore a mid-scroll position.
      if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
      window.scrollTo(0, 0);

      let current = 0;
      let navigating = false;   // true while a programmatic (key-driven) scroll is in flight
      let navTimer = 0;
      const reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      const counter = document.createElement('div');
      counter.className = 'no-print';
      counter.id = 'story-step-counter';
      counter.setAttribute('aria-hidden', 'true');
      counter.style.cssText = 'position:fixed;bottom:1.5rem;left:1.75rem;z-index:60;pointer-events:none';
      document.body.appendChild(counter);

      const hint = document.createElement('div');
      hint.className = 'no-print';
      hint.id = 'story-keyboard-hint';
      hint.setAttribute('aria-hidden', 'true');
      hint.innerHTML = '<span style="font-size:13px;letter-spacing:.05em">← →</span><span>Navigieren</span>';
      hint.style.cssText = 'position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%);z-index:60;display:flex;align-items:center;gap:.7rem;opacity:.78;transition:opacity .8s ease;pointer-events:none';
      document.body.appendChild(hint);
      let hintTimer = window.setTimeout(() => { hint.style.opacity = '0'; }, 4500);

      const pad = (n: number) => String(n).padStart(2, '0');
      const update = () => {
        counter.innerHTML = '<span style="color:var(--accent)">' + pad(current + 1) + '</span>'
          + '<span style="color:var(--text-secondary);opacity:.55"> / ' + pad(steps.length) + '</span>';
      };
      const fadeHint = () => { clearTimeout(hintTimer); hint.style.opacity = '0'; };

      // Keep `current` in sync when the user scrolls manually (rAF-throttled).
      const syncFromScroll = () => {
        const mark = window.innerHeight * 0.33;
        let idx = 0;
        for (let i = 0; i < steps.length; i++) {
          if (steps[i].getBoundingClientRect().top <= mark) idx = i;
        }
        current = idx; update();
      };

      // Synchronous index → fast repeated key presses step reliably (no observer lag).
      const goTo = (i: number) => {
        current = Math.max(0, Math.min(i, steps.length - 1));
        update();
        const el = steps[current];
        // Show the destination at once — don't wait for the reveal observer (no half-faded jump).
        el.classList.add('visible');
        el.querySelectorAll('.reveal').forEach((r) => r.classList.add('visible'));
        // Suppress scroll-sync while we animate, so it can't fight the target index.
        navigating = true;
        clearTimeout(navTimer);
        navTimer = window.setTimeout(() => { navigating = false; }, 700);
        el.scrollIntoView({ behavior: reduce ? 'auto' : 'smooth', block: 'start' });
      };

      document.addEventListener('keydown', (e) => {
        const tgt = e.target as HTMLElement | null;
        if (tgt && tgt.closest && tgt.closest('input,textarea,select,[contenteditable]')) return;
        if (['ArrowDown', 'ArrowRight', 'PageDown', ' '].indexOf(e.key) > -1) { e.preventDefault(); goTo(current + 1); fadeHint(); }
        else if (['ArrowUp', 'ArrowLeft', 'PageUp'].indexOf(e.key) > -1) { e.preventDefault(); goTo(current - 1); fadeHint(); }
        else if (e.key === 'Home') { e.preventDefault(); goTo(0); fadeHint(); }
        else if (e.key === 'End') { e.preventDefault(); goTo(steps.length - 1); fadeHint(); }
      });

      let raf = 0;
      window.addEventListener('scroll', () => {
        if (navigating) return;   // don't let manual-scroll sync override key navigation mid-animation
        if (raf) return;
        raf = requestAnimationFrame(() => { raf = 0; syncFromScroll(); });
      }, { passive: true });

      syncFromScroll();
    })();
  </script>
  </div>
</BaseLayout>
