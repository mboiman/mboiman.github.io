---
import type { AIShowcaseItem } from '../lib/types';

interface Props {
  title: string;
  items: AIShowcaseItem[];
}

const { title, items } = Astro.props;
---

<section class="py-10 px-6" style="background-color: var(--color-surface-alt)">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-center text-2xl font-heading font-bold mb-10" style="color: var(--color-accent)">
      {title}
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {items.map((item, i) => (
        <div
          class="card glow group"
          style={`animation-delay: ${i * 80}ms`}
        >
          <h3 class="font-heading font-semibold text-sm mb-2 group-hover:text-[var(--color-accent)] transition-colors" style="color: var(--color-accent)">
            {item.name}
          </h3>
          <p class="text-sm text-[var(--color-muted)] leading-relaxed">
            {item.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
