---
import type { AIShowcaseItem } from '../lib/types';

interface Props {
  title: string;
  items: AIShowcaseItem[];
}

const { title, items } = Astro.props;
---

<section class="relative py-12 px-6 overflow-hidden" style="background-color: var(--color-surface-alt)">
  <!-- Subtle gradient accent -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[1px]" style="background: linear-gradient(90deg, transparent, var(--color-accent), transparent)"></div>

  <div class="max-w-6xl mx-auto">
    <h2 class="text-center text-xl sm:text-2xl font-heading font-bold mb-10 tracking-tight" style="color: var(--color-accent)">
      {title}
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {items.map((item, i) => (
        <div class="card glow reveal" style={`transition-delay: ${i * 100}ms`}>
          <div class="flex items-start gap-3">
            <div class="w-2 h-2 rounded-full mt-1.5 flex-shrink-0" style="background-color: var(--color-accent)"></div>
            <div>
              <h3 class="font-heading font-semibold text-sm mb-2 transition-colors duration-300" style="color: var(--color-accent)">
                {item.name}
              </h3>
              <p class="text-sm text-[var(--color-muted)] leading-relaxed">
                {item.description}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
