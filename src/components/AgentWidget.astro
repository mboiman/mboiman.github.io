---
// AgentWidget — floating chat client that talks to Michael's Bridge-Agent over A2A.
//
// Self-contained vanilla JS (no framework, no new npm deps, no CDN). Protocol
// logic is ported from bks-web's proven A2A client (A2AChat.tsx / agentService.ts
// / useAgentConnection): JSON-RPC 2.0 with params.message.parts:[{kind:'text',…}],
// message/stream (SSE) preferred, message/send (buffered) fallback, contextId
// persisted in localStorage.
//
// Rendering is escape-FIRST: every agent response is HTML-escaped in full before a
// small, audited markdown subset (tables, lists, code, headings, bold/links) is
// re-introduced — a prompt-injected agent can never emit live HTML (see safeMarkdown).
//
// The panel can be enlarged (maximize toggle) or freely drag-resized (top-left
// grip); the chosen size persists in localStorage. Mobile stays fullscreen.
//
// All user-facing strings come from src/lib/i18n.ts (no hardcoded copy here).
// The widget is JS-injected at runtime and carries `@media print { display:none }`,
// so it is excluded from the Puppeteer-generated PDF (which is built from a
// separate TOML-driven HTML string and never loads this layout — see notes).

import { i18n } from '../lib/i18n';

// Serialize both language bundles so the client can pick by <html lang>.
// Only the widget sub-bundle ships, not the whole i18n surface.
const widgetStrings = {
  de: i18n.de.agentWidget,
  en: i18n.en.agentWidget,
};
---

<div id="agent-widget-root" data-i18n={JSON.stringify(widgetStrings)} class="no-print">
  <!-- Floating launcher -->
  <button
    id="agent-widget-launcher"
    type="button"
    aria-haspopup="dialog"
    aria-expanded="false"
    aria-controls="agent-widget-panel"
  >
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
    </svg>
  </button>
  <button id="agent-widget-label" type="button" aria-hidden="true" tabindex="-1">
    <span class="aw-label-dot"></span>
    <span class="aw-label-text"></span>
  </button>

  <!-- Chat panel -->
  <section
    id="agent-widget-panel"
    role="dialog"
    aria-modal="false"
    aria-labelledby="agent-widget-title"
    hidden
  >
    <!-- Free-resize grip. Top-left because the panel is anchored bottom-right,
         so the top-left corner is the only one that grows the panel "outward". -->
    <div id="agent-widget-resize" class="aw-resize-handle" aria-hidden="true" title="">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"
           stroke-linecap="round" aria-hidden="true">
        <line x1="3" y1="11" x2="11" y2="3"></line>
        <line x1="6" y1="12" x2="12" y2="6"></line>
      </svg>
    </div>

    <header id="agent-widget-header">
      <div class="aw-header-text">
        <h2 id="agent-widget-title"></h2>
        <p id="agent-widget-subtitle"></p>
      </div>
      <div class="aw-header-actions">
        <!-- Agent-Card toggle. Shows the live A2A agent-card; icon swaps card↔chat
             via .aw-show-card on the panel. -->
        <button id="agent-widget-cardbtn" type="button" class="aw-icon-btn">
          <svg class="aw-ico-card" viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="2"></rect>
            <circle cx="8.5" cy="11" r="1.8"></circle>
            <line x1="13" y1="10" x2="18" y2="10"></line>
            <line x1="13" y1="13.5" x2="18" y2="13.5"></line>
            <line x1="6.5" y1="15.6" x2="11" y2="15.6"></line>
          </svg>
          <svg class="aw-ico-chat" viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
          </svg>
        </button>
        <!-- Maximize / restore toggle. Icon swaps via .aw-is-max on the panel. -->
        <button id="agent-widget-maximize" type="button" class="aw-icon-btn">
          <svg class="aw-ico-expand" viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="15 3 21 3 21 9"></polyline>
            <polyline points="9 21 3 21 3 15"></polyline>
            <line x1="21" y1="3" x2="14" y2="10"></line>
            <line x1="3" y1="21" x2="10" y2="14"></line>
          </svg>
          <svg class="aw-ico-restore" viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="4 14 10 14 10 20"></polyline>
            <polyline points="20 10 14 10 14 4"></polyline>
            <line x1="14" y1="10" x2="21" y2="3"></line>
            <line x1="3" y1="21" x2="10" y2="14"></line>
          </svg>
        </button>
        <button id="agent-widget-close" type="button" class="aw-icon-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
    </header>

    <div id="agent-widget-messages" aria-live="polite" aria-atomic="false"></div>

    <!-- Agent-Card view (A2A) — populated at runtime from /.well-known/agent-card.json.
         Shown in place of the message list when toggled; chat stays underneath. -->
    <section id="agent-widget-card" aria-label="" hidden></section>

    <form id="agent-widget-form" autocomplete="off">
      <input
        id="agent-widget-input"
        type="text"
        autocomplete="off"
        enterkeyhint="send"
      />
      <button id="agent-widget-send" type="submit">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="22" y1="2" x2="11" y2="13"></line>
          <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
        </svg>
      </button>
    </form>

    <!-- Point-of-collection privacy note. Tiny, muted, always visible while the
         composer is — text + link set by JS (applyStrings) from the i18n bundle. -->
    <p id="agent-widget-privacy" class="aw-privacy" hidden>
      <span id="agent-widget-privacy-text"></span>
      <a id="agent-widget-privacy-link" href="#" target="_blank" rel="noopener"></a>
    </p>
  </section>
</div>

<style is:global>
  /* GLOBAL (not scoped) ON PURPOSE: the chat bubbles, rows, avatars and the whole
     markdown subtree are built at RUNTIME via createElement — those nodes never
     receive Astro's data-astro-cid attribute, so scoped selectors would silently
     miss them (which is exactly why questions vs. answers looked identical before).
     Every selector here is namespaced under #agent-widget-* / .aw-* (unique to this
     widget), so a global block styles the dynamic DOM without leaking site-wide.

     Colors pull from the site CSS vars so light/dark just work. Spacing / radius /
     typography / elevation map to DESIGN.md tokens (token name beside each value). */
  #agent-widget-root {
    /* --- size state: JS overrides --aw-w / --aw-h for free-resize & maximize --- */
    --aw-w: 380px;                 /* default panel width  */
    --aw-h: 560px;                 /* default panel height */
    --aw-max-w: min(720px, 92vw);  /* maximize target W */
    --aw-max-h: min(840px, 90vh);  /* maximize target H */

    /* radius — DESIGN.md rounded.* */
    --aw-radius: 16px;             /* rounded.xl — panel (CTA-container tier) */
    --aw-radius-md: 8px;           /* rounded.md — bubbles, input, send button */
    --aw-radius-sm: 4px;           /* rounded.sm — bubble tail */

    /* spacing — DESIGN.md spacing.* */
    --aw-pad: 16px;                /* spacing.md — panel inner padding */
    --aw-gap: 8px;                 /* spacing.sm — vertical rhythm between bubbles */

    /* hairline border — tracks --text so it reads in both themes */
    --aw-border: color-mix(in srgb, var(--text) 14%, transparent);
    --aw-border-strong: color-mix(in srgb, var(--text) 22%, transparent);

    /* accent gradient — DESIGN.md accent-from → accent-to, used ONLY on launcher
       + send (decorative/CTA). Falls back to the site accent if vars absent. */
    --aw-grad: linear-gradient(135deg,
      var(--accent-cta, var(--accent)) 0%,
      var(--accent-hover, var(--accent)) 100%);

    /* elevation — DESIGN.md shadow-hover (panel) + proposed shadow-overlay */
    --aw-elev-panel: 0 16px 48px -8px rgba(0,0,0,0.18), 0 4px 12px -4px rgba(0,0,0,0.10);
    --aw-elev-launcher: 0 8px 24px -6px rgba(0,0,0,0.28), 0 2px 6px -2px rgba(0,0,0,0.18);

    /* typography — self-hosted IBM Plex Sans via global font tokens */
    font-family: var(--font-body);
    font-weight: 400;
  }

  /* darker overlay alpha in dark mode (DESIGN.md: soften/strengthen per theme) */
  html.dark #agent-widget-root,
  .dark #agent-widget-root {
    --aw-elev-panel: 0 16px 48px -8px rgba(0,0,0,0.55), 0 4px 12px -4px rgba(0,0,0,0.35);
    --aw-elev-launcher: 0 8px 24px -6px rgba(0,0,0,0.6), 0 2px 6px -2px rgba(0,0,0,0.4);
  }

  /* Belt-and-suspenders: never print the widget. */
  @media print {
    #agent-widget-root { display: none !important; }
  }

  /* ───────────────────────── Launcher (FAB) ───────────────────────── */
  #agent-widget-launcher {
    position: fixed;
    bottom: 1.25rem;
    right: 1.25rem;
    z-index: 9998;
    width: 56px;
    height: 56px;
    border-radius: 9999px;          /* rounded.full */
    border: none;
    cursor: pointer;
    background: var(--aw-grad);      /* accent gradient — decorative CTA */
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--aw-elev-launcher);
    /* DESIGN.md motion rule: transform/opacity only — no color transitions */
    transition: transform 0.2s ease-out, box-shadow 0.2s ease-out, filter 0.2s ease-out;
  }
  #agent-widget-launcher:hover {
    transform: translateY(-2px);    /* DESIGN.md hover lift = -2px */
    filter: brightness(1.06);       /* luminance, not a color-channel tween */
  }
  #agent-widget-launcher:active { transform: translateY(0); }
  #agent-widget-launcher:focus-visible {
    outline: 2px solid var(--accent-hover, var(--accent));
    outline-offset: 3px;
  }
  #agent-widget-launcher svg { width: 26px; height: 26px; }
  #agent-widget-launcher.aw-hidden { display: none; }

  #agent-widget-label {
    position: fixed;
    bottom: 1.55rem;
    right: 5.45rem;
    z-index: 9998;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    max-width: min(260px, calc(100vw - 7rem));
    padding: 8px 11px;
    border: 1px solid var(--aw-border);
    border-radius: 9999px;
    background: color-mix(in srgb, var(--bg) 86%, transparent);
    color: var(--text);
    box-shadow: 0 8px 24px -12px rgba(0,0,0,0.45);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    cursor: pointer;
    font: inherit;
    font-size: 0.78rem;
    line-height: 1.1;
    transition: transform 0.2s ease-out, opacity 0.2s ease-out, border-color 0.2s ease-out;
  }
  #agent-widget-label:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--accent) 38%, transparent);
  }
  #agent-widget-label.aw-hidden { display: none; }
  .aw-label-dot {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: var(--accent-hover, var(--accent));
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 12%, transparent);
    flex-shrink: 0;
  }
  .aw-label-text {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ───────────────────────── Panel ───────────────────────── */
  #agent-widget-panel {
    position: fixed;
    bottom: 1.25rem;
    right: 1.25rem;
    z-index: 9999;
    width: var(--aw-w);
    height: var(--aw-h);
    max-width: 95vw;
    max-height: 92vh;
    min-width: 320px;
    min-height: 420px;
    display: flex;
    flex-direction: column;
    background: var(--bg);
    color: var(--text);
    border: 1px solid var(--aw-border);
    border-radius: 16px;            /* rounded.xl */
    box-shadow: var(--aw-elev-panel);
    overflow: hidden;
    animation: aw-pop 0.2s ease-out; /* 200ms ease-out per DESIGN.md */
  }
  /* While dragging: kill the transition so the panel tracks the pointer 1:1. */
  #agent-widget-panel.aw-resizing { animation: none; user-select: none; }
  #agent-widget-panel.aw-is-max {
    width: var(--aw-max-w);
    height: var(--aw-max-h);
  }
  /* When the panel is open on the two-column layout (lg+), the page content is
     shifted left via an inline body padding (set in openPanel/closePanel below)
     so the fixed panel sits beside the sidebar instead of permanently covering
     it while scrolling. */
  body { transition: padding-right 0.2s ease-out; }

  @keyframes aw-pop {
    from { opacity: 0; transform: translateY(12px) scale(0.98); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* ───────────────────────── Resize grip ───────────────────────── */
  .aw-resize-handle {
    position: absolute;
    top: 0;
    left: 0;
    width: 22px;
    height: 22px;
    z-index: 2;
    cursor: nwse-resize;
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    padding: 5px 0 0 5px;
    color: var(--text-secondary);
    opacity: 0.55;
    transition: opacity 0.18s ease-out;   /* opacity only — DESIGN.md motion rule */
    touch-action: none;                    /* let JS own the gesture; no scroll-steal */
  }
  .aw-resize-handle:hover { opacity: 1; }
  .aw-resize-handle svg { width: 12px; height: 12px; }

  /* ───────────────────────── Header ───────────────────────── */
  #agent-widget-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--aw-gap);            /* spacing.sm */
    padding: 14px 14px 14px 26px;  /* l-pad clears the 22px top-left grip */
    background: color-mix(in srgb, var(--text) 3%, var(--bg));
    border-bottom: 1px solid var(--aw-border);
  }
  .aw-header-text { min-width: 0; }
  .aw-header-actions {
    display: flex;
    align-items: center;
    gap: 2px;
    flex-shrink: 0;
  }
  #agent-widget-title {
    /* DESIGN.md card-title (h4 20/500) scaled to a dense UI title */
    font-size: 0.9375rem;          /* 15px */
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--text);
  }
  #agent-widget-subtitle {
    font-size: 0.75rem;            /* body-sm/meta */
    font-weight: 400;
    line-height: 1.4;
    margin: 3px 0 0;
    color: var(--text-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* icon buttons (maximize + close) share one quiet style */
  .aw-icon-btn {
    flex-shrink: 0;
    background: transparent;
    border: none;
    color: var(--text-secondary);
    cursor: pointer;
    width: 30px;
    height: 30px;
    border-radius: 8px;            /* rounded.md */
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.15s ease-out;
  }
  .aw-icon-btn:hover {
    color: var(--text);
    background: color-mix(in srgb, var(--text) 9%, transparent);
  }
  .aw-icon-btn:focus-visible {
    outline: 2px solid var(--accent-hover, var(--accent));
    outline-offset: 1px;
  }
  .aw-icon-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .aw-icon-btn svg { width: 16px; height: 16px; }

  /* maximize icon swap: expand at default, restore when maximized */
  .aw-ico-restore { display: none; }
  #agent-widget-panel.aw-is-max .aw-ico-expand { display: none; }
  #agent-widget-panel.aw-is-max .aw-ico-restore { display: inline-flex; }

  /* card-toggle icon swap: card glyph in chat view, chat glyph in card view */
  .aw-ico-chat { display: none; }
  #agent-widget-panel.aw-show-card .aw-ico-card { display: none; }
  #agent-widget-panel.aw-show-card .aw-ico-chat { display: inline-flex; }

  /* ───────────────────────── Messages ───────────────────────── */
  #agent-widget-messages {
    flex: 1 1 auto;                /* flexes; layout never breaks when wide/tall */
    min-height: 0;                 /* critical: lets the scroll area shrink in flex */
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: var(--aw-pad);        /* spacing.md */
    display: flex;
    flex-direction: column;
    gap: var(--aw-gap);            /* spacing.sm vertical rhythm */
    font-size: 0.875rem;           /* body-md scaled to 14px */
    line-height: 1.6;              /* DESIGN.md: line-height 1.6 is mandatory */
  }

  /* custom scrollbar — quiet, theme-tracking */
  #agent-widget-messages { scrollbar-width: thin; scrollbar-color: var(--aw-border-strong) transparent; }
  #agent-widget-messages::-webkit-scrollbar { width: 8px; }
  #agent-widget-messages::-webkit-scrollbar-track { background: transparent; }
  #agent-widget-messages::-webkit-scrollbar-thumb {
    background: var(--aw-border-strong);
    border-radius: 9999px;
    border: 2px solid transparent;
    background-clip: padding-box;
  }
  #agent-widget-messages::-webkit-scrollbar-thumb:hover {
    background: color-mix(in srgb, var(--text) 32%, transparent);
    background-clip: padding-box;
  }

  /* ───────────────────────── Rows (speaker lane) ─────────────────────────
     Each message is a ROW: [avatar?] + [bubble]. The row owns the left/right
     alignment; the avatar lives on the AGENT side only. That single asymmetry —
     agent answers carry an avatar on the left, the visitor's questions are a bare
     gradient bubble on the right — is what makes "answer vs. question" readable
     at a glance, beyond colour alone. */
  .aw-row {
    display: flex;
    gap: 8px;                      /* spacing.sm between avatar and bubble */
    align-items: flex-end;         /* avatar sits at the bubble's baseline */
    max-width: 92%;
    animation: aw-msg-in 0.18s ease-out;
  }
  .aw-row-user  { align-self: flex-end;   justify-content: flex-end; }
  .aw-row-agent { align-self: flex-start; }
  @keyframes aw-msg-in {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Agent avatar — neutral accent-tinted chip (NOT the user's gradient, so the
     two speakers never read as the same colour). Same speech-glyph as launcher. */
  .aw-avatar {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 9999px;         /* rounded.full */
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1px;            /* nudge onto the bubble's last line */
    background: color-mix(in srgb, var(--accent) 16%, var(--bg));
    color: var(--accent-hover, var(--accent));
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
  }
  .aw-avatar svg { width: 15px; height: 15px; }

  /* ───────────────────────── Bubbles ───────────────────────── */
  .aw-msg {
    max-width: 100%;               /* the ROW caps the width now */
    padding: 8px 12px;
    border-radius: 12px;
    word-wrap: break-word;
    overflow-wrap: anywhere;
  }

  /* USER (question) — bold accent gradient fill, tail bottom-right */
  .aw-msg.aw-user {
    background: var(--aw-grad);
    color: #fff;
    border-bottom-right-radius: 4px;
    box-shadow: 0 2px 6px -2px color-mix(in srgb, var(--accent) 55%, transparent);
  }
  .aw-msg.aw-user a { color: #fff; }

  /* AGENT (answer) — solid card surface, visible outline + lift so a long answer
     reads as a distinct block, never as plain text floating in the panel. */
  .aw-msg.aw-agent {
    background: color-mix(in srgb, var(--text) 6%, var(--bg));
    border: 1px solid var(--aw-border-strong);
    color: var(--text);
    border-bottom-left-radius: 4px;
    box-shadow: 0 1px 3px -1px rgba(0,0,0,0.10);
  }
  .aw-msg.aw-error {
    background: color-mix(in srgb, #c0392b 16%, var(--bg));
    border: 1px solid color-mix(in srgb, #c0392b 38%, transparent);
    color: var(--text);
    border-bottom-left-radius: 4px;
  }
  .aw-msg a { color: inherit; text-decoration: underline; text-underline-offset: 2px; }
  .aw-msg.aw-agent a { color: var(--accent-hover, var(--accent)); }
  .aw-msg strong { font-weight: 600; }
  .aw-msg p:first-child { margin-top: 0; }
  .aw-msg p:last-child { margin-bottom: 0; }

  /* retry affordance on error bubbles */
  .aw-retry {
    display: inline-block;
    margin-top: 0.5rem;
    padding: 0.3rem 0.7rem;
    font: inherit;
    font-size: 0.78rem;
    line-height: 1.2;
    cursor: pointer;
    border-radius: 8px;
    border: 1px solid color-mix(in srgb, var(--text) 22%, transparent);
    background: color-mix(in srgb, var(--text) 8%, transparent);
    color: var(--text);
    transition: background-color 0.15s ease-out, opacity 0.15s ease-out;
  }
  .aw-retry:hover:not(:disabled) { background: color-mix(in srgb, var(--text) 16%, transparent); }
  .aw-retry:disabled { opacity: 0.5; cursor: not-allowed; }

  /* ───────────── Working / typing indicator ───────────── */
  .aw-working {
    display: flex;
    align-items: center;
    gap: var(--aw-gap);
    font-size: 0.75rem;
    color: var(--text-secondary);
    padding: 6px 12px;
    background: color-mix(in srgb, var(--text) 6%, var(--bg));
    border: 1px solid var(--aw-border-strong);
    border-radius: 12px;
    border-bottom-left-radius: 4px;
    box-shadow: 0 1px 3px -1px rgba(0,0,0,0.10);
  }
  .aw-dots { display: inline-flex; gap: 3px; flex-shrink: 0; }
  .aw-dots span {
    width: 5px; height: 5px; border-radius: 9999px;
    background: var(--accent);
    animation: aw-blink 1.2s infinite ease-in-out both;
  }
  .aw-dots span:nth-child(2) { animation-delay: 0.2s; }
  .aw-dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes aw-blink {
    0%, 80%, 100% { opacity: 0.25; }
    40% { opacity: 1; }
  }
  .aw-step {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
    font-size: 0.6875rem;          /* 11px — label-caps eyebrow tone */
    letter-spacing: 0.04em;
  }

  /* ───────────── Safe-markdown block elements (agent bubbles only) ───────────── */
  .aw-msg.aw-agent .aw-md-p, .aw-msg.aw-error .aw-md-p { margin: 0 0 0.5rem; }
  .aw-msg.aw-agent .aw-md-p:last-child, .aw-msg.aw-error .aw-md-p:last-child { margin-bottom: 0; }

  .aw-msg.aw-agent .aw-md-h {
    font-family: var(--font-display);
    font-weight: 600;
    line-height: 1.25;
    margin: 0.6rem 0 0.35rem;
    color: var(--text);
  }
  .aw-msg.aw-agent h4.aw-md-h { font-size: 1rem; }
  .aw-msg.aw-agent h5.aw-md-h { font-size: 0.9rem; }
  .aw-msg.aw-agent h6.aw-md-h { font-size: 0.82rem; color: var(--text-secondary); }
  .aw-msg.aw-agent .aw-md-h:first-child { margin-top: 0; }

  .aw-msg.aw-agent .aw-md-list {
    margin: 0.25rem 0 0.5rem;
    padding-left: 1.25rem;
  }
  .aw-msg.aw-agent .aw-md-list li { margin: 0.1rem 0; }
  .aw-msg.aw-agent .aw-md-nested {
    margin: 0.15rem 0 0.15rem;
    padding-left: 1.1rem;
  }
  .aw-msg.aw-agent ul.aw-md-list { list-style: disc; }
  .aw-msg.aw-agent ol.aw-md-list { list-style: decimal; }

  .aw-msg.aw-agent .aw-md-quote {
    margin: 0.4rem 0;
    padding: 0.3rem 0.7rem;
    border-left: 3px solid color-mix(in srgb, var(--accent) 60%, transparent);
    background: color-mix(in srgb, var(--text) 5%, transparent);
    color: var(--text-secondary);
    border-radius: 0 6px 6px 0;
  }

  .aw-msg.aw-agent .aw-md-code,
  .aw-msg.aw-agent .aw-md-pre code {
    font-family: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, monospace;
    font-size: 0.8em;
  }
  .aw-msg.aw-agent .aw-md-code {
    background: color-mix(in srgb, var(--text) 10%, transparent);
    border: 1px solid var(--aw-border);
    border-radius: 4px;
    padding: 0.05em 0.35em;
    white-space: nowrap;
  }
  .aw-msg.aw-agent .aw-md-pre {
    margin: 0.4rem 0;
    padding: 0.6rem 0.7rem;
    background: color-mix(in srgb, var(--text) 7%, var(--bg));
    border: 1px solid var(--aw-border);
    border-radius: 8px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .aw-msg.aw-agent .aw-md-pre code {
    display: block;
    white-space: pre;
    color: var(--text);
  }

  /* ───────────── GFM TABLES — wrap-first, fits the panel; scroll only as fallback ─────────────
     Tokens: DESIGN.md spacing.xs(4)/sm(8)/md(16) · rounded.md(8) · body-sm(14)
     Colors via site CSS vars (--text/--bg/--accent) through color-mix → light+dark for free. */

  /* Wrapper: overflow-x:auto is a FALLBACK, not the default — cells wrap (below),
     so it only scrolls when a table is genuinely too wide (many cols / long tokens). */
  .aw-msg.aw-agent .aw-md-table-wrap {
    margin: 0.5rem 0;
    max-width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border: 1px solid var(--aw-border);
    border-radius: 8px;               /* rounded.md */
    /* faint inset edge so a scrolling table reads as "more to the right" */
    background:
      linear-gradient(to right, transparent 70%, color-mix(in srgb, var(--text) 4%, transparent)) right / 14px 100% no-repeat;
  }

  .aw-msg.aw-agent .aw-md-table {
    border-collapse: collapse;
    width: 100%;
    /* AUTO layout: first column hugs its label, content columns share + WRAP. */
    table-layout: auto;
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .aw-msg.aw-agent .aw-md-table th,
  .aw-msg.aw-agent .aw-md-table td {
    padding: 0.4rem 0.6rem;
    border-bottom: 1px solid var(--aw-border);
    border-right: 1px solid color-mix(in srgb, var(--text) 7%, transparent);
    text-align: left;
    vertical-align: top;
    /* THE FIX: wrap instead of forcing the table wider than the panel */
    white-space: normal;
    overflow-wrap: anywhere;          /* break very long unbreakable tokens (URLs, IDs) */
    word-break: normal;
    hyphens: auto;
    min-width: 4.5rem;                /* keeps columns balanced; scroll only past panel width */
    max-width: 22rem;                 /* roomy when maximized, harmless when narrow */
  }
  .aw-msg.aw-agent .aw-md-table th:last-child,
  .aw-msg.aw-agent .aw-md-table td:last-child { border-right: none; }

  /* First column = label/key: hug content, wrap if long, never collapse to 1 char. */
  .aw-msg.aw-agent .aw-md-table th:first-child,
  .aw-msg.aw-agent .aw-md-table td:first-child {
    overflow-wrap: normal;
    min-width: 5.5rem;
    max-width: 14rem;
  }

  /* Header: quiet tint + weight, NO sticky (a chat bubble scrolls as one block). */
  .aw-msg.aw-agent .aw-md-table thead th {
    background: color-mix(in srgb, var(--accent) 14%, var(--bg));
    color: var(--text);
    font-weight: 600;
    border-bottom: 1px solid color-mix(in srgb, var(--text) 16%, transparent);
  }

  /* Zebra rows — barely-there, tracks --text so it reads light & dark. */
  .aw-msg.aw-agent .aw-md-table tbody tr:nth-child(even) td {
    background: color-mix(in srgb, var(--text) 4%, transparent);
  }
  .aw-msg.aw-agent .aw-md-table tbody tr:last-child td { border-bottom: none; }

  /* Right-aligned (numeric) columns read best tabular + non-wrapping. */
  .aw-msg.aw-agent .aw-md-table td[style*="right"],
  .aw-msg.aw-agent .aw-md-table th[style*="right"] {
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  /* Inline code inside a cell wraps with the cell. */
  .aw-msg.aw-agent .aw-md-table code.aw-md-code { white-space: normal; overflow-wrap: anywhere; }

  /* Wide-table mode (renderer adds .aw-md-wide for many columns): skip wrapping,
     comfortable per-column min so a wide table scrolls cleanly instead of cramping. */
  .aw-msg.aw-agent .aw-md-table.aw-md-wide th,
  .aw-msg.aw-agent .aw-md-table.aw-md-wide td {
    white-space: nowrap;
    max-width: none;
    min-width: 6.5rem;
  }
  .aw-msg.aw-agent .aw-md-table.aw-md-wide th:first-child,
  .aw-msg.aw-agent .aw-md-table.aw-md-wide td:first-child { min-width: 6.5rem; max-width: none; }

  /* Mobile (<640px): more width budget per cell so 3-col tables wrap to 2–3 lines. */
  @media (max-width: 639px) {
    .aw-msg.aw-agent .aw-md-table { font-size: 0.75rem; }
    .aw-msg.aw-agent .aw-md-table th,
    .aw-msg.aw-agent .aw-md-table td { padding: 0.35rem 0.5rem; max-width: 16rem; }
    .aw-msg.aw-agent .aw-md-table th:first-child,
    .aw-msg.aw-agent .aw-md-table td:first-child { max-width: 9rem; }
  }

  /* ───────────────────────── Agent-Card view (A2A) ─────────────────────────
     Shown in place of the message list when the header card-toggle is active.
     All content is built from the live agent-card via textContent (XSS-safe). */
  #agent-widget-card {
    flex: 1 1 auto;
    min-height: 0;
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: var(--aw-pad);
    scrollbar-width: thin;
    scrollbar-color: var(--aw-border-strong) transparent;
  }
  #agent-widget-panel.aw-show-card #agent-widget-messages { display: none; }
  #agent-widget-panel.aw-show-card #agent-widget-card { display: flex; flex-direction: column; }
  #agent-widget-card::-webkit-scrollbar { width: 8px; }
  #agent-widget-card::-webkit-scrollbar-track { background: transparent; }
  #agent-widget-card::-webkit-scrollbar-thumb {
    background: var(--aw-border-strong); border-radius: 9999px;
    border: 2px solid transparent; background-clip: padding-box;
  }

  .aw-card-eyebrow {
    font-size: 0.6875rem; letter-spacing: 0.08em; text-transform: uppercase;
