  .aw-card-tags { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 0.4rem; }
  .aw-card-tag {
    font-size: 0.66rem; color: var(--text-secondary); padding: 0.12rem 0.4rem;
    border-radius: 4px; background: color-mix(in srgb, var(--text) 8%, transparent);
  }
  .aw-card-ex-hint { font-size: 0.66rem; color: var(--text-secondary); margin: 0.5rem 0 0.3rem; }
  .aw-card-examples { display: flex; flex-direction: column; gap: 4px; }
  .aw-card-ex {
    text-align: left; font: inherit; font-size: 0.74rem; line-height: 1.3;
    padding: 0.38rem 0.55rem; border-radius: 8px; cursor: pointer;
    border: 1px solid color-mix(in srgb, var(--accent) 28%, transparent);
    background: color-mix(in srgb, var(--accent) 8%, transparent); color: var(--text);
    transition: background-color 0.15s ease-out;
  }
  .aw-card-ex::before { content: "›  "; color: var(--accent-hover, var(--accent)); font-weight: 700; }
  .aw-card-ex:hover { background: color-mix(in srgb, var(--accent) 16%, transparent); }
  .aw-card-ex:focus-visible { outline: 2px solid var(--accent-hover, var(--accent)); outline-offset: 1px; }
  .aw-card-empty, .aw-card-loading { font-size: 0.8rem; color: var(--text-secondary); padding: 0.5rem 0; }

  /* ───────────────────────── Composer ───────────────────────── */
  #agent-widget-form {
    display: flex;
    align-items: flex-end;
    gap: var(--aw-gap);
    padding: 10px 12px;
    border-top: 1px solid var(--aw-border);
    background: color-mix(in srgb, var(--text) 3%, var(--bg));
  }
  #agent-widget-input {
    flex: 1 1 auto;
    min-width: 0;
    padding: 9px 12px;
    border-radius: 8px;            /* rounded.md */
    border: 1px solid var(--aw-border);
    background: var(--bg);
    color: var(--text);
    font-size: 0.875rem;           /* 14px */
    font-family: inherit;
    line-height: 1.4;
    transition: border-color 0.15s ease-out, box-shadow 0.15s ease-out;
  }
  #agent-widget-input::placeholder { color: var(--text-secondary); }
  #agent-widget-input:focus-visible {
