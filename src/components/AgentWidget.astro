  #agent-widget-send:hover:not(:disabled) { filter: brightness(1.06); transform: translateY(-1px); }
  #agent-widget-send:active:not(:disabled) { transform: translateY(0); }
  #agent-widget-send:focus-visible { outline: 2px solid var(--accent-hover, var(--accent)); outline-offset: 2px; }
  #agent-widget-send:disabled { opacity: 0.5; cursor: not-allowed; }
  #agent-widget-send svg { width: 17px; height: 17px; }

  /* Point-of-collection privacy fine-print under the composer. Deliberately
     understated (muted, ~10.5px) so it informs without nagging. */
  .aw-privacy {
