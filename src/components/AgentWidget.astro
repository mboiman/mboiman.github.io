  .aw-card-meta { font-size: 0.72rem; color: var(--text-secondary); margin: 0.15rem 0; word-break: break-word; }
  .aw-card-meta strong { color: var(--text); font-weight: 600; }
  .aw-card-meta a { color: var(--accent-hover, var(--accent)); text-decoration: underline; text-underline-offset: 2px; }

  .aw-card-skill {
    padding: 0.55rem 0.65rem; margin-bottom: 0.5rem;
