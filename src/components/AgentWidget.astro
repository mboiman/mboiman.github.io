  .aw-privacy a:hover { color: var(--accent); }

  /* ───────────────────────── Mobile: fullscreen ───────────────────────── */
  @media (max-width: 639px) {
    #agent-widget-panel,
    #agent-widget-panel.aw-is-max {
      inset: 0;
      width: 100% !important;       /* override JS-set --aw-w */
      height: 100% !important;
      max-width: 100%;
      max-height: 100%;
      min-width: 0;
      min-height: 0;
      border-radius: 0;
      border: none;
    }
    .aw-resize-handle { display: none; }
    #agent-widget-maximize { display: none; }
    #agent-widget-header { padding-left: 16px; }
    .aw-row { max-width: 94%; }
    #agent-widget-label {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #agent-widget-panel,
    .aw-msg,
    .aw-working { animation: none; }
    #agent-widget-launcher,
    #agent-widget-send { transition: none; }
    .aw-dots span { animation: none; opacity: 0.6; }
  }

  /* ─────────────── Agent-driven highlight (scroll + red ring) ───────────────
     NOT namespaced under #agent-widget-* on purpose: this class is applied to
     CV SECTION cards out in the page DOM (elements carrying [data-cv-anchor]),
     not to the widget. The agent proposes an anchor in its reply; the widget
     validates it against the DOM whitelist and toggles this class for ~2.6s.
     A pure outline (no innerHTML, no layout shift) — reversible by class removal. */
  .bridge-flash {
    outline: 3px solid #e23b3b;        /* attention red — functional alert, not a brand token */
    outline-offset: 4px;
    border-radius: 10px;               /* soft corners so the ring hugs the card */
    animation: bridge-flash-pulse 2.6s ease-out forwards;
  }
  @keyframes bridge-flash-pulse {
    0%   { outline-color: rgba(226,59,59,0); }
    10%  { outline-color: rgba(226,59,59,1); }
    35%  { outline-color: rgba(226,59,59,0.5); }
    55%  { outline-color: rgba(226,59,59,1); }
    100% { outline-color: rgba(226,59,59,0); }
  }
  @media (prefers-reduced-motion: reduce) {
    /* no pulse — show a steady ring; JS still removes the class after the timeout */
    .bridge-flash { animation: none; outline-color: #e23b3b; }
  }

  /* visually-hidden live region for the highlight announcement (screen readers) */
  .aw-visually-hidden {
    position: absolute !important;
    width: 1px; height: 1px;
    margin: -1px; padding: 0; border: 0;
    clip: rect(0 0 0 0); clip-path: inset(50%);
    overflow: hidden; white-space: nowrap;
  }

  /* "Show on the page" pill — mobile only. The fullscreen panel covers the CV,
     so instead of hiding the answer we offer a tap that closes the panel and
     reveals the highlighted section. Keeps the text; still delivers the jump. */
  .aw-viewpage-row { justify-content: flex-start; }
  .aw-view-on-page {
    display: inline-flex; align-items: center; gap: 6px;
    font: inherit; font-size: 12px; font-weight: 500; line-height: 1.2;
    color: var(--accent, #e23b3b);
    background: color-mix(in srgb, var(--accent, #e23b3b) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent, #e23b3b) 40%, transparent);
    border-radius: 999px; padding: 7px 13px; cursor: pointer;
    transition: background .15s ease;
  }
  .aw-view-on-page:hover { background: color-mix(in srgb, var(--accent, #e23b3b) 22%, transparent); }
  .aw-view-on-page:focus-visible { outline: 2px solid var(--accent, #e23b3b); outline-offset: 2px; }
  .aw-view-on-page svg { width: 14px; height: 14px; flex-shrink: 0; }
</style>

<script>
  // ---------------------------------------------------------------------------
  // Vanilla A2A client — ported from bks-web (A2AChat.tsx / agentService.ts).
  // ---------------------------------------------------------------------------

  type WidgetStr = {
    launcherLabel: string; headerTitle: string; headerSubtitle: string;
    inputPlaceholder: string; send: string; close: string; greeting: string;
    launcherText?: string;
    connecting: string; working: string; errorConnect: string;
    errorSend: string; errorAgent: string; emptyAnswer: string; retry: string;
    maximize?: string; restore?: string; resize?: string;
    cardOpen?: string; cardBack?: string; cardTitle?: string; cardIntro?: string;
    cardProtocol?: string; cardEndpoint?: string; cardModes?: string; cardSkills?: string;
    cardExamplesHint?: string; cardStreaming?: string; cardPush?: string;
    cardLoading?: string; cardUnavailable?: string;
    privacyNote?: string; privacyLink?: string;
  };

  // Every handler resolves to exactly one of these. send() decides what to render.
  type Outcome =
    | { kind: 'answer'; text: string }
    | { kind: 'agent-error'; text: string }
    | { kind: 'empty' };

  // Terminal A2A task states that mean "the agent stopped without an answer".
  // Both spellings of cancel(l)ed — A2A spec uses 'canceled', some agents emit 'cancelled'.
  const FAILED_STATES = new Set(['failed', 'canceled', 'cancelled', 'rejected', 'unknown']);

  const root = document.getElementById('agent-widget-root');
  if (root) {
    const launcher = document.getElementById('agent-widget-launcher') as HTMLButtonElement;
    const launcherLabel = document.getElementById('agent-widget-label') as HTMLButtonElement | null;
    const panel = document.getElementById('agent-widget-panel') as HTMLElement;
    const closeBtn = document.getElementById('agent-widget-close') as HTMLButtonElement;
    const maximizeBtn = document.getElementById('agent-widget-maximize') as HTMLButtonElement | null;
    const cardBtn = document.getElementById('agent-widget-cardbtn') as HTMLButtonElement | null;
    const cardEl = document.getElementById('agent-widget-card') as HTMLElement | null;
    const resizeHandle = document.getElementById('agent-widget-resize') as HTMLElement | null;
    const messagesEl = document.getElementById('agent-widget-messages') as HTMLElement;
    const form = document.getElementById('agent-widget-form') as HTMLFormElement;
    const input = document.getElementById('agent-widget-input') as HTMLInputElement;
    const sendBtn = document.getElementById('agent-widget-send') as HTMLButtonElement;
    const titleEl = document.getElementById('agent-widget-title') as HTMLElement;
    const subtitleEl = document.getElementById('agent-widget-subtitle') as HTMLElement;

    // --- i18n: detect language from <html lang>, default de ---
    const lang = (document.documentElement.lang || 'de').toLowerCase().startsWith('en') ? 'en' : 'de';
    const bundles = JSON.parse(root.getAttribute('data-i18n') || '{}') as Record<string, WidgetStr>;
    const t: WidgetStr = bundles[lang] || bundles.de;

    // --- mutable state (declared early to avoid TDZ in event handlers) ---
    let panelOpen = false;
    let greeted = false;
    let cardFetched = false;
    let streamingSupported = true; // default true; agent card refines this
    let cardEverReached = false;   // true once any agent endpoint answered (card or POST)
    let busy = false;
    let lastUserMessage = '';
    let agentCard: any = null;     // full A2A agent-card JSON (for the card view)
    let cardInflight: Promise<any | null> | null = null; // de-dupes concurrent fetches
    let cardShown = false;         // is the card view currently displayed?
    let cardRendered = false;      // has renderCard run for the current card?

    // --- Agent URL resolution -------------------------------------------------
    // Priority: ?agent= query param > localStorage('bridgeAgentUrl') > host-based.
    const CONTEXT_KEY = 'bridgeAgentContextId';
    const OVERRIDE_KEY = 'bridgeAgentUrl';
    function trimSlash(u: string): string { return u.replace(/\/+$/, ''); }
    // Only accept an override that points at a trusted host. A crafted ?agent=
    // link must never repoint the widget at an attacker endpoint and exfiltrate
    // what a visitor types. Allowlist: localhost + *.bks-lab.com.
    function isAllowedAgent(u: string): boolean {
      try {
        const h = new URL(u).hostname;
        return h === 'localhost' || h === '127.0.0.1' || h === '::1'
          || h === 'bks-lab.com' || h.endsWith('.bks-lab.com');
      } catch { return false; }
    }
    function resolveAgentUrl(): string {
      try {
        const qp = new URLSearchParams(window.location.search).get('agent');
        if (qp && isAllowedAgent(qp)) {
          try { localStorage.setItem(OVERRIDE_KEY, trimSlash(qp)); } catch {}
          return trimSlash(qp);
        }
        const stored = localStorage.getItem(OVERRIDE_KEY);
        if (stored && isAllowedAgent(stored)) return trimSlash(stored);
      } catch {}
      const host = window.location.hostname;
      if (host === 'localhost' || host === '127.0.0.1' || host === '::1') {
        return '/agent-proxy';
      }
      return 'https://mboiman.bks-lab.com';
    }
    const agentUrl = resolveAgentUrl();

    // --- contextId persistence (port of useSessionId) -------------------------
    function uuid(): string {
      try {
        if (crypto && typeof crypto.randomUUID === 'function') return crypto.randomUUID();
      } catch {}
      return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, (c) => {
        const r = (Math.random() * 16) | 0;
        const v = c === 'x' ? r : (r & 0x3) | 0x8;
        return v.toString(16);
      });
    }
    function getContextId(): string {
      try {
        let id = localStorage.getItem(CONTEXT_KEY) || '';
        if (!id) { id = uuid(); localStorage.setItem(CONTEXT_KEY, id); }
        return id;
      } catch {
        return uuid();
      }
    }
    const contextId = getContextId();

    // =========================================================================
    // SAFE rich-text renderer — escape-FIRST, then re-introduce an audited subset.
    //
    // THREAT MODEL: the agent's output is influenced by untrusted public visitors
    // (prompt injection). A visitor may try to make the agent emit <script>,
    // onerror=, javascript:/data: URLs, entity-encoded tags that re-form, etc.
    //
    // CORE INVARIANT: escapeHtml() runs ONCE on the WHOLE raw string FIRST. After
    // that, the working text contains no live `< > " '`. Every subsequent step only
    // (1) inserts OUR OWN hardcoded tags, or (2) pattern-matches on already-escaped
    // text. No visitor byte is ever re-interpreted as HTML. innerHTML never sees
    // raw model text — only this function's output.
    // =========================================================================

    /** HTML-escape EVERYTHING. The one and only entry point for untrusted bytes. */
    function escapeHtml(s: string): string {
      return s
        .replace(/&/g, '&amp;')   // MUST be first — so we don't double-escape our own entities
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    /** Validate + sanitise a link target. Operates on ALREADY-ESCAPED text.
     *  Returns a safe href, or null if the URL is not allowlisted. */
    function safeUrl(escapedUrl: string): string | null {
      const probe = escapedUrl.replace(/&amp;/g, '&');
      if (!/^https?:\/\//i.test(probe) && !/^mailto:/i.test(probe)) return null;
      if (!/^[A-Za-z0-9\-._~:/?#\[\]@!$&'()*+,;=%&#]+$/.test(escapedUrl)) return null;
      return escapedUrl; // already escaped → safe inside a double-quoted attribute
    }

    /** Inline formatting — applied ONLY to already-escaped text runs.
     *  Code spans are isolated via split (no sentinel char) so * _ ~ [ ] inside
     *  code stay literal and the other inline rules never touch code content. */
    function inlineFormat(escaped: string): string {
      const segs = escaped.split(/(`[^`]+`)/g);
      return segs.map((seg) => {
        // a captured code span: starts and ends with a backtick (char 96)
        if (seg.length >= 2 && seg.charCodeAt(0) === 96 && seg.charCodeAt(seg.length - 1) === 96) {
          return '<code class="aw-md-code">' + seg.slice(1, -1) + '</code>';
        }
        let s = seg.replace(/\[([^\]]+)\]\(([^)\s]+)\)/g, (m, text, url) => {
          const href = safeUrl(url);
          if (!href) return m; // not allowlisted -> leave as literal escaped text
          return '<a href="' + href + '" target="_blank" rel="noopener noreferrer">' + text + '</a>';
        });
        s = s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
        s = s.replace(/~~([^~]+)~~/g, '<del>$1</del>');
        s = s.replace(/(^|[^*])\*([^*\n]+)\*(?!\*)/g, '$1<em>$2</em>');
        return s;
      }).join('');
    }

    /** Split a GFM pipe-table row into cells, honouring escaped \| literals. */
    function splitRow(line: string): string[] {
      let tt = line.trim();
      if (tt.startsWith('|')) tt = tt.slice(1);
      if (tt.endsWith('|')) tt = tt.slice(0, -1);
      const cells: string[] = [];
      let cur = '';
      for (let i = 0; i < tt.length; i++) {
        if (tt[i] === '\\' && tt[i + 1] === '|') { cur += '|'; i++; continue; }
        if (tt[i] === '|') { cells.push(cur); cur = ''; continue; }
        cur += tt[i];
      }
      cells.push(cur);
      return cells.map((c) => c.trim());
    }

    /** Is this line a GFM separator row?  |---|:--:|---:|  → returns alignments. */
    function parseAlignRow(line: string): ('left' | 'right' | 'center' | 'none')[] | null {
      const cells = splitRow(line);
      if (cells.length === 0) return null;
      const aligns: ('left' | 'right' | 'center' | 'none')[] = [];
      for (const c of cells) {
        if (!/^:?-+:?$/.test(c)) return null;
        const left = c.startsWith(':');
        const right = c.endsWith(':');
        aligns.push(left && right ? 'center' : right ? 'right' : left ? 'left' : 'none');
      }
      return aligns;
    }

    /** List builder with one level of nesting. Operates on already-escaped lines. */
    function buildList(lines: string[], start: number, kind: 'ul' | 'ol'): { html: string; next: number } {
      const anyItem = /^(\s*)(?:\d+\.|[-*+])\s+(.*)$/;
      const isOlLine = (s: string) => /^\s*\d+\.\s+/.test(s);
      let i = start;
      let html = '<' + kind + ' class="aw-md-list">';
      let inNested = false;
      while (i < lines.length) {
        const m = anyItem.exec(lines[i]);
        if (!m) break;
        const indent = m[1].length;
        const content = inlineFormat(m[2]);
        if (indent >= 2) {
          if (!inNested) { html += '<ul class="aw-md-list aw-md-nested">'; inNested = true; }
          html += '<li>' + content + '</li>';
        } else {
          if ((kind === 'ol') !== isOlLine(lines[i])) break; // top-level kind switch ends the list
          if (inNested) { html += '</ul>'; inNested = false; }
          html += '<li>' + content + '</li>';
        }
        i++;
      }
      if (inNested) html += '</ul>';
      html += '</' + kind + '>';
      return { html, next: i };
    }

    // ── Agent UI directives ──────────────────────────────────────────────────
    // The agent may append a machine-only directive proposing a page action,
    // e.g.  ⟦ui:highlight tuev-sued⟧  on its own line at the end of the reply.
    // We (1) STRIP it from EVERY render so it never shows — even mid-stream a
    // half-typed sentinel is hidden — and (2) collect anchors so send() can run
    // the scroll+highlight once, on the final answer. Parsing the RAW text (pre-
    // escape) is fine: the sentinel chars ⟦ ⟧ are not HTML-special.
    const UI_DIRECTIVE_RE = /⟦\s*ui:highlight\s+([a-z0-9-]+)\s*⟧/g;
    function parseDirectives(raw: string): { text: string; anchors: string[] } {
      const anchors: string[] = [];
      let text = String(raw ?? '').replace(UI_DIRECTIVE_RE, (_m: string, a: string) => { anchors.push(a); return ''; });
      text = text.replace(/⟦\s*ui:highlight[^⟧]*$/, '');      // hide a not-yet-closed (streaming) sentinel
      text = text.replace(/[ \t]+\n/g, '\n').replace(/\n{3,}/g, '\n\n').trim();
      return { text, anchors };
    }

    /** MAIN ENTRY. raw = untrusted agent text. Returns sanitised HTML for innerHTML. */
    function safeMarkdown(raw: string): string {
      const escaped = escapeHtml(parseDirectives(raw).text);
      const lines = escaped.split('\n');
      const out: string[] = [];
      let i = 0;
      let para: string[] = [];
      const flushPara = () => {
        if (!para.length) return;
        out.push('<p class="aw-md-p">' + para.map(inlineFormat).join('<br>') + '</p>');
        para = [];
      };

      while (i < lines.length) {
        const line = lines[i];
        const trimmed = line.trim();

        // Fenced code block ``` — emitted verbatim (already escaped), no inline rules.
        if (/^```/.test(trimmed)) {
          flushPara();
          i++;
          const code: string[] = [];
          while (i < lines.length && !/^```/.test(lines[i].trim())) { code.push(lines[i]); i++; }
          i++;
          out.push('<pre class="aw-md-pre"><code>' + code.join('\n') + '</code></pre>');
          continue;
        }

        if (trimmed === '') { flushPara(); i++; continue; }

        // GFM table: current line has a pipe AND the next line is a valid separator.
        if (trimmed.includes('|') && i + 1 < lines.length) {
          const aligns = parseAlignRow(lines[i + 1]);
          if (aligns) {
            flushPara();
            const headerCells = splitRow(line);
            const colCount = Math.max(headerCells.length, aligns.length);
            const alignAttr = (idx: number) => {
              const a = aligns[idx] || 'none';
              return a === 'none' ? '' : ' style="text-align:' + a + '"';
            };
            const padCells = (cells: string[]) => {
              const r = cells.slice(0, colCount);
              while (r.length < colCount) r.push('');
              return r;
            };
            // 4+ columns rarely wrap well in a chat bubble → CSS .aw-md-wide
            // switches to a clean horizontal-scroll table. (still escape-first; this
            // is a fixed class string, no untrusted bytes enter the tag.)
            const tableCls = colCount >= 4 ? 'aw-md-table aw-md-wide' : 'aw-md-table';
            let html = '<div class="aw-md-table-wrap"><table class="' + tableCls + '"><thead><tr>';
            padCells(headerCells).forEach((c, idx) => { html += '<th' + alignAttr(idx) + '>' + inlineFormat(c) + '</th>'; });
            html += '</tr></thead><tbody>';
            i += 2;
            while (i < lines.length && lines[i].trim().includes('|') && lines[i].trim() !== '') {
              if (/^```/.test(lines[i].trim())) break;
              html += '<tr>';
              padCells(splitRow(lines[i])).forEach((c, idx) => { html += '<td' + alignAttr(idx) + '>' + inlineFormat(c) + '</td>'; });
              html += '</tr>';
              i++;
            }
            html += '</tbody></table></div>';
            out.push(html);
            continue;
          }
        }

        // Headings # ## ### -> h4 h5 h6 (scaled for the small panel)
        const h = /^(#{1,6})\s+(.*)$/.exec(trimmed);
        if (h) {
          flushPara();
          const level = Math.min(6, h[1].length);
          const tag = level <= 1 ? 'h4' : level === 2 ? 'h5' : 'h6';
          out.push('<' + tag + ' class="aw-md-h">' + inlineFormat(h[2].trim()) + '</' + tag + '>');
          i++;
          continue;
        }

        // Blockquote > ...  ('>' is '&gt;' after escaping)
        if (/^&gt;\s?/.test(trimmed)) {
          flushPara();
          const quote: string[] = [];
          while (i < lines.length && /^&gt;\s?/.test(lines[i].trim())) {
            quote.push(lines[i].trim().replace(/^&gt;\s?/, ''));
            i++;
          }
          out.push('<blockquote class="aw-md-quote">' + quote.map(inlineFormat).join('<br>') + '</blockquote>');
          continue;
        }

        // Lists (unordered - / * / + , ordered 1.)
        const isUl = /^([-*+])\s+/.test(trimmed);
        const isOl = /^(\d+)\.\s+/.test(trimmed);
        if (isUl || isOl) {
          flushPara();
          const r = buildList(lines, i, isOl ? 'ol' : 'ul');
          out.push(r.html);
          i = r.next;
          continue;
        }

        para.push(line);
        i++;
      }
      flushPara();
      return out.join('');
    }

    // --- DOM helpers ----------------------------------------------------------
    function scrollToBottom() { messagesEl.scrollTop = messagesEl.scrollHeight; }
    // Like scrollToBottom but only follows the growing answer while the reader is
    // already at the bottom — if they scrolled up to re-read, we don't yank them
    // back down. Used during the paced live reveal so long answers glide rather
    // than snap.
    function stickToBottom() {
      const slack = messagesEl.scrollHeight - messagesEl.scrollTop - messagesEl.clientHeight;
      if (slack < 120) messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    // Speech-bubble glyph (same as the launcher) — the agent's identity chip.
    const AGENT_AVATAR_SVG =
      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"' +
      ' stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">' +
      '<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>';

    /** A fresh avatar node (a DOM node can't be reused in two places at once). */
    function makeAvatar(): HTMLElement {
      const a = document.createElement('div');
      a.className = 'aw-avatar';
      a.setAttribute('aria-hidden', 'true');
      a.innerHTML = AGENT_AVATAR_SVG;
      return a;
    }

    /** Build a speaker row. Agent/error rows carry the avatar; user rows don't.
     *  Appends the row and returns it (caller decides what to put inside). */
    function makeRow(role: 'user' | 'agent'): HTMLElement {
      const row = document.createElement('div');
      row.className = 'aw-row ' + (role === 'user' ? 'aw-row-user' : 'aw-row-agent');
      if (role !== 'user') row.appendChild(makeAvatar());
      return row;
    }

    function addBubble(role: 'user' | 'agent', text: string): HTMLElement {
      const row = makeRow(role);
      const el = document.createElement('div');
      el.className = 'aw-msg ' + (role === 'user' ? 'aw-user' : 'aw-agent');
      if (role === 'user') {
        el.textContent = text; // user input is plain text, never interpreted
      } else {
        el.innerHTML = safeMarkdown(text);
      }
      row.appendChild(el);
      messagesEl.appendChild(row);
      scrollToBottom();
      return el; // the bubble itself — streaming sets .innerHTML on this node
    }

    // Error bubble with a retry affordance. The failures we surface (agent
    // unreachable / agent-reported error) are transient, so re-sending the last
    // user message is the right UX. The button removes its own bubble before
    // re-sending so there's never a stale retry control and the busy-lock holds.
    function addErrorBubble(text: string): HTMLElement {
      const row = makeRow('agent');
      const wrap = document.createElement('div');
      wrap.className = 'aw-msg aw-error';
      const msg = document.createElement('div');
      msg.innerHTML = safeMarkdown(text); // escape-first, same as agent bubbles
      wrap.appendChild(msg);

      if (lastUserMessage) {
        const retryBtn = document.createElement('button');
        retryBtn.type = 'button';
        retryBtn.className = 'aw-retry';
        retryBtn.textContent = t.retry;
        retryBtn.disabled = busy;
        retryBtn.addEventListener('click', () => {
          if (busy) return;
          const msgToRetry = lastUserMessage;
          row.remove();
          send(msgToRetry);
        });
        wrap.appendChild(retryBtn);
      }

      row.appendChild(wrap);
      messagesEl.appendChild(row);
      scrollToBottom();
      return wrap;
    }

    function makeWorkingIndicator(): { el: HTMLElement; setStep: (s: string) => void } {
      const row = makeRow('agent');
      const pill = document.createElement('div');
      pill.className = 'aw-working';
      const dots = document.createElement('span');
      dots.className = 'aw-dots';
      dots.innerHTML = '<span></span><span></span><span></span>';
      const label = document.createElement('span');
      label.className = 'aw-step';
      label.textContent = t.working;
      pill.appendChild(dots);
      pill.appendChild(label);
      row.appendChild(pill);
      messagesEl.appendChild(row);
      scrollToBottom();
      // .el = the ROW, so callers' indicator.el.remove() clears avatar + pill together.
      return { el: row, setStep: (s: string) => { label.textContent = s || t.working; scrollToBottom(); } };
    }

    function extractText(parts: any[]): string {
      if (!Array.isArray(parts)) return '';
      return parts.filter((p) => p && p.kind === 'text').map((p) => p.text).join('\n');
    }

    // --- Agent card (capability + reachability detection) ---------------------
    // Fetches /.well-known/agent-card.json once, caches it in agentCard, and uses
    // it for (a) capability/reachability detection and (b) the in-panel card view.
    async function loadAgentCard(): Promise<any | null> {
      if (agentCard) return agentCard;
      if (cardInflight) return cardInflight;   // a fetch is already pending — share it
      cardInflight = (async () => {
        try {
          const res = await fetch(`${agentUrl}/.well-known/agent-card.json`, {
            method: 'GET',
            headers: { Accept: 'application/json' },
            mode: 'cors',
            signal: AbortSignal.timeout(8000),
          });
          if (!res.ok) return null;
          cardEverReached = true; // agent host is reachable
          const card = await res.json();
          // Cache only a real object; a falsy/non-object 200 body is a soft failure
          // (shows the unavailable state) and must not poison the truthy cache guard.
          if (card && typeof card === 'object') agentCard = card;
          if (card && card.capabilities && typeof card.capabilities.streaming === 'boolean') {
            streamingSupported = card.capabilities.streaming;
          }
          if (card && card.name) { subtitleEl.textContent = (lang === 'de' && card.description) || t.headerSubtitle; }
          return (card && typeof card === 'object') ? card : null;
        } catch {
          // Non-fatal: keep streaming-first default and try anyway.
          return null;
        } finally {
          cardInflight = null;
        }
      })();
      return cardInflight;
    }

    // --- Fact chips on the host page (progressive enhancement) ----------------
    // Derive the "protocolVersion / transport / streaming / skills" chips from the card
    // instead of hand-maintaining them in config. Returns null when the card can't
    // answer, so the caller leaves the server-rendered fallback alone.
    function factsFromCard(card: any): string[] | null {
      if (!card || typeof card !== 'object') return null;
      // Read BOTH A2A dialects. v1.0 moved version + binding onto supportedInterfaces[]
      // and dropped the top-level pair; 0.3 has only the top level. Reading a single
      // location is precisely the bug that cut this agent's own BKS consult off for
      // five days — don't repeat it one layer up.
      const iface = Array.isArray(card.supportedInterfaces)
        ? card.supportedInterfaces.find((i: any) => i && typeof i === 'object')
        : null;
      const protocol = String(iface?.protocolVersion ?? card.protocolVersion ?? '').trim();
      const transport = String(iface?.protocolBinding ?? card.preferredTransport ?? '').trim();
      const streaming = card.capabilities?.streaming;
      const skills = Array.isArray(card.skills) ? card.skills.length : null;

      const facts: string[] = [];
      if (protocol) facts.push(`protocolVersion: ${protocol}`);
      if (transport) facts.push(`transport: ${transport}`);
      if (typeof streaming === 'boolean') facts.push(`streaming: ${streaming}`);
      if (skills !== null) facts.push(`skills: ${skills}`);
      return facts.length ? facts : null;
    }

    function renderAgentFacts(card: any): void {
      const host = document.querySelector('[data-agent-facts]');
      if (!host) return;                       // host page has no chips — nothing to do
      const facts = factsFromCard(card);
      if (!facts) return;                      // unreachable/unusable card → keep fallback
      host.replaceChildren(...facts.map((fact) => {
        const el = document.createElement('span');
        el.className = 'cv-agent-fact rounded-full px-2.5 py-1 text-[11px]';
        el.textContent = fact;                 // textContent, never innerHTML — card data is remote
        return el;
      }));
    }

    // =========================================================================
    // AGENT-CARD VIEW — renders the live A2A card inside the panel. Every value is
    // injected via textContent (never innerHTML), so even a compromised/injected
    // card field cannot become live HTML. URLs are scheme-validated before linking.
    // =========================================================================
    function isHttpUrl(u: unknown): u is string {
      if (typeof u !== 'string') return false;
      try { const p = new URL(u); return p.protocol === 'https:' || p.protocol === 'http:'; }
      catch { return false; }
    }
    function el(tag: string, cls?: string, text?: string): HTMLElement {
      const n = document.createElement(tag);
      if (cls) n.className = cls;
      if (text != null) n.textContent = text;
      return n;
    }
    function cardSection(heading: string): HTMLElement {
      const s = el('div', 'aw-card-section');
      s.appendChild(el('h4', 'aw-card-section-h', heading)); // real heading (under the h3 name) for AT
      return s;
    }
    function metaLine(label: string, value: string, href?: string): HTMLElement {
      const p = el('p', 'aw-card-meta');
      p.appendChild(el('strong', undefined, label + ': '));
      if (href && isHttpUrl(href)) {
        const a = document.createElement('a');
        a.href = href; a.target = '_blank'; a.rel = 'noopener noreferrer';
        a.textContent = value;
        p.appendChild(a);
      } else {
        p.appendChild(document.createTextNode(value));
      }
      return p;
    }

    function renderCard(card: any | null): void {
      if (!cardEl) return;
      cardEl.textContent = '';
      if (!card) { cardEl.appendChild(el('p', 'aw-card-empty', t.cardUnavailable || 'Agent card unavailable.')); return; }

      cardEl.appendChild(el('p', 'aw-card-eyebrow', t.cardTitle || 'Agent Card'));
      cardEl.appendChild(el('h3', 'aw-card-name', String(card.name || t.headerTitle || 'Agent')));
      const desc = typeof card.description === 'string' ? card.description.trim() : '';
      if (desc) cardEl.appendChild(el('p', 'aw-card-desc', desc));
      if (t.cardIntro) cardEl.appendChild(el('p', 'aw-card-intro', t.cardIntro));

      // --- A2A protocol section: bindings, capabilities, version, modes, endpoint ---
      const proto = cardSection(t.cardProtocol || 'A2A protocol');
      const badges = el('div', 'aw-card-badges');
      const ifaces = Array.isArray(card.supportedInterfaces) ? card.supportedInterfaces : [];
      ifaces.forEach((i: any) => { if (i && typeof i.protocolBinding === 'string') badges.appendChild(el('span', 'aw-card-badge', i.protocolBinding)); });
      if (card.capabilities && card.capabilities.streaming) badges.appendChild(el('span', 'aw-card-badge', t.cardStreaming || 'Streaming'));
      if (card.capabilities && card.capabilities.pushNotifications) badges.appendChild(el('span', 'aw-card-badge', t.cardPush || 'Push'));
      if (card.version) badges.appendChild(el('span', 'aw-card-badge', 'v' + String(card.version)));
      if (badges.childNodes.length) proto.appendChild(badges);

      const inModes = Array.isArray(card.defaultInputModes) ? card.defaultInputModes.join(', ') : '';
      const outModes = Array.isArray(card.defaultOutputModes) ? card.defaultOutputModes.join(', ') : '';
      if (inModes || outModes) proto.appendChild(metaLine(t.cardModes || 'I/O', [inModes, outModes].filter(Boolean).join(' / ')));

      const endpoint = (ifaces[0] && typeof ifaces[0].url === 'string') ? ifaces[0].url : (typeof card.url === 'string' ? card.url : '');
      if (endpoint) {
        let host = endpoint;
        try { host = new URL(endpoint).host; } catch {}
        // Only LINK the endpoint if it's a trusted host (same allowlist as the fetch
        // target). A semi-trusted card must not turn the widget into an open-redirect
        // to an arbitrary external site; otherwise show the host as plain text.
        proto.appendChild(metaLine(t.cardEndpoint || 'Endpoint', host, isAllowedAgent(endpoint) ? endpoint : undefined));
      }
      cardEl.appendChild(proto);

      // --- Skills section: name, description, tags, clickable example questions ---
      const skills = Array.isArray(card.skills) ? card.skills : [];
      if (skills.length) {
        const sec = cardSection(t.cardSkills || 'Skills');
        skills.forEach((s: any) => {
          if (!s) return;
          const item = el('div', 'aw-card-skill');
          item.appendChild(el('h5', 'aw-card-skill-name', String(s.name || s.id || '')));
          if (typeof s.description === 'string' && s.description.trim()) {
            item.appendChild(el('div', 'aw-card-skill-desc', s.description.trim()));
          }
          if (Array.isArray(s.tags) && s.tags.length) {
            const tg = el('div', 'aw-card-tags');
            s.tags.forEach((tag: any) => { if (tag != null) tg.appendChild(el('span', 'aw-card-tag', String(tag))); });
            item.appendChild(tg);
          }
          const examples = Array.isArray(s.examples) ? s.examples.filter((q: any) => typeof q === 'string' && q.trim()) : [];
          if (examples.length) {
            if (t.cardExamplesHint) item.appendChild(el('div', 'aw-card-ex-hint', t.cardExamplesHint));
            const list = el('div', 'aw-card-examples');
            examples.forEach((q: string) => {
              const text = q.trim();
              const chip = document.createElement('button');
              chip.type = 'button';
              chip.className = 'aw-card-ex';
              chip.textContent = text;                 // raw text, safe; sent verbatim on click
              // focus the (visible, persistent) input BEFORE the async send, so focus
              // never lands on the about-to-be-hidden chip and drop to <body>.
              chip.addEventListener('click', () => { closeCard(); input.focus(); send(text); });
              list.appendChild(chip);
            });
            item.appendChild(list);
          }
          sec.appendChild(item);
        });
        cardEl.appendChild(sec);
      }
    }

    function setCardBtnState(): void {
      if (!cardBtn) return;
      const label = cardShown ? (t.cardBack || 'Back to chat') : (t.cardOpen || 'Show agent card');
      cardBtn.setAttribute('aria-label', label);
      cardBtn.setAttribute('title', label);
      cardBtn.setAttribute('aria-pressed', cardShown ? 'true' : 'false');
    }

    async function openCard(): Promise<void> {
      if (!cardEl) return;
      cardShown = true;
      cardEl.hidden = false;
      panel.classList.add('aw-show-card');
      if (cardEl.setAttribute) cardEl.setAttribute('aria-label', t.cardTitle || 'Agent Card');
      setCardBtnState();
      if (!cardRendered) {
        cardEl.textContent = '';
        cardEl.appendChild(el('p', 'aw-card-loading', t.cardLoading || 'Loading …'));
        const card = await loadAgentCard();
        if (!cardShown) return;        // user toggled away while loading
        renderCard(card);
        cardRendered = !!card;         // retry next open if it failed
      }
      cardEl.scrollTop = 0;
    }
    function closeCard(): void {
      cardShown = false;
      panel.classList.remove('aw-show-card');
      if (cardEl) cardEl.hidden = true;
      setCardBtnState();
    }
    function toggleCard(): void { if (cardShown) closeCard(); else void openCard().catch(() => {}); }

    // --- JSON-RPC request body (exact shape from agentService.ts) -------------
    function buildBody(message: string, useStreaming: boolean) {
      return JSON.stringify({
        jsonrpc: '2.0',
        id: uuid(),
        method: useStreaming ? 'message/stream' : 'message/send',
        params: {
          message: {
            role: 'user',
            parts: [{ kind: 'text', text: message }],
            messageId: uuid(),
            contextId: contextId,
            // Machine channel (A2A message.metadata): tells the agent WHERE it is
            // being addressed from — page, language, the section in view, and the
            // highlight anchors that actually exist on THIS page. Separate from the
            // visible question (the user bubble shows only what was typed); the agent
            // treats it as advisory. The DOM whitelist still gates any real highlight.
            metadata: { runtime_context: buildRuntimeContext() },
          },
        },
      });
    }

    async function postMessage(message: string, useStreaming: boolean): Promise<Response> {
      return fetch(agentUrl, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Accept: useStreaming ? 'text/event-stream' : 'application/json',
        },
        mode: 'cors',
        body: buildBody(message, useStreaming),
      });
    }

    // --- Streaming (SSE over fetch + ReadableStream) → Outcome ----------------
    async function handleStream(
      res: Response,
      indicator: { el: HTMLElement; setStep: (s: string) => void },
    ): Promise<Outcome> {
      const reader = res.body?.getReader();
      if (!reader) throw new Error('no-stream-body');
      const decoder = new TextDecoder();
      let buffer = '';
      let finalContent = '';     // from 'completed' status-update or 'message' frames
      let artifactContent = '';  // from 'artifact-update' — fallback answer carrier
      let errorText = '';        // surfaced text of a terminal failure state
      let sawError = false;
      let bubble: HTMLElement | null = null;

      function ensureBubble(): HTMLElement {
        if (!bubble) bubble = addBubble('agent', '');
        return bubble;
      }
      // Paced reveal: the server may deliver the answer in big chunks (or one
      // 'completed' frame). Dumping each chunk makes the panel lurch downward, so
      // instead we hold the newest full text as a target and reveal it a few chars
      // per animation frame — even a one-shot answer then reads like a stream.
      // Catch up faster when far behind so we never lag a fast sender; honour
      // prefers-reduced-motion by showing everything at once.
      let liveTarget = '';
      let liveShown = 0;
      let paceRAF = 0;
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      function paintLive() {
        ensureBubble().innerHTML = safeMarkdown(liveTarget.slice(0, liveShown));
        stickToBottom();
      }
      function pump() {
        paceRAF = 0;
        if (liveShown >= liveTarget.length) return;
        const backlog = liveTarget.length - liveShown;
        liveShown = Math.min(liveTarget.length, liveShown + (backlog > 400 ? 60 : 18));
        paintLive();
        if (liveShown < liveTarget.length) paceRAF = requestAnimationFrame(pump);
      }
      function renderLive(text: string) {
        liveTarget = text;
        if (liveShown > liveTarget.length) liveShown = 0;   // replaced/shrank → restart
        if (reduceMotion) { liveShown = liveTarget.length; paintLive(); return; }
        if (!paceRAF) paceRAF = requestAnimationFrame(pump);
      }
      function finishLive() {
        if (paceRAF) { cancelAnimationFrame(paceRAF); paceRAF = 0; }
      }

      try {
        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          buffer += decoder.decode(value, { stream: true });
          const lines = buffer.split('\n');
          buffer = lines.pop() || '';
          for (const line of lines) {
            if (!line.startsWith('data: ')) continue;
            const data = line.slice(6);
            if (data === '[DONE]') continue;
            let event: any;
            try { event = JSON.parse(data); } catch { continue; }

            if (event.jsonrpc !== '2.0' || !event.result) {
              if (event.error) { sawError = true; errorText = event.error.message || errorText; }
              continue;
            }
            const result = event.result;

            // artifact-update — the answer's authoritative carrier
            if (result.kind === 'artifact-update' && result.artifact) {
              const txt = extractText(result.artifact.parts || []);
              if (txt) {
                artifactContent = txt;
                if (!finalContent.trim()) renderLive(artifactContent.trim());
              }
              continue;
            }

            // status-update — working / completed / terminal-failure
            if (result.kind === 'status-update' && result.status) {
              const status = result.status;
              const txt = extractText(status.message?.parts || []);
              const state = status.state;
              if (state === 'working') {
                if (txt) indicator.setStep(txt);
              } else if (state === 'completed') {
                if (txt) { finalContent = txt.trim(); renderLive(finalContent); }
              } else if (FAILED_STATES.has(state)) {
                sawError = true;
                if (txt) errorText = txt.trim();
              }
              continue;
            }

            // message frame (legacy/buffered-style mid-stream) — append.
            if (result.kind === 'message' && result.parts) {
              const txt = extractText(result.parts);
              if (txt) { finalContent += txt; renderLive(finalContent); }
            }
          }
        }
      } finally {
        finishLive();
        indicator.el.remove();
      }

      const answer = (finalContent.trim() || artifactContent.trim());
      if (answer) {
        if (bubble) bubble.innerHTML = safeMarkdown(answer);
        return { kind: 'answer', text: answer };
      }
      if (bubble) (bubble.closest('.aw-row') || bubble).remove(); // empty live bubble — drop its row
      if (sawError) return { kind: 'agent-error', text: errorText || t.errorAgent };
      return { kind: 'empty' };
    }

    // --- Buffered (message/send) fallback → Outcome ---------------------------
    function parseBuffered(data: any): Outcome {
      if (data && data.error) return { kind: 'agent-error', text: data.error.message || t.errorAgent };
      if (!data || data.jsonrpc !== '2.0' || !data.result) return { kind: 'empty' };

      const result = data.result;
      let artifactText = '';
      if (Array.isArray(result.artifacts)) {
        artifactText = result.artifacts
          .map((a: any) => extractText(a && a.parts ? a.parts : []))
          .filter(Boolean)
          .join('\n')
          .trim();
      }
      const taskState = result.status?.state;
      const statusText = extractText(result.status?.message?.parts || []).trim();
      const taskFailed = taskState && FAILED_STATES.has(taskState);

      let plain = '';
      if (result.parts) plain = extractText(result.parts).trim();
      else if (result.message?.parts) plain = extractText(result.message.parts).trim();
      else if (typeof result === 'string') plain = (result as string).trim();
      else if (typeof result.text === 'string') plain = result.text.trim();
      else if (typeof result.content === 'string') plain = result.content.trim();

      const answer = artifactText || plain || (!taskFailed ? statusText : '');
      if (answer) return { kind: 'answer', text: answer };
      if (taskFailed) return { kind: 'agent-error', text: statusText || t.errorAgent };
      return { kind: 'empty' };
    }

    async function handleBuffered(
      res: Response,
      indicator: { el: HTMLElement; setStep: (s: string) => void },
    ): Promise<Outcome> {
      let data: any;
      try {
        data = await res.json();
      } finally {
        indicator.el.remove();
      }
      return parseBuffered(data);
    }

    // =========================================================================
    // AGENT-PROPOSED PAGE ACTION — scroll to a CV section + flash a red ring.
    // The agent only PROPOSES an anchor in its reply; the widget EXECUTES, gated
    // by a DOM whitelist. Same posture as the agent's other tools: propose, never
    // freely act. A prompt-injected agent can at most jump between Michael's own
    // CV sections — no foreign selectors, no HTML, no navigation. Scroll + outline
    // only, fully reversible by removing the class.
    // =========================================================================
    const ANCHOR_RE = /^[a-z0-9-]+$/;
    let flashTimer = 0;
    let flashEl: HTMLElement | null = null;

    // visually-hidden live region announcing the highlight (screen readers)
    const liveRegion = document.createElement('div');
    liveRegion.className = 'aw-visually-hidden';
    liveRegion.setAttribute('aria-live', 'polite');
    root.appendChild(liveRegion);

    // Mobile "show on the page" affordance: the fullscreen panel covers the CV,
    // so rather than hide the answer we drop a tappable pill into the chat that
    // closes the panel and reveals the highlighted section on demand.
    let viewPillRow: HTMLElement | null = null;
    function removeViewOnPagePill() {
      if (viewPillRow) { viewPillRow.remove(); viewPillRow = null; }
    }
    const PIN_SVG =
      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"' +
      ' stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">' +
      '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>' +
      '<circle cx="12" cy="10" r="3"></circle></svg>';
    function addViewOnPagePill(label: string, onTap: () => void) {
      removeViewOnPagePill();
      const row = document.createElement('div');
      row.className = 'aw-row aw-row-agent aw-viewpage-row';
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'aw-view-on-page';
      const what = label
        ? (lang === 'en' ? `Show “${label}” on the page` : `„${label}“ auf der Seite zeigen`)
        : (lang === 'en' ? 'Show on the page' : 'Auf der Seite zeigen');
      btn.innerHTML = PIN_SVG + '<span></span>';
      btn.querySelector('span')!.textContent = what;
      btn.addEventListener('click', () => { removeViewOnPagePill(); onTap(); });
      row.appendChild(btn);
      messagesEl.appendChild(row);
      scrollToBottom();
      viewPillRow = row;
    }

    function highlightAnchor(anchor: string): boolean {
      if (!anchor || !ANCHOR_RE.test(anchor)) return false;
      // Whitelist: the anchor MUST exist as a real [data-cv-anchor] in the page.
      // anchor is /^[a-z0-9-]+$/ → safe to interpolate into the attribute selector.
      const target = document.querySelector<HTMLElement>(`[data-cv-anchor="${anchor}"]`);
      if (!target) return false;
      // single highlight: clear any previous ring + pending timeout first
      if (flashTimer) { clearTimeout(flashTimer); flashTimer = 0; }
      if (flashEl) flashEl.classList.remove('bridge-flash');
      flashEl = null;
      removeViewOnPagePill();                 // drop a stale "show on page" pill
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      // A section anchor (a whole group) aligns to its top so the heading leads;
      // a single entry centres in view.
      const block = (target.hasAttribute('data-cv-group') ? 'start' : 'center') as ScrollLogicalPosition;
      const label = (target.querySelector('h2, h3, h4') as HTMLElement | null)?.textContent?.trim()
        || target.getAttribute('data-cv-group')?.trim() || '';
      const reveal = () => {
        target.scrollIntoView({ behavior: reduce ? 'auto' : 'smooth', block });
        target.classList.add('bridge-flash');
        flashEl = target;
        if (label) liveRegion.textContent = (lang === 'en' ? 'Highlighted on the page: ' : 'Auf der Seite hervorgehoben: ') + label;
        flashTimer = window.setTimeout(() => {
          target.classList.remove('bridge-flash');
          flashTimer = 0;
          if (flashEl === target) flashEl = null;
        }, 2600);
      };
      // On mobile the panel is fullscreen and covers the CV. Closing it to show the
      // jump would also hide the answer the visitor just received — so keep the
      // answer and offer a tap that closes the panel and reveals the section. On
      // desktop the panel floats beside the CV, so reveal straight away.
      if (isMobile() && panelOpen) {
        addViewOnPagePill(label, () => { closePanel(); window.setTimeout(reveal, 120); });
      } else {
        reveal();
      }
      return true;
    }

    // Execute directives carried by a final answer — at most ONE highlight.
    function runDirectives(text: string): void {
      const { anchors } = parseDirectives(text);
      for (const a of anchors) { if (highlightAnchor(a)) break; }
    }

    // Dev hook: drive the highlight from the console without an agent (test recipe).
    //   __bridgeUI.highlight('tuev-sued')
    try { (window as any).__bridgeUI = { highlight: highlightAnchor }; } catch {}

    // ── Runtime context for the agent ────────────────────────────────────────
    // The agent reaches the page as a stateless `claude -p` turn — it only sees the
    // question text. To know WHERE it is being addressed from (and that it can drive
    // the page), each outbound message carries a machine-readable context block via
    // A2A message.metadata.runtime_context. Built from the SAME [data-cv-anchor]
    // whitelist the highlight uses, so the anchor set the agent is told about is
    // exactly what the widget can actually act on.

    /** The CV section whose centre is nearest the viewport centre (or null). */
    function currentVisibleAnchor(): HTMLElement | null {
      const vh = window.innerHeight || 0;
      let best: HTMLElement | null = null;
      let bestDist = Infinity;
      document.querySelectorAll<HTMLElement>('[data-cv-anchor]').forEach((el) => {
        const r = el.getBoundingClientRect();
        if (r.bottom < 0 || r.top > vh) return;          // fully off-screen
        const dist = Math.abs((r.top + r.height / 2) - vh / 2);
        if (dist < bestDist) { bestDist = dist; best = el; }
      });
      return best;
    }

    /** Advisory context string handed to the agent each turn (localized). */
    function buildRuntimeContext(): string {
      const all = Array.from(document.querySelectorAll<HTMLElement>('[data-cv-anchor]'))
        .filter((el) => ANCHOR_RE.test(el.getAttribute('data-cv-anchor') || ''));
      // A section anchor carries data-cv-group (its human label) and stands for a
      // whole group of entries — usable for category/overview questions. Plain
      // entry anchors point at a single item. We tell the agent both, separately,
      // so it can pick a section for "which talks?" and an entry for a specific one.
      const sectionSlugs = new Set(
        all.filter((el) => el.hasAttribute('data-cv-group'))
           .map((el) => el.getAttribute('data-cv-anchor') || ''),
      );
      const sections = all
        .filter((el) => el.hasAttribute('data-cv-group'))
        .map((el) => ({
          a: el.getAttribute('data-cv-anchor') || '',
          label: (el.getAttribute('data-cv-group') || '').trim().replace(/\s+/g, ' ').slice(0, 60),
        }));
      const entries = Array.from(new Set(
        all.map((el) => el.getAttribute('data-cv-anchor') || '')
           .filter((a) => !sectionSlugs.has(a)),
      ));
      const visEl = currentVisibleAnchor();
      const visAnchor = visEl ? visEl.getAttribute('data-cv-anchor') : '';
      const visLabel = visEl
        ? (visEl.getAttribute('data-cv-group')
            || (visEl.querySelector('h2,h3,h4') as HTMLElement | null)?.textContent
            || '').trim().replace(/\s+/g, ' ').slice(0, 80)
        : '';
      const path = location.pathname;
      if (lang === 'en') {
        const vis = visAnchor
          ? `Currently in the visitor's view: section “${visLabel}” (anchor ${visAnchor}).`
          : `No specific section is in the visitor's view right now.`;
        return [
          `You are embedded on Michael Boiman's CV page (path ${path}, UI language ${lang}). You can guide this page: scrolling to and briefly highlighting one section via ⟦ui:highlight <anchor>⟧.`,
          vis,
          sections.length ? `Section anchors (each spans a whole group — use one for a category/overview question, e.g. "which talks?"): ${sections.map((s) => `${s.a} (${s.label})`).join(', ')}.` : '',
          entries.length ? `Single-entry anchors (use one when the answer points at a specific entry): ${entries.join(', ')}.` : '',
        ].filter(Boolean).join('\n');
      }
      const vis = visAnchor
        ? `Aktuell im Blickfeld des Besuchers: Abschnitt „${visLabel}“ (Anker ${visAnchor}).`
        : `Aktuell ist kein bestimmter Abschnitt im Blickfeld des Besuchers.`;
      return [
        `Sie sind auf Michael Boimans CV-Seite eingebettet (Pfad ${path}, Oberflächensprache ${lang}). Sie können diese Seite führen: zu einem Abschnitt scrollen und ihn kurz hervorheben via ⟦ui:highlight <anchor>⟧.`,
        vis,
        sections.length ? `Abschnitts-Anker (umfassen je eine ganze Gruppe — einer davon für Kategorie-/Übersichtsfragen, z. B. „welche Vorträge?"): ${sections.map((s) => `${s.a} (${s.label})`).join(', ')}.` : '',
        entries.length ? `Einzel-Anker (einer davon, wenn die Antwort auf einen bestimmten Eintrag zeigt): ${entries.join(', ')}.` : '',
      ].filter(Boolean).join('\n');
    }

    // --- Send orchestration ---------------------------------------------------
    function setBusy(b: boolean) {
      busy = b;
      sendBtn.disabled = b;
      input.disabled = b;
      // Block the card toggle while streaming — else opening the card hides the
      // message list and the live answer renders into it invisibly.
      if (cardBtn) cardBtn.disabled = b;
    }

    function renderOutcome(outcome: Outcome): void {
      if (outcome.kind === 'answer') addBubble('agent', outcome.text);
      else if (outcome.kind === 'empty') addBubble('agent', t.emptyAnswer);
      else addErrorBubble(outcome.text);
    }

    async function send(message: string): Promise<void> {
      if (!message.trim() || busy) return;
      lastUserMessage = message;
      if (cardShown) closeCard();   // sending switches back to the chat view
      setBusy(true);
      addBubble('user', message);

      let reached = false;
      let indicator: { el: HTMLElement; setStep: (s: string) => void } | null = null;
      try {
        if (streamingSupported) {
          indicator = makeWorkingIndicator();
          try {
            const res = await postMessage(message, true);
            reached = true; cardEverReached = true;
            if (!res.ok || !res.body) throw new Error(`HTTP ${res.status}`);
            const outcome = await handleStream(res, indicator); // removes indicator in finally
            indicator = null;
            if (outcome.kind === 'answer') { runDirectives(outcome.text); return; } // bubble already rendered live
            renderOutcome(outcome);
            return;
          } catch {
            if (indicator) { try { indicator.el.remove(); } catch {} indicator = null; }
            // fall through to buffered (the documented fallback)
          }
        }

        indicator = makeWorkingIndicator();
        const res2 = await postMessage(message, false);
        reached = true; cardEverReached = true;
        if (!res2.ok) throw new Error(`HTTP ${res2.status}`);
        const outcome = await handleBuffered(res2, indicator);
        indicator = null;
        renderOutcome(outcome);
        if (outcome.kind === 'answer') runDirectives(outcome.text);
      } catch {
        if (indicator) { try { indicator.el.remove(); } catch {} }
        const unreachable = !reached || !cardEverReached;
        addErrorBubble(unreachable ? t.errorConnect : t.errorSend);
      } finally {
        setBusy(false);
        if (panelOpen) input.focus();
      }
    }

    // =========================================================================
    // RESIZE + MAXIMIZE — (a) maximize toggle snaps default<->large; (b) drag the
    // top-left grip for a free size. Persisted in localStorage; mobile = fullscreen.
    // =========================================================================
    const SIZE_KEY = 'bridgeAgentWidgetSize';
    const MIN_W = 320, MIN_H = 420, DEFAULT_W = 380, DEFAULT_H = 560;
    const maxW = () => Math.round(window.innerWidth * 0.95);
    const maxH = () => Math.round(window.innerHeight * 0.92);
    const isMobile = () => window.matchMedia('(max-width: 639px)').matches;
    const clamp = (v: number, lo: number, hi: number) => Math.min(Math.max(v, lo), hi);

    type SizeState = { mode: 'default' | 'max' | 'custom'; w?: number; h?: number };
    let sizeState: SizeState = { mode: 'default' };

    function loadSizeState(): SizeState {
      try {
        const raw = localStorage.getItem(SIZE_KEY);
        if (raw) {
          const p = JSON.parse(raw);
          if (p && (p.mode === 'default' || p.mode === 'max' || p.mode === 'custom')) return p;
        }
      } catch {}
      return { mode: 'default' };
    }
    function saveSizeState(s: SizeState) {
      try { localStorage.setItem(SIZE_KEY, JSON.stringify(s)); } catch {}
    }
    function syncMaximizeAria() {
      if (!maximizeBtn) return;
      const maxed = panel.classList.contains('aw-is-max');
      maximizeBtn.setAttribute('aria-pressed', maxed ? 'true' : 'false');
      const label = maxed ? (t.restore || 'Restore size') : (t.maximize || 'Enlarge');
      maximizeBtn.setAttribute('aria-label', label);
      maximizeBtn.setAttribute('title', label);
    }
    function applySizeState(s: SizeState) {
      if (isMobile()) { panel.classList.remove('aw-is-max'); return; }
      if (s.mode === 'max') {
        panel.classList.add('aw-is-max');
        root.style.removeProperty('--aw-w');
        root.style.removeProperty('--aw-h');
      } else if (s.mode === 'custom' && s.w && s.h) {
        panel.classList.remove('aw-is-max');
        root.style.setProperty('--aw-w', clamp(s.w, MIN_W, maxW()) + 'px');
        root.style.setProperty('--aw-h', clamp(s.h, MIN_H, maxH()) + 'px');
      } else {
        panel.classList.remove('aw-is-max');
        root.style.setProperty('--aw-w', DEFAULT_W + 'px');
        root.style.setProperty('--aw-h', DEFAULT_H + 'px');
      }
      syncMaximizeAria();
    }
    function toggleMaximize() {
      if (isMobile()) return;
      sizeState = sizeState.mode === 'max' ? { mode: 'default' } : { mode: 'max' };
      applySizeState(sizeState);
      saveSizeState(sizeState);
      scrollToBottom();
    }

    // free drag-resize (pointer events); top-left grip grows the bottom-right panel.
    let dragging = false;
    let startX = 0, startY = 0, startW = 0, startH = 0, pointerId = -1;
    function onResizeMove(e: PointerEvent) {
      if (!dragging) return;
      const dx = e.clientX - startX;
      const dy = e.clientY - startY;
      root.style.setProperty('--aw-w', clamp(startW - dx, MIN_W, maxW()) + 'px');
      root.style.setProperty('--aw-h', clamp(startH - dy, MIN_H, maxH()) + 'px');
    }
    function onResizeUp() {
      if (!dragging) return;
      dragging = false;
      panel.classList.remove('aw-resizing');
      try { resizeHandle?.releasePointerCapture(pointerId); } catch {}
      window.removeEventListener('pointermove', onResizeMove);
      window.removeEventListener('pointerup', onResizeUp);
      window.removeEventListener('pointercancel', onResizeUp);
      const rect = panel.getBoundingClientRect();
      sizeState = { mode: 'custom', w: Math.round(rect.width), h: Math.round(rect.height) };
      saveSizeState(sizeState);
      syncMaximizeAria();
      scrollToBottom();
    }
    function onResizeDown(e: PointerEvent) {
      if (isMobile()) return;
      e.preventDefault();
      dragging = true;
      pointerId = e.pointerId;
      const rect = panel.getBoundingClientRect();
      startX = e.clientX; startY = e.clientY; startW = rect.width; startH = rect.height;
      panel.classList.add('aw-resizing');
      try { resizeHandle?.setPointerCapture(pointerId); } catch {}
      window.addEventListener('pointermove', onResizeMove);
      window.addEventListener('pointerup', onResizeUp);
      window.addEventListener('pointercancel', onResizeUp);
    }

    let resizeRaf = 0;
    window.addEventListener('resize', () => {
      if (resizeRaf) return;
      resizeRaf = requestAnimationFrame(() => {
        resizeRaf = 0;
        if (panelOpen) applySizeState(sizeState);
      });
    });
    if (resizeHandle) resizeHandle.addEventListener('pointerdown', onResizeDown);
    if (maximizeBtn) maximizeBtn.addEventListener('click', toggleMaximize);
    if (cardBtn) cardBtn.addEventListener('click', toggleCard);
    sizeState = loadSizeState();

    // --- Open / close ---------------------------------------------------------
    function applyStrings() {
      launcher.setAttribute('aria-label', t.launcherLabel);
      launcher.setAttribute('title', t.launcherLabel);
      titleEl.textContent = t.headerTitle;
      subtitleEl.textContent = t.headerSubtitle;
      input.setAttribute('placeholder', t.inputPlaceholder);
      input.setAttribute('aria-label', t.inputPlaceholder);
      sendBtn.setAttribute('aria-label', t.send);
      sendBtn.setAttribute('title', t.send);
      closeBtn.setAttribute('aria-label', t.close);
      closeBtn.setAttribute('title', t.close);
      syncMaximizeAria();
      setCardBtnState();
      if (cardEl) cardEl.setAttribute('aria-label', t.cardTitle || 'Agent Card'); // name the region from the start
      if (resizeHandle) resizeHandle.setAttribute('title', t.resize || 'Drag to resize');
      // Point-of-collection privacy note: text + lang-correct link, then reveal.
      const privacyWrap = document.getElementById('agent-widget-privacy');
      const privacyText = document.getElementById('agent-widget-privacy-text');
      const privacyLink = document.getElementById('agent-widget-privacy-link') as HTMLAnchorElement | null;
      if (privacyWrap && privacyText && privacyLink && t.privacyNote && t.privacyLink) {
        privacyText.textContent = t.privacyNote + ' ';
        privacyLink.textContent = t.privacyLink;
        privacyLink.setAttribute('href', '/' + lang + '/datenschutz');
        privacyWrap.hidden = false;
      }
    }

    const OPEN_KEY = 'bridgeAgentWidgetOpen';
    // The chat is open by default on the CV page. First visit: open only where the
    // two-column layout has room for it (lg+, with the content shift below); stay
    // collapsed on phones and narrow tablets (an open panel would cover the CV).
    // After that, always honor the visitor's last explicit choice.
    const hasRoomForPanel = () => window.matchMedia('(min-width: 1024px)').matches;
    function shouldAutoOpen(): boolean {
      let s: string | null = null;
      try { s = localStorage.getItem(OPEN_KEY); } catch {}
      if (s === 'closed') return false;   // visitor closed it → keep it closed
      if (s === 'open') return true;       // visitor opened it → keep it open
      return hasRoomForPanel();            // first visit: open only with room to spare
    }
    function openPanel(opts: { focus?: boolean; persist?: boolean } = {}) {
      panel.hidden = false;
      panelOpen = true;
      applySizeState(sizeState); // restore persisted size/mode
      launcher.classList.add('aw-hidden');
      launcherLabel?.classList.add('aw-hidden');
      launcher.setAttribute('aria-expanded', 'true');
      document.documentElement.classList.add('aw-panel-open');
      // Shift the centered content left of the fixed panel (two-column layout only).
      if (window.matchMedia('(min-width: 1024px)').matches) {
        document.body.style.paddingRight = '26rem';
      }
      if (!greeted) { addBubble('agent', t.greeting); greeted = true; }
      if (!cardFetched) { cardFetched = true; loadAgentCard(); }
      // Auto-open is not a visitor decision — only persist 'open' when the
      // visitor opened the panel themselves (launcher, label, prompt buttons).
      if (opts.persist !== false) {
        try { localStorage.setItem(OPEN_KEY, 'open'); } catch {}
      }
      // Auto-open (page load) must NOT steal focus or scroll the page to the widget;
      // manual open focuses the input so the visitor can type right away.
      if (opts.focus !== false) setTimeout(() => input.focus({ preventScroll: true }), 50);
    }
    function openPanelWithPrompt(text: string) {
      openPanel();
      if (text.trim()) {
        setTimeout(() => send(text), 80);
      }
    }
    function closePanel() {
      panel.hidden = true;
      panelOpen = false;
      document.documentElement.classList.remove('aw-panel-open');
      document.body.style.paddingRight = '';
      try { localStorage.setItem(OPEN_KEY, 'closed'); } catch {}   // visitor's choice sticks
      if (cardShown) closeCard();   // next open starts on the chat view
      launcher.classList.remove('aw-hidden');
      launcherLabel?.classList.remove('aw-hidden');
      launcher.setAttribute('aria-expanded', 'false');
      launcher.focus();
    }

    applyStrings();
    if (launcherLabel) {
      launcherLabel.querySelector('.aw-label-text')!.textContent = t.launcherText || t.launcherLabel;
      launcherLabel.setAttribute('title', t.launcherLabel);
      launcherLabel.addEventListener('click', () => openPanel());
    }
    launcher.addEventListener('click', () => openPanel());
    window.addEventListener('bridge-agent:prompt', (event) => {
      const custom = event as CustomEvent<{ text?: string }>;
      openPanelWithPrompt(custom.detail?.text || '');
    });
    closeBtn.addEventListener('click', closePanel);
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape' || !panelOpen) return;
      // Layered Escape: back out of the card sub-view first, then close the panel.
      if (cardShown) { closeCard(); input.focus(); } else { closePanel(); }
    });
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const v = input.value;
      input.value = '';
      send(v);
    });

    // Open by default (desktop, first visit; always honor the saved choice) —
    // focus:false so a page load never scrolls to or steals focus for the widget;
    // persist:false so an auto-open is never stored as the visitor's choice.
    if (shouldAutoOpen()) openPanel({ focus: false, persist: false });

    // The page's fact chips describe the LIVE agent, so read them off the live card
    // rather than trusting the hand-written strings the server rendered: those drifted
    // unnoticed (protocolVersion pinned at 0.3 long after the agent moved on, skills
    // stuck at 4 against a card advertising 5). Progressive enhancement — on any
    // failure the server-rendered fallback simply stays. loadAgentCard() de-dupes and
    // caches, so this is at most ONE extra GET of static JSON, and zero when auto-open
    // already fetched it.
    loadAgentCard().then(renderAgentFacts);
  }
</script>
