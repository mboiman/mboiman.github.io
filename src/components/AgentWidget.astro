  }
  .aw-card-desc {
    font-size: 0.82rem; line-height: 1.5; color: var(--text);
    margin: 0 0 0.5rem; white-space: pre-line;
  }
  .aw-card-intro { font-size: 0.72rem; line-height: 1.45; color: var(--text-secondary); margin: 0 0 0.5rem; }

  .aw-card-section { margin-top: 0.7rem; }
  .aw-card-section-h {
    font-size: 0.6875rem; letter-spacing: 0.06em; text-transform: uppercase;
