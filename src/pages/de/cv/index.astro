---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCVData } from '../../../lib/toml-loader';
import { formatToHTML, formatMarkdown } from '../../../lib/markdown';

const data = getCVData('de');
const { profile, contact, ui, experiences, projects, summary, education, language: langs, skills } = data;

const featuredProjects = projects.list.filter(p => p.featured);
const otherProjects = projects.list.filter(p => !p.featured);
---

<BaseLayout
  title={`${profile.name} — CV`}
  description={ui.tagline}
  lang="de"
>
  <!-- Header -->
  <header class="bg-gradient-to-br from-[#0B1120] via-[#0F172A] to-[#162032] text-white pt-6 pb-12 px-6 sm:px-8">
    <div class="max-w-6xl mx-auto">
      <!-- Top bar -->
      <div class="flex items-center justify-between mb-8 text-sm">
        <a href="/de/" class="group opacity-70 hover:opacity-100 transition-all cursor-pointer flex items-center gap-2" style="color: var(--accent)">
          <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
          Experience the Story
        </a>
        <div class="flex items-center gap-3">
          <a href="/de/cv/" class="font-semibold text-white">DE</a>
          <span class="opacity-20">|</span>
          <a href="/en/cv/" class="opacity-40 hover:opacity-100 transition-opacity">EN</a>
        </div>
      </div>

      <!-- Profile -->
      <div class="flex flex-col sm:flex-row items-center sm:items-start gap-8">
        <div class="relative flex-shrink-0">
          <div class="absolute -inset-1 rounded-full opacity-30 blur-sm" style="background: conic-gradient(from 0deg, var(--accent), #5bb8c9, var(--accent))"></div>
          <img src="/images/profile_.jpg" alt={profile.name} class="relative w-28 h-28 rounded-full border-[3px] border-white/10 object-cover" width="112" height="112" />
        </div>
        <div class="flex-1 text-center sm:text-left">
          <h1 class="text-3xl sm:text-4xl font-bold tracking-tight font-heading">{profile.name}</h1>
          <p class="mt-2 text-base sm:text-lg text-white/70">{ui.tagline}</p>

          <!-- Contact -->
          <div class="mt-4 flex flex-wrap items-center justify-center sm:justify-start gap-x-5 gap-y-2 text-sm text-white/50">
            {contact.list.slice(0, 6).map(item => (
              <a href={item.url || '#'} target={item.url?.startsWith('mailto:') ? '_self' : '_blank'} rel="noopener" class="hover:text-white transition-colors cursor-pointer">{item.title}</a>
            ))}
          </div>

          <!-- CTAs -->
          <div class="mt-5 flex flex-wrap justify-center sm:justify-start gap-3">
            <a href="/pdfs/Michael_Boiman_CV_DE.pdf" download class="px-5 py-2.5 rounded-lg border border-white/20 text-sm font-medium hover:bg-white/10 transition-colors cursor-pointer flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
              PDF herunterladen
            </a>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- Main Layout -->
  <div class="max-w-6xl mx-auto px-4 sm:px-8 py-12">
    <div class="flex flex-col lg:flex-row gap-12">

      <!-- Main Content (70%) -->
      <main class="lg:w-[70%] space-y-14">

        <!-- Karriereprofil -->
        {summary.enable && (
          <section>
            <h2 class="cv-section-title">{summary.title}</h2>
            <div class="p-6 rounded-xl border-l-4 bg-[var(--bg-alt)]" style="border-color: var(--accent)">
              <div class="text-[15px] leading-[1.85] [&_strong]:font-semibold [&_strong]:text-[var(--accent)]" set:html={formatToHTML(summary.summary)} />
            </div>
          </section>
        )}

        <!-- PROJEKTE VOR ERFAHRUNG -->
        {projects.enable && (
          <section>
            <h2 class="cv-section-title">{projects.title}</h2>
            <p class="text-sm mb-6" style="color: var(--text-secondary)" set:html={projects.intro} />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {featuredProjects.map(project => (
                <div class="rounded-xl overflow-hidden bg-[var(--bg-alt)] border border-white/[0.04] hover:-translate-y-1 hover:border-[var(--accent)]/30 transition-all duration-300 cursor-pointer group">
                  {project.screenshot && (
                    <div class="h-40 overflow-hidden relative">
                      <img src={`/images/${project.screenshot}`} alt={project.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                      <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
                      <p class="absolute bottom-3 left-4 text-[10px] tracking-[0.2em] uppercase text-white/80">{project.category}</p>
                    </div>
                  )}
                  {!project.screenshot && (
                    <div class="px-5 pt-4">
                      <p class="text-[10px] tracking-[0.2em] uppercase" style="color: var(--accent)">{project.category}</p>
                    </div>
                  )}
                  <div class="p-5">
                    <h3 class="text-base font-semibold font-heading mb-2 leading-tight">
                      {project.url ? (
                        <a href={project.url} target="_blank" rel="noopener" class="hover:text-[var(--accent)] transition-colors inline-flex items-center gap-1.5">
                          {project.title}
                          <svg class="w-3.5 h-3.5 opacity-40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                        </a>
                      ) : project.title}
                    </h3>

                    {project.tech_stack?.length > 0 && (
                      <div class="flex flex-wrap gap-1.5 mb-3">
                        {project.tech_stack.slice(0, 6).map(tech => (
                          <span class="text-[10px] px-2 py-0.5 rounded-md font-medium" style="background: rgba(58,143,160,0.1); color: var(--accent)">{tech}</span>
                        ))}
                        {project.tech_stack.length > 6 && (
                          <span class="text-[10px] px-2 py-0.5 rounded-md" style="color: var(--text-secondary)">+{project.tech_stack.length - 6}</span>
                        )}
                      </div>
                    )}

                    <div class="text-[13px] leading-[1.8] [&_strong]:font-medium [&_strong]:text-[var(--text)]" style="color: var(--text-secondary)" set:html={formatMarkdown(project.tagline)} />
                  </div>
                </div>
              ))}
            </div>

            {otherProjects.length > 0 && (
              <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
                {otherProjects.map(project => (
                  <div class="p-4 rounded-lg bg-[var(--bg-alt)] border border-white/[0.03]">
                    <p class="text-[10px] tracking-[0.15em] uppercase mb-1" style="color: var(--accent)">{project.category}</p>
                    <h4 class="text-sm font-semibold font-heading mb-1">{project.title}</h4>
                    {project.tech_stack?.length > 0 && (
                      <p class="text-[10px]" style="color: var(--text-secondary)">{project.tech_stack.slice(0, 4).join(' · ')}</p>
                    )}
                  </div>
                ))}
              </div>
            )}
          </section>
        )}

        <!-- Berufserfahrung -->
        {experiences.enable && (
          <section>
            <h2 class="cv-section-title">{experiences.title}</h2>
            <div class="space-y-6 relative ml-3 pl-7" style="border-left: 2px solid rgba(58,143,160,0.15)">
              {experiences.list.map((exp, i) => (
                <div class="relative">
                  <!-- Timeline dot -->
                  <div class="absolute -left-[33px] top-2 w-3 h-3 rounded-full border-2 bg-[var(--bg)]" style="border-color: var(--accent)"></div>

                  <div class="p-6 rounded-xl bg-[var(--bg-alt)] border border-white/[0.03]">
                    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-3">
                      <div>
                        <h3 class="text-[15px] font-semibold font-heading leading-snug" style="color: var(--accent)">{exp.position}</h3>
                        <p class="text-sm mt-1 font-medium" style="color: var(--text-secondary)">{exp.company}</p>
                      </div>
                      <span class="text-[11px] font-medium px-2.5 py-1 rounded-md whitespace-nowrap self-start" style="background: rgba(58,143,160,0.12); color: var(--accent)">{exp.dates}</span>
                    </div>
                    <div class="text-[13px] leading-[1.9] [&_strong]:font-medium [&_strong]:text-[var(--accent)] [&_p]:mb-3" style="color: var(--text-secondary)" set:html={formatToHTML(exp.details)} />
                  </div>
                </div>
              ))}
            </div>
          </section>
        )}
      </main>

      <!-- Sidebar (30%) -->
      <aside class="lg:w-[30%]">
        <div class="sticky top-6 space-y-6">

          <!-- Skills -->
          <div class="cv-sidebar-card">
            <h3 class="cv-sidebar-title">{ui.sidebar_skills_title}</h3>
            <div class="flex flex-wrap gap-1.5">
              {ui.sidebar_skills.map(skill => (
                <span class="text-xs px-2.5 py-1 rounded-full border border-white/[0.08] hover:border-[var(--accent)]/40 transition-colors cursor-default" style="color: var(--text-secondary)">{skill}</span>
              ))}
            </div>
          </div>

          <!-- Education -->
          {education.enable && (
            <div class="cv-sidebar-card">
              <h3 class="cv-sidebar-title">{education.title}</h3>
              <div class="space-y-3">
                {education.list.map(edu => (
                  <div>
                    <p class="text-sm font-medium">{edu.degree}</p>
                    {edu.college && <p class="text-xs mt-0.5" style="color: var(--text-secondary)">{edu.college}</p>}
                    <p class="text-xs" style="color: var(--text-secondary)">{edu.dates}</p>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Languages -->
          {langs.enable && (
            <div class="cv-sidebar-card">
              <h3 class="cv-sidebar-title">{langs.title}</h3>
              <div class="space-y-2.5">
                {langs.list.map(l => (
                  <div class="flex justify-between items-center text-sm">
                    <span>{l.language}</span>
                    <span class="text-[11px] px-2.5 py-0.5 rounded-md font-medium" style="background: rgba(58,143,160,0.1); color: var(--accent)">{l.level}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Certifications -->
          <div class="cv-sidebar-card">
            <h3 class="cv-sidebar-title">{ui.sidebar_qualifications_title}</h3>
            <div class="space-y-2.5 text-sm">
              {['ISTQB Certified Tester', 'Dynatrace Diagnostics', 'Agile (Scrum/Kanban)'].map(cert => (
                <div class="flex items-center gap-2.5">
                  <div class="w-1.5 h-1.5 rounded-full flex-shrink-0" style="background: var(--accent)"></div>
                  <span>{cert}</span>
                </div>
              ))}
            </div>
          </div>

        </div>
      </aside>

    </div>
  </div>

  <!-- Footer -->
  <footer class="py-10 px-6 text-center text-sm border-t border-white/[0.04]" style="color: var(--text-secondary)">
    <p>&copy; {new Date().getFullYear()} {profile.name} &middot; BKS-Lab &middot; Frankfurt am Main</p>
    <p class="mt-3 text-xs opacity-60">
      <a href="/de/" class="hover:opacity-100 transition-opacity">Experience the Story</a>
      &nbsp;&middot;&nbsp;
      <a href="/pdfs/Michael_Boiman_CV_DE.pdf" class="hover:opacity-100 transition-opacity">PDF</a>
      &nbsp;&middot;&nbsp;
      <a href="/en/cv/" class="hover:opacity-100 transition-opacity">English</a>
    </p>
  </footer>
</BaseLayout>

<style>
  .cv-section-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--accent);
    color: var(--accent);
    letter-spacing: -0.01em;
  }

  .cv-sidebar-card {
    padding: 1.25rem;
    border-radius: 0.75rem;
    background: var(--bg-alt);
    border: 1px solid rgba(255,255,255,0.03);
  }

  .cv-sidebar-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
</style>
