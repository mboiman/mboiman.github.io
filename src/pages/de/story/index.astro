---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCVData } from '../../../lib/toml-loader';
import { formatToHTML, formatMarkdown } from '../../../lib/markdown';

const data = getCVData('de');
const { profile, contact, ui, experiences, projects, summary, education, language: langs, skills } = data;

const featuredProjects = projects.list.filter(p => p.featured).slice(0, 5);
const recentExp = experiences.list.slice(0, 5);
const olderExp = experiences.list.slice(5);

// Screenshots that work on dark backgrounds
const darkScreenshots: Record<string, string> = {
  'Quality Dashboard - Echtzeit-Übersicht': '/images/projects/qualitydashboard.png',
  'E-Mail-Klassifizierung und -Verarbeitungsprozess': '/images/projects/nlpanalyse.png',
};
---

<BaseLayout
  title={`${profile.name} — ${profile.tagline}`}
  description={ui.tagline}
  lang="de"
>
  <!-- Scroll progress bar -->
  <div id="scroll-progress" style="width: 0%"></div>

  <!-- ═══ FLOATING NAV ═══ -->
  <header>
    <nav class="fixed top-0 left-0 right-0 z-50 no-print nav-glass" id="floating-nav">
      <div class="max-w-6xl mx-auto px-6 py-3 flex items-center justify-between">
        <a href="/pdfs/Michael_Boiman_CV_DE.pdf" download class="text-xs tracking-[0.1em] uppercase opacity-0 hover:opacity-80 transition-all duration-500 cursor-pointer min-h-[44px] min-w-[44px] flex items-center" style="color: var(--text-secondary)" id="nav-pdf" tabindex="-1">
          PDF herunterladen
        </a>
        <div class="flex items-center gap-2 opacity-0 transition-all duration-500" id="nav-right">
          <a href="/de/" class="text-xs font-semibold min-h-[44px] min-w-[44px] flex items-center justify-center" style="color: var(--text)" tabindex="-1">DE</a>
          <span class="text-xs" style="color: var(--text-secondary); opacity: 0.3">|</span>
          <a href="/en/" class="text-xs opacity-50 hover:opacity-100 transition-opacity min-h-[44px] min-w-[44px] flex items-center justify-center" style="color: var(--text-secondary)" tabindex="-1">EN</a>
        </div>
      </div>
    </nav>
  </header>

  <!-- ═══ ACT 1: THE STATEMENT ═══ -->
  <section class="act" aria-label="Statement">
    <div class="text-center max-w-5xl">
      <p class="text-sm tracking-[0.2em] uppercase mb-12 opacity-0 animate-[fadeIn_1s_ease_0.3s_forwards]" style="color: var(--text-secondary)">
        Quality Engineer &middot; AI Architect &middot; System Thinker
      </p>
      <h1 class="text-[clamp(2.5rem,7vw,7rem)] leading-[1.05] tracking-tight opacity-0 animate-[fadeIn_1.2s_ease_0.8s_forwards]">
        Here's to the ones<br>who <em class="italic" style="color: var(--accent)">automate<br class="sm:hidden"> the impossible.</em>
      </h1>
      <div class="mt-16 opacity-0 animate-[fadeIn_1s_ease_2s_forwards]">
        <div class="teal-rule"></div>
      </div>
      <!-- Scroll hint -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 opacity-0 animate-[fadeIn_1s_ease_2.5s_forwards] no-print" aria-hidden="true">
        <svg class="w-5 h-5 animate-[scrollHint_2s_ease-in-out_infinite]" style="color: var(--text-secondary)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7" />
        </svg>
      </div>
    </div>
  </section>

  <main>

  <!-- ═══ ACT 1.5: THE PORTRAIT REVEAL ═══ -->
  <section class="flex flex-col items-center justify-center pt-0 pb-32 px-6 -mt-16 relative z-10" aria-label="Portrait">
    <div class="reveal max-w-md mx-auto">
      <div class="relative">
        <div class="absolute -inset-8 rounded-full opacity-[0.06] blur-3xl" style="background: var(--accent)" aria-hidden="true"></div>
        <img
          src="/images/profile_.jpg"
          alt={profile.name}
          class="relative w-full max-w-[360px] mx-auto rounded-sm"
          style="filter: contrast(1.05); mix-blend-mode: luminosity;"
          width="360"
          height="480"
        />
      </div>
      <p class="text-center mt-10 text-3xl sm:text-4xl tracking-tight" style="font-family: 'Playfair Display', serif">
        {profile.name}
      </p>
      <p class="text-center mt-2 text-sm tracking-[0.15em] uppercase" style="color: var(--accent)">
        Quality Engineer &middot; AI Architect
      </p>
      <p class="text-center mt-2 text-sm tracking-[0.1em]" style="color: var(--text-secondary)">
        Frankfurt am Main
      </p>
    </div>
  </section>

  <!-- ═══ ACT 2: THE NUMBER WALL ═══ -->
  <section class="py-32 px-6" id="main" aria-label="Zahlen" style="background-color: var(--bg-alt)">
    <div class="max-w-4xl mx-auto w-full">
      {[
        { num: '20+', label: 'Jahre im Quality Engineering' },
        { num: '80%', label: 'weniger Aufwand durch Automatisierung' },
        { num: '96%', label: 'Qualität nach Migration — vorher 30%' },
        { num: '4', label: 'Sprachen — DE EN RU HE' },
      ].map((item, i) => (
        <div class="reveal flex flex-col sm:flex-row sm:items-baseline sm:gap-8 py-10 border-b border-white/[0.03] last:border-0" style={`transition-delay: ${i * 120}ms`}>
          <span class="text-[clamp(3.5rem,14vw,12rem)] font-black leading-none tracking-[-0.04em]" style="font-family: 'Playfair Display', serif">
            {item.num}
          </span>
          <span class="text-base sm:text-lg tracking-wide" style="color: var(--text-secondary)">
            {item.label}
          </span>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ ACT 2.5: IMPACT HIGHLIGHTS ═══ -->
  <section class="py-20 px-6" aria-label="Impact">
    <div class="max-w-4xl mx-auto">
      <div class="reveal grid grid-cols-1 sm:grid-cols-3 gap-6">
        {[
          { metric: '-80%', label: 'Rückfragen', detail: 'durch Quality-Monitoring-Systeme' },
          { metric: '96%', label: 'Qualität nach Migration', detail: 'vorher 30% — 24/7 Validierung' },
          { metric: '80%', label: 'auto-generierte Tests', detail: 'KI-gestützte Testautomatisierung' },
        ].map((item, i) => (
          <div class="text-center py-8 reveal" style={`transition-delay: ${i * 150}ms`}>
            <p class="text-4xl sm:text-5xl font-black tracking-tight" style="font-family: 'Playfair Display', serif; color: var(--accent)">{item.metric}</p>
            <p class="text-sm font-medium mt-3">{item.label}</p>
            <p class="text-xs mt-1" style="color: var(--text-secondary)">{item.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ ACT 3: THE ORIGIN (kompakt) ═══ -->
  <section class="py-32 px-6" aria-label="Profil">
    <div class="prose-column">
      <div class="reveal">
        <div class="teal-rule mb-20"></div>
        <p class="text-xl sm:text-2xl leading-[1.8] font-light" style="font-family: 'Playfair Display', serif; font-style: italic; color: var(--text-secondary)">
          Alles, was KI heute braucht — Verlässlichkeit, Messbarkeit, Selbstkorrektur — habe ich 20 Jahre lang in Systeme eingebaut, die noch nicht denken konnten. Als LLMs kamen, fehlte kein neuer Anfang. Es fehlte nur noch das letzte Puzzlestück.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ ACT 4: SELECTED WORKS ═══ -->
  <section aria-label="Projekte">
    {featuredProjects.map((project, i) => {
      const bgImage = darkScreenshots[project.title];
      return (
        <div
          class={`relative px-6 py-24 reveal overflow-hidden`}
          style={`transition-delay: ${i * 80}ms; background-color: ${i % 2 === 0 ? 'var(--bg-alt)' : 'var(--bg)'}`}
        >
          {bgImage && (
            <div class="absolute inset-0 opacity-[0.04] bg-cover bg-center" style={`background-image: url('${bgImage}')`}></div>
          )}
          <div class="relative max-w-5xl mx-auto">
            <p class="text-[10px] tracking-[0.25em] uppercase mb-4" style="color: var(--accent)">{project.category}</p>
            <h3 class="text-2xl sm:text-4xl mb-5 tracking-tight" style="font-family: 'Playfair Display', serif">{project.title}</h3>

            {project.tech_stack?.length > 0 && (
              <p class="text-sm mb-8 tracking-wide" style="color: var(--text-secondary)">
                {project.tech_stack.join(' · ')}
              </p>
            )}

            <div class="max-w-3xl text-base leading-relaxed [&_strong]:text-[var(--text)] [&_strong]:font-medium" style="color: var(--text-secondary)" set:html={formatMarkdown(project.tagline)} />
          </div>
        </div>
      );
    })}
  </section>

  <!-- ═══ ACT 5: THE SYSTEM THINKER ═══ -->
  <section class="py-32 px-6" aria-label="System">
    <div class="max-w-3xl mx-auto w-full">
      <div class="reveal overflow-hidden rounded-lg" style="background: var(--bg-alt); border: 1px solid rgba(255,255,255,0.06)">
        <!-- Terminal title bar -->
        <div class="flex items-center gap-2 px-5 py-3" style="background: rgba(255,255,255,0.03); border-bottom: 1px solid rgba(255,255,255,0.04)">
          <span class="w-3 h-3 rounded-full" style="background: #ff5f57"></span>
          <span class="w-3 h-3 rounded-full" style="background: #febc2e"></span>
          <span class="w-3 h-3 rounded-full" style="background: #28c840"></span>
          <span class="ml-4 text-xs" style="color: var(--text-secondary); font-family: 'JetBrains Mono', monospace;">cockpit — zsh</span>
        </div>

        <!-- Terminal body -->
        <div class="terminal p-6 sm:p-12">
          <p class="mb-6"><span class="prompt">$</span> cockpit status</p>

          <div class="grid gap-y-1" style="grid-template-columns: max-content 1fr;">
            {[
              ['repos', '23 active'],
              ['skills', '40+ production'],
              ['agents', 'multi-agent orchestration'],
              ['protocols', 'MCP, A2A, JSON-RPC 2.0'],
              ['stack', 'Python, Rust, Go, TypeScript'],
              ['spoken', 'DE  EN  RU  HE'],
            ].map(([key, value]) => (
              <>
                <span class="pr-4 sm:pr-6" style="color: var(--text)">&nbsp;&nbsp;{key}</span>
                <span style={`color: ${key === 'spoken' ? 'var(--text-secondary)' : 'var(--text)'}`}>{value}</span>
              </>
            ))}
          </div>

          <p class="mt-6">
            &nbsp;&nbsp;<span style="color: var(--text-secondary)">one cockpit. every system. zero friction.</span>
            <span class="inline-block w-2 h-4 ml-1 animate-pulse" style="background: var(--accent); vertical-align: middle;" aria-hidden="true"></span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ ACT 6: BELIEFS ═══ -->
  <section class="py-32 px-6" aria-label="Überzeugungen" style="background-color: var(--bg-alt)">
    <div class="max-w-4xl mx-auto">
      {[
        { text: 'Wenn du 10 Tools hast\nund keine Übersicht,\nhast du null Tools.', align: 'text-left' },
        { text: 'Eine Million Kombinationen\ntestet kein Mensch.\nAber eine Maschine,\ndie nie schläft, schon.', align: 'text-center' },
        { text: 'Der beste Test ist der,\nden ein Entwickler\nnie schreiben musste.', align: 'text-right' },
        { text: 'Automatisierung ohne Messbarkeit\nist nur schnelleres Raten.', align: 'text-left' },
      ].map((belief, i) => (
        <div class={`reveal py-14 ${i < 3 ? 'border-b border-white/[0.03]' : ''}`} style={`transition-delay: ${i * 200}ms`}>
          <div class={`relative max-w-2xl ${belief.align === 'text-right' ? 'ml-auto' : belief.align === 'text-center' ? 'mx-auto' : ''}`}>
            <span class="absolute -top-6 -left-3 text-[5rem] leading-none select-none pointer-events-none" style="font-family: 'Playfair Display', serif; color: var(--accent); opacity: 0.06;" aria-hidden="true">&ldquo;</span>
            <p class={`text-xl sm:text-2xl leading-snug whitespace-pre-line ${belief.align}`} style="font-family: 'Playfair Display', serif; font-style: italic; color: var(--text-secondary)">
              {belief.text}
            </p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ ACT 7: EXPERIENCE ═══ -->
  <section class="py-32 px-6" aria-label="Berufserfahrung">
    <div class="max-w-4xl mx-auto">
      <div class="teal-rule mb-20"></div>
      <h2 class="text-3xl sm:text-4xl text-center mb-20 reveal" style="font-family: 'Playfair Display', serif">Berufserfahrung</h2>

      <!-- Recent: full details -->
      {recentExp.map((exp, i) => (
        <div class="reveal mb-16 last:mb-0" style={`transition-delay: ${Math.min(i * 60, 300)}ms`}>
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-3">
            <h3 class="text-lg font-sans font-medium" style="color: var(--accent)">{exp.position}</h3>
            <span class="text-sm whitespace-nowrap" style="color: var(--text-secondary)">{exp.dates}</span>
          </div>
          <p class="text-sm mb-4" style="color: var(--text-secondary)">{exp.company}</p>
          <div class="text-sm leading-[1.9] [&_strong]:text-[var(--accent)] [&_strong]:font-medium" style="color: var(--text-secondary)" set:html={formatToHTML(exp.details)} />
          {i < recentExp.length - 1 && (
            <div class="border-b border-white/[0.03] mt-16"></div>
          )}
        </div>
      ))}

      <!-- Older: compact -->
      {olderExp.length > 0 && (
        <div class="mt-20 reveal">
          <div class="border-b border-white/[0.03] mb-10"></div>
          <p class="text-xs tracking-[0.2em] uppercase mb-8" style="color: var(--text-secondary)">Fruehere Positionen</p>
          {olderExp.map((exp) => (
            <div class="exp-compact">
              <div>
                <span class="text-sm font-medium" style="color: var(--text)">{exp.position}</span>
                <span class="text-sm ml-2" style="color: var(--text-secondary)">— {exp.company}</span>
              </div>
              <span class="text-xs whitespace-nowrap" style="color: var(--text-secondary)">{exp.dates}</span>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- ═══ ACT 7.5: EDUCATION & SKILLS ═══ -->
  <section class="py-20 px-6" aria-label="Ausbildung" style="background-color: var(--bg-alt)">
    <div class="max-w-4xl mx-auto reveal">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-12 text-sm">
        <!-- Education -->
        <div>
          <p class="text-[10px] tracking-[0.25em] uppercase mb-4" style="color: var(--accent)">{education.title}</p>
          {education.list.map(edu => (
            <div class="mb-3">
              <p class="font-medium">{edu.degree}</p>
              {edu.college && <p style="color: var(--text-secondary)">{edu.college}</p>}
              <p class="text-xs" style="color: var(--text-secondary)">{edu.dates}</p>
            </div>
          ))}
        </div>

        <!-- Languages -->
        <div>
          <p class="text-[10px] tracking-[0.25em] uppercase mb-4" style="color: var(--accent)">{langs.title}</p>
          {langs.list.map(l => (
            <div class="flex justify-between mb-2">
              <span>{l.language}</span>
              <span style="color: var(--text-secondary)">{l.level}</span>
            </div>
          ))}
        </div>

        <!-- Key Skills -->
        <div>
          <p class="text-[10px] tracking-[0.25em] uppercase mb-4" style="color: var(--accent)">Skills</p>
          <p class="leading-relaxed" style="color: var(--text-secondary)">
            {ui.sidebar_skills.join(' · ')}
          </p>
        </div>
      </div>
    </div>
  </section>

  </main>

  <!-- ═══ ACT 8: CLOSE ═══ -->
  <footer>
  <section class="act" aria-label="Kontakt">
    <div class="text-center reveal">
      <p class="text-5xl sm:text-7xl lg:text-8xl mb-6 tracking-tight" style="font-family: 'Playfair Display', serif">{profile.name}</p>
      <p class="text-sm tracking-[0.2em] uppercase mb-10" style="color: var(--text-secondary)">
        BKS-Lab — AI Engineering &middot; Frankfurt am Main
      </p>
      <a href="mailto:mboiman@gmail.com" class="text-lg transition-colors duration-300 hover:opacity-80" style="color: var(--accent)">
        mboiman@gmail.com
      </a>
      <p class="mt-4 text-sm" style="color: var(--text-secondary)">
        <a href="https://www.linkedin.com/in/mboiman/" target="_blank" rel="noopener" class="hover:text-[var(--text)] transition-colors">LinkedIn</a>
        &nbsp;&middot;&nbsp;
        <a href="https://github.com/mboiman" target="_blank" rel="noopener" class="hover:text-[var(--text)] transition-colors">GitHub</a>
        &nbsp;&middot;&nbsp;
        <a href="https://bks-lab.com" target="_blank" rel="noopener" class="hover:text-[var(--text)] transition-colors">BKS-Lab</a>
      </p>

      <p class="mt-16 text-xs no-print" style="color: var(--text-secondary); opacity: 0.4">
        <a href="/de/" class="hover:opacity-100 transition-opacity">Klassischer Lebenslauf</a>
        &nbsp;&middot;&nbsp;
        <a href="/pdfs/Michael_Boiman_CV_DE.pdf" class="hover:opacity-100 transition-opacity">PDF</a>
        &nbsp;&middot;&nbsp;
        <a href="/en/" class="hover:opacity-100 transition-opacity">English</a>
      </p>
    </div>
  </section>

  </footer>

  <!-- Scripts -->
  <script>
    // Floating nav
    const navPdf = document.getElementById('nav-pdf');
    const navRight = document.getElementById('nav-right');
    // Scroll progress
    const progressBar = document.getElementById('scroll-progress');

    window.addEventListener('scroll', () => {
      const y = window.scrollY;
      // Nav visibility + tabindex
      const show = y > 300;
      [navPdf, navRight].forEach(el => {
        if (show) { el?.classList.remove('opacity-0'); el?.classList.add('opacity-100'); }
        else { el?.classList.add('opacity-0'); el?.classList.remove('opacity-100'); }
      });
      // Make nav links tabbable only when visible
      document.querySelectorAll('#floating-nav a').forEach(a => {
        (a as HTMLElement).tabIndex = show ? 0 : -1;
      });
      // Progress bar
      const max = document.documentElement.scrollHeight - window.innerHeight;
      if (progressBar && max > 0) {
        progressBar.style.width = `${(y / max) * 100}%`;
      }
    });
  </script>
</BaseLayout>
