---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCVData } from '../../../lib/toml-loader';
import { formatToHTML } from '../../../lib/markdown';

const data = getCVData('en');
const { profile, contact, ui, experiences, projects, summary, education, language: langs, skills } = data;

const featuredProjects = projects.list.filter(p => p.featured);
const otherProjects = projects.list.filter(p => !p.featured);
---

<BaseLayout
  title={`${profile.name} — CV`}
  description={ui.tagline}
  lang="en"
>
  <!-- Header -->
  <header class="bg-gradient-to-r from-[#0F172A] to-[#1E293B] text-white pt-6 pb-10 px-6 sm:px-8">
    <div class="max-w-6xl mx-auto">
      <!-- Top bar -->
      <div class="flex items-center justify-between mb-6 text-sm">
        <a href="/en/" class="opacity-60 hover:opacity-100 transition-opacity cursor-pointer flex items-center gap-1.5" style="color: var(--accent)">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
          Experience the Story
        </a>
        <div class="flex items-center gap-3">
          <a href="/de/cv/" class="opacity-50 hover:opacity-100 transition-opacity">DE</a>
          <span class="opacity-30">|</span>
          <a href="/en/cv/" class="font-semibold">EN</a>
        </div>
      </div>

      <!-- Profile -->
      <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6">
        <img src="/images/profile_.jpg" alt={profile.name} class="w-24 h-24 rounded-full border-3 border-white/20 object-cover" width="96" height="96" />
        <div class="flex-1 text-center sm:text-left">
          <h1 class="text-3xl sm:text-4xl font-bold tracking-tight font-heading">{profile.name}</h1>
          <p class="mt-1 text-lg" style="color: var(--accent)">{profile.tagline}</p>

          <!-- Contact -->
          <div class="mt-3 flex flex-wrap items-center justify-center sm:justify-start gap-x-5 gap-y-1 text-sm text-white/60">
            {contact.list.slice(0, 5).map(item => (
              <a href={item.url || '#'} target={item.url?.startsWith('mailto:') ? '_self' : '_blank'} rel="noopener" class="hover:text-white transition-colors">{item.title}</a>
            ))}
          </div>

          <!-- CTAs -->
          <div class="mt-4 flex flex-wrap justify-center sm:justify-start gap-3">
            <a href="/pdfs/Michael_Boiman_CV_EN.pdf" download class="px-4 py-2 rounded-lg border border-white/20 text-sm font-medium hover:bg-white/10 transition-colors cursor-pointer flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
              Download PDF
            </a>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- Main Layout -->
  <div class="max-w-6xl mx-auto px-4 sm:px-8 py-10">
    <div class="flex flex-col lg:flex-row gap-10">

      <!-- Main Content (70%) -->
      <main class="lg:w-[70%] space-y-10">

        <!-- Karriereprofil -->
        {summary.enable && (
          <section>
            <h2 class="text-xl font-bold font-heading mb-4 flex items-center gap-2" style="color: var(--accent)">{summary.title}</h2>
            <div class="p-5 rounded-xl border-l-4 bg-[var(--bg-alt)]" style="border-color: var(--accent)">
              <div class="text-sm leading-relaxed [&_strong]:font-semibold [&_strong]:text-[var(--accent)]" set:html={formatToHTML(summary.summary)} />
            </div>
          </section>
        )}

        <!-- Berufserfahrung -->
        {experiences.enable && (
          <section>
            <h2 class="text-xl font-bold font-heading mb-6 flex items-center gap-2" style="color: var(--accent)">{experiences.title}</h2>
            <div class="space-y-6 relative ml-3 border-l-2 border-[var(--accent)]/20 pl-6">
              {experiences.list.map(exp => (
                <div class="relative">
                  <div class="absolute -left-[31px] top-1 w-3 h-3 rounded-full border-2 bg-[var(--bg)]" style="border-color: var(--accent)"></div>
                  <div class="p-5 rounded-xl bg-[var(--bg-alt)] border border-white/[0.03]">
                    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-2">
                      <h3 class="text-base font-semibold font-heading" style="color: var(--accent)">{exp.position}</h3>
                      <span class="text-xs font-medium px-2.5 py-1 rounded-lg whitespace-nowrap" style="background: var(--accent); color: white; opacity: 0.8">{exp.dates}</span>
                    </div>
                    <p class="text-sm mb-3" style="color: var(--text-secondary)">{exp.company}</p>
                    <div class="text-sm leading-relaxed [&_strong]:font-medium [&_strong]:text-[var(--accent)]" style="color: var(--text-secondary)" set:html={formatToHTML(exp.details)} />
                  </div>
                </div>
              ))}
            </div>
          </section>
        )}

        <!-- Projekte -->
        {projects.enable && (
          <section>
            <h2 class="text-xl font-bold font-heading mb-6 flex items-center gap-2" style="color: var(--accent)">{projects.title}</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              {featuredProjects.map(project => (
                <div class="rounded-xl overflow-hidden bg-[var(--bg-alt)] border border-white/[0.03] hover:-translate-y-1 transition-all duration-300 cursor-pointer group">
                  {project.screenshot && (
                    <div class="h-36 overflow-hidden">
                      <img src={`/images/${project.screenshot}`} alt={project.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                    </div>
                  )}
                  <div class="p-4">
                    <p class="text-[10px] tracking-[0.2em] uppercase mb-1" style="color: var(--accent)">{project.category}</p>
                    <h3 class="text-sm font-semibold font-heading mb-2">{project.title}</h3>
                    {project.tech_stack?.length > 0 && (
                      <div class="flex flex-wrap gap-1 mb-2">
                        {project.tech_stack.slice(0, 5).map(tech => (
                          <span class="text-[10px] px-2 py-0.5 rounded" style="background: rgba(58,143,160,0.1); color: var(--accent)">{tech}</span>
                        ))}
                      </div>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </section>
        )}
      </main>

      <!-- Sidebar (30%) -->
      <aside class="lg:w-[30%]">
        <div class="sticky top-6 space-y-6">

          <!-- Skills -->
          <div class="p-5 rounded-xl bg-[var(--bg-alt)] border border-white/[0.03]">
            <h3 class="text-sm font-bold font-heading mb-3 pb-2 border-b border-white/[0.05]" style="color: var(--accent)">{ui.sidebar_skills_title}</h3>
            <div class="flex flex-wrap gap-1.5">
              {ui.sidebar_skills.map(skill => (
                <span class="text-xs px-2.5 py-1 rounded-full border border-white/[0.06]" style="color: var(--text-secondary)">{skill}</span>
              ))}
            </div>
          </div>

          <!-- Education -->
          {education.enable && (
            <div class="p-5 rounded-xl bg-[var(--bg-alt)] border border-white/[0.03]">
              <h3 class="text-sm font-bold font-heading mb-3 pb-2 border-b border-white/[0.05]" style="color: var(--accent)">{education.title}</h3>
              <div class="space-y-3">
                {education.list.map(edu => (
                  <div>
                    <p class="text-sm font-medium">{edu.degree}</p>
                    {edu.college && <p class="text-xs" style="color: var(--text-secondary)">{edu.college}</p>}
                    <p class="text-xs" style="color: var(--text-secondary)">{edu.dates}</p>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Languages -->
          {langs.enable && (
            <div class="p-5 rounded-xl bg-[var(--bg-alt)] border border-white/[0.03]">
              <h3 class="text-sm font-bold font-heading mb-3 pb-2 border-b border-white/[0.05]" style="color: var(--accent)">{langs.title}</h3>
              <div class="space-y-2">
                {langs.list.map(l => (
                  <div class="flex justify-between text-sm">
                    <span>{l.language}</span>
                    <span class="text-xs px-2 py-0.5 rounded" style="background: rgba(58,143,160,0.1); color: var(--accent)">{l.level}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Certifications -->
          <div class="p-5 rounded-xl bg-[var(--bg-alt)] border border-white/[0.03]">
            <h3 class="text-sm font-bold font-heading mb-3 pb-2 border-b border-white/[0.05]" style="color: var(--accent)">{ui.sidebar_qualifications_title}</h3>
            <div class="space-y-2 text-sm">
              <div class="flex items-center gap-2">
                <div class="w-1.5 h-1.5 rounded-full" style="background: var(--accent)"></div>
                ISTQB Certified Tester
              </div>
              <div class="flex items-center gap-2">
                <div class="w-1.5 h-1.5 rounded-full" style="background: var(--accent)"></div>
                Dynatrace Diagnostics
              </div>
              <div class="flex items-center gap-2">
                <div class="w-1.5 h-1.5 rounded-full" style="background: var(--accent)"></div>
                Agile (Scrum/Kanban)
              </div>
            </div>
          </div>

        </div>
      </aside>

    </div>
  </div>

  <!-- Footer -->
  <footer class="py-8 px-6 text-center text-sm border-t border-white/[0.03]" style="color: var(--text-secondary)">
    <p>&copy; {new Date().getFullYear()} {profile.name} &middot; BKS-Lab</p>
    <p class="mt-2 text-xs">
      <a href="/en/" class="hover:text-[var(--accent)] transition-colors">Experience the Story</a>
      &nbsp;&middot;&nbsp;
      <a href="/pdfs/Michael_Boiman_CV_EN.pdf" class="hover:text-[var(--accent)] transition-colors">PDF</a>
    </p>
  </footer>
</BaseLayout>
