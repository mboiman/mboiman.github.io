---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCVData } from '../../lib/toml-loader';
import { formatToHTML, formatMarkdown } from '../../lib/markdown';

const data = getCVData('en');
const { profile, contact, ui, experiences, projects, summary, education, language: langs, skills } = data;

const featuredProjects = projects.list.filter(p => p.featured).slice(0, 5);
const recentExp = experiences.list.slice(0, 5);
const olderExp = experiences.list.slice(5);

const darkScreenshots: Record<string, string> = {
  'Quality Dashboard - Real-time Overview': '/images/projects/qualitydashboard.png',
  'Email Classification and Processing Workflow': '/images/projects/nlpanalyse.png',
};
---

<BaseLayout
  title={`${profile.name} — ${profile.tagline}`}
  description={ui.tagline}
  lang="en"
>
  <div id="scroll-progress" style="width: 0%"></div>

  <header>
    <nav class="fixed top-0 left-0 right-0 z-50 no-print nav-glass" id="floating-nav">
      <div class="max-w-6xl mx-auto px-6 py-3 flex items-center justify-between">
        <a href="/pdfs/Michael_Boiman_CV_EN.pdf" download class="text-xs tracking-[0.1em] uppercase opacity-0 hover:opacity-80 transition-all duration-500 cursor-pointer min-h-[44px] min-w-[44px] flex items-center" style="color: var(--text-secondary)" id="nav-pdf" tabindex="-1">Download PDF</a>
        <div class="flex items-center gap-2 opacity-0 transition-all duration-500" id="nav-right">
          <a href="/de/" class="text-xs opacity-50 hover:opacity-100 transition-opacity min-h-[44px] min-w-[44px] flex items-center justify-center" style="color: var(--text-secondary)" tabindex="-1">DE</a>
          <span class="text-xs" style="color: var(--text-secondary); opacity: 0.3">|</span>
          <a href="/en/" class="text-xs font-semibold min-h-[44px] min-w-[44px] flex items-center justify-center" style="color: var(--text)" tabindex="-1">EN</a>
        </div>
      </div>
    </nav>
  </header>

  <section class="act" aria-label="Statement">
    <div class="text-center max-w-5xl">
      <p class="text-sm tracking-[0.2em] uppercase mb-12 opacity-0 animate-[fadeIn_1s_ease_0.3s_forwards]" style="color: var(--text-secondary)">
        Quality Engineer &middot; AI Architect &middot; System Thinker
      </p>
      <h1 class="text-[clamp(2.5rem,7vw,7rem)] leading-[1.05] tracking-tight opacity-0 animate-[fadeIn_1.2s_ease_0.8s_forwards]">
        Here's to the ones<br>who <em class="italic" style="color: var(--accent)">automate<br class="sm:hidden"> the impossible.</em>
      </h1>
      <div class="mt-16 opacity-0 animate-[fadeIn_1s_ease_2s_forwards]">
        <div class="teal-rule"></div>
      </div>
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 opacity-0 animate-[fadeIn_1s_ease_2.5s_forwards] no-print" aria-hidden="true">
        <svg class="w-5 h-5 animate-[scrollHint_2s_ease-in-out_infinite]" style="color: var(--text-secondary)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7" />
        </svg>
      </div>
    </div>
  </section>

  <main>

  <section class="flex flex-col items-center justify-center py-24 px-6" aria-label="Portrait">
    <div class="reveal max-w-md mx-auto">
      <img src="/images/profile_.jpg" alt={profile.name} class="w-full max-w-[360px] mx-auto rounded-sm" style="filter: contrast(1.05); mix-blend-mode: luminosity;" width="360" height="480" />
      <p class="text-center mt-8 text-3xl sm:text-4xl tracking-tight" style="font-family: 'Playfair Display', serif">{profile.name}</p>
      <p class="text-center mt-3 text-sm tracking-[0.1em]" style="color: var(--text-secondary)">Frankfurt am Main</p>
    </div>
  </section>

  <section class="py-32 px-6" id="main" aria-label="Numbers" style="background-color: var(--bg-alt)">
    <div class="max-w-4xl mx-auto w-full">
      {[
        { num: '20+', label: 'years shipping software quality' },
        { num: '40+', label: 'production AI skills built' },
        { num: '20+', label: 'repositories — one cockpit' },
        { num: '4', label: 'languages spoken' },
      ].map((item, i) => (
        <div class="reveal flex items-baseline gap-8 py-10 border-b border-white/[0.03] last:border-0" style={`transition-delay: ${i * 120}ms`}>
          <span class="text-[clamp(3.5rem,14vw,12rem)] font-black leading-none tracking-[-0.04em]" style="font-family: 'Playfair Display', serif">{item.num}</span>
          <span class="text-base sm:text-lg tracking-wide" style="color: var(--text-secondary)">{item.label}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="py-32 px-6" aria-label="Profile">
    <div class="prose-column">
      <div class="reveal">
        <div class="teal-rule mb-20"></div>
        <p class="text-xl sm:text-2xl leading-[1.8] font-light" style="font-family: 'Playfair Display', serif; font-style: italic; color: var(--text-secondary)">
          20 years of quality engineering. Then AI arrived — and the same principles held: structure, observability, relentless automation. The tools changed. The thinking didn't.
        </p>
      </div>
    </div>
  </section>

  <section aria-label="Projects">
    {featuredProjects.map((project, i) => {
      const bgImage = darkScreenshots[project.title];
      return (
        <div class="relative px-6 py-24 reveal overflow-hidden" style={`transition-delay: ${i * 80}ms; background-color: ${i % 2 === 0 ? 'var(--bg-alt)' : 'var(--bg)'}`}>
          {bgImage && (<div class="absolute inset-0 opacity-[0.04] bg-cover bg-center" style={`background-image: url('${bgImage}')`}></div>)}
          <div class="relative max-w-5xl mx-auto">
            <p class="text-[10px] tracking-[0.25em] uppercase mb-4" style="color: var(--accent)">{project.category}</p>
            <h3 class="text-2xl sm:text-4xl mb-5 tracking-tight" style="font-family: 'Playfair Display', serif">{project.title}</h3>
            {project.tech_stack?.length > 0 && (<p class="text-sm mb-8 tracking-wide" style="color: var(--text-secondary)">{project.tech_stack.join(' · ')}</p>)}
            <div class="max-w-3xl text-base leading-relaxed [&_strong]:text-[var(--text)] [&_strong]:font-medium" style="color: var(--text-secondary)" set:html={formatMarkdown(project.tagline)} />
          </div>
        </div>
      );
    })}
  </section>

  <section class="py-32 px-6" aria-label="System">
    <div class="max-w-3xl mx-auto w-full">
      <div class="reveal terminal p-10 sm:p-14" style="background: var(--bg-alt); border-left: 2px solid var(--accent)">
        <p><span class="prompt">$</span> cockpit status</p>
        <br>
        <p>&nbsp;&nbsp;repos &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;23 active</p>
        <p>&nbsp;&nbsp;skills &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;40+ production</p>
        <p>&nbsp;&nbsp;agents &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;multi-agent orchestration</p>
        <p>&nbsp;&nbsp;protocols &nbsp;&nbsp;&nbsp;&nbsp;MCP, A2A, JSON-RPC 2.0</p>
        <p>&nbsp;&nbsp;stack &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Python, Rust, Go, TypeScript</p>
        <p>&nbsp;&nbsp;spoken &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span style="color: var(--text-secondary)">DE&nbsp; EN&nbsp; RU&nbsp; HE</span></p>
        <br>
        <p>&nbsp;&nbsp;<span style="color: var(--text-secondary)">one cockpit. every system. zero friction.</span></p>
      </div>
    </div>
  </section>

  <section class="py-32 px-6" aria-label="Beliefs" style="background-color: var(--bg-alt)">
    <div class="text-center max-w-3xl mx-auto space-y-20">
      {[
        'Quality is architecture,\nnot afterthought.',
        'The best automation\nis the one nobody notices.',
        'Teach the craft.\nDon\'t hoard it.',
      ].map((belief, i) => (
        <p class="text-2xl sm:text-3xl leading-snug reveal whitespace-pre-line" style={`transition-delay: ${i * 200}ms; font-family: 'Playfair Display', serif; font-style: italic; color: var(--text-secondary)`}>{belief}</p>
      ))}
    </div>
  </section>

  <section class="py-32 px-6" aria-label="Experience">
    <div class="max-w-4xl mx-auto">
      <div class="teal-rule mb-20"></div>
      <h2 class="text-3xl sm:text-4xl text-center mb-20 reveal" style="font-family: 'Playfair Display', serif">Professional Experience</h2>
      {recentExp.map((exp, i) => (
        <div class="reveal mb-16 last:mb-0" style={`transition-delay: ${Math.min(i * 60, 300)}ms`}>
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-3">
            <h3 class="text-lg font-sans font-medium" style="color: var(--accent)">{exp.position}</h3>
            <span class="text-sm whitespace-nowrap" style="color: var(--text-secondary)">{exp.dates}</span>
          </div>
          <p class="text-sm mb-4" style="color: var(--text-secondary)">{exp.company}</p>
          <div class="text-sm leading-[1.9] [&_strong]:text-[var(--accent)] [&_strong]:font-medium" style="color: var(--text-secondary)" set:html={formatToHTML(exp.details)} />
          {i < recentExp.length - 1 && (<div class="border-b border-white/[0.03] mt-16"></div>)}
        </div>
      ))}
      {olderExp.length > 0 && (
        <div class="mt-20 reveal">
          <div class="border-b border-white/[0.03] mb-10"></div>
          <p class="text-xs tracking-[0.2em] uppercase mb-8" style="color: var(--text-secondary)">Earlier Positions</p>
          {olderExp.map(exp => (
            <div class="exp-compact">
              <div>
                <span class="text-sm font-medium" style="color: var(--text)">{exp.position}</span>
                <span class="text-sm ml-2" style="color: var(--text-secondary)">— {exp.company}</span>
              </div>
              <span class="text-xs whitespace-nowrap" style="color: var(--text-secondary)">{exp.dates}</span>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="py-20 px-6" aria-label="Education" style="background-color: var(--bg-alt)">
    <div class="max-w-4xl mx-auto reveal">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-12 text-sm">
        <div>
          <p class="text-[10px] tracking-[0.25em] uppercase mb-4" style="color: var(--accent)">{education.title}</p>
          {education.list.map(edu => (
            <div class="mb-3">
              <p class="font-medium">{edu.degree}</p>
              {edu.college && <p style="color: var(--text-secondary)">{edu.college}</p>}
              <p class="text-xs" style="color: var(--text-secondary)">{edu.dates}</p>
            </div>
          ))}
        </div>
        <div>
          <p class="text-[10px] tracking-[0.25em] uppercase mb-4" style="color: var(--accent)">{langs.title}</p>
          {langs.list.map(l => (
            <div class="flex justify-between mb-2">
              <span>{l.language}</span>
              <span style="color: var(--text-secondary)">{l.level}</span>
            </div>
          ))}
        </div>
        <div>
          <p class="text-[10px] tracking-[0.25em] uppercase mb-4" style="color: var(--accent)">Skills</p>
          <p class="leading-relaxed" style="color: var(--text-secondary)">{ui.sidebar_skills.join(' · ')}</p>
        </div>
      </div>
    </div>
  </section>

  </main>

  <footer>
  <section class="act" aria-label="Contact">
    <div class="text-center reveal">
      <p class="text-5xl sm:text-7xl lg:text-8xl mb-6 tracking-tight" style="font-family: 'Playfair Display', serif">{profile.name}</p>
      <p class="text-sm tracking-[0.2em] uppercase mb-10" style="color: var(--text-secondary)">BKS-Lab — AI Engineering &middot; Frankfurt am Main</p>
      <a href="mailto:mboiman@gmail.com" class="text-lg transition-colors duration-300 hover:opacity-80" style="color: var(--accent)">mboiman@gmail.com</a>
      <p class="mt-4 text-sm" style="color: var(--text-secondary)">
        <a href="https://www.linkedin.com/in/mboiman/" target="_blank" rel="noopener" class="hover:text-[var(--text)] transition-colors">LinkedIn</a>
        &nbsp;&middot;&nbsp;
        <a href="https://github.com/mboiman" target="_blank" rel="noopener" class="hover:text-[var(--text)] transition-colors">GitHub</a>
        &nbsp;&middot;&nbsp;
        <a href="https://bks-lab.com" target="_blank" rel="noopener" class="hover:text-[var(--text)] transition-colors">BKS-Lab</a>
      </p>
      <p class="mt-16 text-xs no-print" style="color: var(--text-secondary); opacity: 0.4">
        <a href="/en/cv/" class="hover:opacity-100 transition-opacity">Classic CV</a>
        &nbsp;&middot;&nbsp;
        <a href="/pdfs/Michael_Boiman_CV_EN.pdf" class="hover:opacity-100 transition-opacity">PDF</a>
        &nbsp;&middot;&nbsp;
        <a href="/de/" class="hover:opacity-100 transition-opacity">Deutsche Version</a>
      </p>
    </div>
  </section>

  </footer>

  <script>
    const navPdf = document.getElementById('nav-pdf');
    const navRight = document.getElementById('nav-right');
    const progressBar = document.getElementById('scroll-progress');
    window.addEventListener('scroll', () => {
      const y = window.scrollY;
      const show = y > 300;
      [navPdf, navRight].forEach(el => {
        if (show) { el?.classList.remove('opacity-0'); el?.classList.add('opacity-100'); }
        else { el?.classList.add('opacity-0'); el?.classList.remove('opacity-100'); }
      });
      document.querySelectorAll('#floating-nav a').forEach(a => {
        (a as HTMLElement).tabIndex = show ? 0 : -1;
      });
      const max = document.documentElement.scrollHeight - window.innerHeight;
      if (progressBar && max > 0) progressBar.style.width = `${(y / max) * 100}%`;
    });
  </script>
</BaseLayout>
